// ==UserScript==
// @name         Overleaf GitHub Shortcut
// @namespace    http://tampermonkey.net/
// @version      1.0
// @description  Add a GitHub integration shortcut next to the PDF/ZIP controls in Overleaf
// @author       You
// @match        https://*.overleaf.com/*
// @grant        none
// @run-at       document-idle
// ==/UserScript==

(function () {
    'use strict';

    if (window.__overleafGitHubShortcutInitialized) return;
    window.__overleafGitHubShortcutInitialized = true;

    const BUTTON_CLASS = 'custom-github-shortcut-btn';
    const STATUS_ID = 'custom-github-shortcut-status';

    function getPdfButton() {
        return document.querySelector('a[aria-label="Download PDF"]');
    }

    function getZipButton() {
        return document.querySelector('.custom-zip-download-btn');
    }

    function getStatusElement(anchor) {
        let status = document.getElementById(STATUS_ID);
        if (!status) {
            status = document.createElement('span');
            status.id = STATUS_ID;
            status.style.cssText = 'margin-left:8px;font:600 12px/1 system-ui,sans-serif;color:#57606a;white-space:nowrap;';
        }

        if (anchor?.parentElement && status.parentElement !== anchor.parentElement) {
            anchor.parentElement.appendChild(status);
        }

        return status;
    }

    function setStatus(anchor, message, isError = false) {
        const status = getStatusElement(anchor);
        status.textContent = message;
        status.style.color = isError ? '#cf222e' : '#57606a';
    }

    function isVisible(element) {
        return Boolean(element && element.isConnected && element.getClientRects().length > 0);
    }

    function normalizeText(text) {
        return String(text || '').replace(/\s+/g, ' ').trim().toLowerCase();
    }

    function getTargetScore(element) {
        const text = normalizeText([
            element.textContent,
            element.getAttribute('aria-label'),
            element.getAttribute('title'),
            element.getAttribute('data-testid'),
            element.getAttribute('href'),
        ].filter(Boolean).join(' '));

        if (!text.includes('github')) return -1;

        let score = 0;
        if (element.matches('a[href]')) score += 4;
        if (text.includes('sync')) score += 4;
        if (text.includes('integration')) score += 3;
        if (text.includes('link')) score += 2;
        if (text.includes('settings')) score += 1;
        if (isVisible(element)) score += 2;
        if (element.closest('[role="menu"], [role="dialog"], [data-testid*="menu"]')) score += 2;
        if (element.classList.contains(BUTTON_CLASS)) score = -1;
        return score;
    }

    function findGitHubTarget() {
        const candidates = [...document.querySelectorAll('a, button, [role="menuitem"], [data-testid], [aria-label], [title]')];
        let best = null;
        let bestScore = -1;

        for (const element of candidates) {
            const score = getTargetScore(element);
            if (score > bestScore) {
                best = element;
                bestScore = score;
            }
        }

        return bestScore >= 0 ? best : null;
    }

    function getMenuTriggerScore(element) {
        const text = normalizeText([
            element.textContent,
            element.getAttribute('aria-label'),
            element.getAttribute('title'),
            element.getAttribute('data-testid'),
        ].filter(Boolean).join(' '));

        if (!element.matches('button, [role="button"]')) return -1;
        if (!isVisible(element)) return -1;

        let score = 0;
        if (text.includes('menu')) score += 4;
        if (text.includes('project')) score += 2;
        if (text.includes('settings')) score += 2;
        if (text.includes('source')) score += 1;
        if (element.getAttribute('aria-haspopup') === 'menu') score += 2;
        if (element.closest('header')) score += 2;
        return score;
    }

    function findMenuTrigger() {
        const candidates = [...document.querySelectorAll('button, [role="button"]')];
        let best = null;
        let bestScore = -1;

        for (const element of candidates) {
            const score = getMenuTriggerScore(element);
            if (score > bestScore) {
                best = element;
                bestScore = score;
            }
        }

        return bestScore > 0 ? best : null;
    }

    function wait(ms) {
        return new Promise(resolve => window.setTimeout(resolve, ms));
    }

    function activateTarget(target) {
        const href = target.getAttribute('href');
        if (href && href !== '#') {
            const destination = new URL(href, window.location.origin).toString();
            window.open(destination, '_blank', 'noopener');
            return true;
        }

        target.dispatchEvent(new MouseEvent('click', { bubbles: true, cancelable: true, view: window }));
        return true;
    }

    async function openGitHubIntegration(shortcutButton) {
        setStatus(shortcutButton, 'Opening GitHub…');

        let target = findGitHubTarget();
        if (target) {
            activateTarget(target);
            setStatus(shortcutButton, 'Opened GitHub integration');
            return;
        }

        const menuTrigger = findMenuTrigger();
        if (menuTrigger) {
            menuTrigger.dispatchEvent(new MouseEvent('click', { bubbles: true, cancelable: true, view: window }));
            await wait(250);
            target = findGitHubTarget();
        }

        if (target) {
            activateTarget(target);
            setStatus(shortcutButton, 'Opened GitHub integration');
            return;
        }

        setStatus(shortcutButton, 'GitHub integration button not visible. Try opening the project menu first.', true);
    }

    function createShortcutButton(referenceButton) {
        let button = document.querySelector(`.${BUTTON_CLASS}`);
        if (button) return button;

        button = referenceButton.cloneNode(true);
        button.classList.add(BUTTON_CLASS);
        button.setAttribute('aria-label', 'Open GitHub integration');
        button.removeAttribute('href');
        button.href = '#';
        button.title = 'Open GitHub integration';
        button.innerHTML = '<span class="button-content" aria-hidden="false"><span aria-hidden="true">GitHub</span></span>';
        button.addEventListener('click', event => {
            event.preventDefault();
            event.stopPropagation();
            openGitHubIntegration(button);
        });
        return button;
    }

    function addShortcutButton() {
        const pdfButton = getPdfButton();
        if (!pdfButton?.parentElement) return;

        const referenceButton = getZipButton() || pdfButton;
        const shortcutButton = createShortcutButton(referenceButton);

        if (shortcutButton.parentElement !== pdfButton.parentElement) {
            pdfButton.parentElement.insertBefore(shortcutButton, referenceButton.nextSibling);
        }

        getStatusElement(shortcutButton);
    }

    const observer = new MutationObserver(() => addShortcutButton());

    function init() {
        observer.observe(document.body, { childList: true, subtree: true });
        addShortcutButton();
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init, { once: true });
    } else {
        init();
    }
})();
