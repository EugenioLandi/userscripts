// ==UserScript==
// @name         Overleaf GitHub Shortcut
// @namespace    http://tampermonkey.net/
// @version      1.3
// @description  Add a GitHub integration shortcut next to the PDF/ZIP controls in Overleaf
// @author       You
// @match        https://*.overleaf.com/*
// @updateURL    https://raw.githubusercontent.com/EugenioLandi/userscripts/main/Overleaf%20GitHub%20Shortcut
// @downloadURL  https://raw.githubusercontent.com/EugenioLandi/userscripts/main/Overleaf%20GitHub%20Shortcut
// @grant        none
// @run-at       document-idle
// ==/UserScript==

(function () {
    'use strict';

    if (window.__overleafGitHubShortcutInitialized) return;
    window.__overleafGitHubShortcutInitialized = true;

    const BUTTON_CLASS = 'custom-github-shortcut-btn';
    const STATUS_ID = 'custom-github-shortcut-status';

    function getGitHubIconMarkup() {
        return [
            '<span class="button-content" aria-hidden="true" style="display:inline-flex;align-items:center;justify-content:center;width:18px;height:18px;">',
            '<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.85" stroke-linecap="round" stroke-linejoin="round" focusable="false" aria-hidden="true">',
            '<circle cx="7" cy="6" r="2.25"/>',
            '<circle cx="17" cy="6" r="2.25"/>',
            '<circle cx="17" cy="18" r="2.25"/>',
            '<path d="M9.25 6h4a2.5 2.5 0 0 1 2.5 2.5v5.25"/>',
            '<path d="M7 8.25v8.5a2.25 2.25 0 0 0 2.25 2.25h5.5"/>',
            '</svg>',
            '</span>',
        ].join('');
    }

    function getPdfButton() {
        return document.querySelector('a[aria-label="Download PDF"]');
    }

    function getZipButton() {
        return document.querySelector('.custom-zip-download-btn');
    }

    function getProjectId() {
        const match = window.location.pathname.match(/\/project\/([^/]+)/);
        return match ? match[1] : null;
    }

    function getClickableText(element) {
        return normalizeText([
            element.textContent,
            element.getAttribute('aria-label'),
            element.getAttribute('title'),
            element.getAttribute('data-testid'),
            element.getAttribute('href'),
        ].filter(Boolean).join(' '));
    }

    function getStatusElement(anchor) {
        let status = document.getElementById(STATUS_ID);
        if (!status) {
            status = document.createElement('span');
            status.id = STATUS_ID;
            status.style.cssText = 'margin-left:8px;font:600 12px/1 system-ui,sans-serif;color:#57606a;white-space:nowrap;';
        }

        if (anchor?.parentElement && status.parentElement !== anchor.parentElement) {
            anchor.parentElement.appendChild(status);
        }

        return status;
    }

    function setStatus(anchor, message, isError = false) {
        const status = getStatusElement(anchor);
        status.textContent = message;
        status.style.color = isError ? '#cf222e' : '#57606a';
    }

    function isVisible(element) {
        return Boolean(element && element.isConnected && element.getClientRects().length > 0);
    }

    function normalizeText(text) {
        return String(text || '').replace(/\s+/g, ' ').trim().toLowerCase();
    }

    function getTargetScore(element) {
        const text = getClickableText(element);

        if (!text.includes('github')) return -1;

        let score = 0;
        if (element.matches('a[href]')) score += 4;
        if (text.includes('/github')) score += 5;
        if (text.includes('github sync')) score += 5;
        if (text === 'github') score += 4;
        if (text.includes('sync')) score += 4;
        if (text.includes('integration')) score += 3;
        if (text.includes('git')) score += 2;
        if (text.includes('link')) score += 2;
        if (text.includes('settings')) score += 1;
        if (isVisible(element)) score += 2;
        if (element.closest('[role="menu"], [role="dialog"], [data-testid*="menu"]')) score += 2;
        if (element.classList.contains(BUTTON_CLASS)) score = -1;
        return score;
    }

    function rankCandidates(selector, scoreFn) {
        return [...document.querySelectorAll(selector)]
            .map(element => ({ element, score: scoreFn(element) }))
            .filter(candidate => candidate.score >= 0)
            .sort((left, right) => right.score - left.score);
    }

    function findGitHubTarget() {
        return rankCandidates('a, button, [role="menuitem"], [data-testid], [aria-label], [title]', getTargetScore)[0]?.element || null;
    }

    function getMenuTriggerScore(element) {
        const text = getClickableText(element);

        if (!element.matches('button, [role="button"]')) return -1;
        if (!isVisible(element)) return -1;

        let score = 0;
        if (text.includes('menu')) score += 4;
        if (text.includes('project')) score += 2;
        if (text.includes('settings')) score += 2;
        if (text.includes('source')) score += 1;
        if (text.includes('github')) score += 6;
        if (element.getAttribute('aria-haspopup') === 'menu') score += 2;
        if (element.closest('header')) score += 2;
        return score;
    }

    function findMenuTrigger() {
        return rankCandidates('button, [role="button"]', getMenuTriggerScore)
            .filter(candidate => candidate.score > 0)
            .map(candidate => candidate.element)
            .filter(Boolean);
    }

    function wait(ms) {
        return new Promise(resolve => window.setTimeout(resolve, ms));
    }

    function triggerClick(element) {
        if (!element) return false;
        element.focus?.({ preventScroll: true });
        if (typeof element.click === 'function') {
            element.click();
            return true;
        }
        element.dispatchEvent(new MouseEvent('click', { bubbles: true, cancelable: true, view: window }));
        return true;
    }

    function activateTarget(target) {
        const href = target.getAttribute('href');
        if (href && href !== '#') {
            const destination = new URL(href, window.location.origin).toString();
            window.open(destination, '_blank', 'noopener,noreferrer');
            return true;
        }

        return triggerClick(target);
    }

    function openProjectSettings(shortcutButton) {
        const projectId = getProjectId();
        if (!projectId) return false;
        window.open(new URL(`/project/${encodeURIComponent(projectId)}/settings`, window.location.origin).toString(), '_blank', 'noopener,noreferrer');
        setStatus(shortcutButton, 'Opened project settings');
        return true;
    }

    async function openGitHubIntegration(shortcutButton) {
        setStatus(shortcutButton, 'Opening GitHub…');

        let target = findGitHubTarget();
        if (target) {
            activateTarget(target);
            setStatus(shortcutButton, 'Opened GitHub integration');
            return;
        }

        for (const menuTrigger of findMenuTrigger().slice(0, 5)) {
            triggerClick(menuTrigger);
            await wait(250);
            target = findGitHubTarget();
            if (target) {
                activateTarget(target);
                setStatus(shortcutButton, 'Opened GitHub integration');
                return;
            }
        }

        if (openProjectSettings(shortcutButton)) return;

        setStatus(shortcutButton, 'GitHub integration button not visible.', true);
    }

    function makeCompactToolbarButton(button, label, iconMarkup, title) {
        button.draggable = false;
        button.removeAttribute('disabled');
        button.removeAttribute('aria-disabled');
        button.removeAttribute('data-ol-loading');
        button.setAttribute('role', 'button');
        button.setAttribute('aria-label', label);
        button.title = title;
        button.style.pointerEvents = 'auto';
        button.style.cursor = 'pointer';
        button.style.minWidth = '32px';
        button.style.width = '32px';
        button.style.height = '32px';
        button.style.padding = '0';
        button.style.display = 'inline-flex';
        button.style.alignItems = 'center';
        button.style.justifyContent = 'center';
        button.innerHTML = iconMarkup;
        return button;
    }

    function createShortcutButton(referenceButton) {
        let button = document.querySelector(`.${BUTTON_CLASS}`);
        if (button) return button;

        button = referenceButton.cloneNode(true);
        button.classList.add(BUTTON_CLASS);
        button.removeAttribute('href');
        button.href = '#';
        makeCompactToolbarButton(button, 'Open GitHub integration', getGitHubIconMarkup(), 'Open GitHub integration');
        button.addEventListener('click', event => {
            event.preventDefault();
            event.stopPropagation();
            openGitHubIntegration(button);
        });
        return button;
    }

    function addShortcutButton() {
        const pdfButton = getPdfButton();
        if (!pdfButton?.parentElement) return;

        const referenceButton = getZipButton() || pdfButton;
        const shortcutButton = createShortcutButton(referenceButton);

        if (shortcutButton.parentElement !== pdfButton.parentElement) {
            pdfButton.parentElement.insertBefore(shortcutButton, referenceButton.nextSibling);
        }

        getStatusElement(shortcutButton);
    }

    const observer = new MutationObserver(() => addShortcutButton());

    function init() {
        observer.observe(document.body, { childList: true, subtree: true });
        addShortcutButton();
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init, { once: true });
    } else {
        init();
    }
})();
