// ==UserScript==
// @name         Overleaf ZIP Download with Date
// @namespace    http://tampermonkey.net/
// @version      0.2
// @description  Add ZIP download button next to PDF download in Overleaf
// @author       You
// @match        https://*.overleaf.com/*
// @grant        none
// ==/UserScript==

(function() {
    'use strict';

    // Funzione per ottenere il timestamp nel formato yyyy-mm-dd
    function getTimestamp() {
        const now = new Date();
        const year = now.getFullYear();
        const month = String(now.getMonth() + 1).padStart(2, '0');
        const day = String(now.getDate()).padStart(2, '0');
        return `${year}-${month}-${day}`;
    }

    // Funzione per estrarre il nome del progetto dall'URL o dalla pagina
    function getProjectName() {
        const titleElement = document.querySelector('.ide-redesign-toolbar-project-name');
        if (titleElement) {
            return titleElement.textContent.trim();
        }
        const pageTitle = document.title;
        if (pageTitle && !pageTitle.includes('Overleaf')) {
            return pageTitle.split('-')[0].trim();
        }
        return 'document';
    }

    // Funzione per pulire il nome del file (rimuove caratteri non validi)
    function sanitizeFilename(name) {
        return name.replace(/[^a-zA-Z0-9_\-]/g, ' ');
    }

    // Funzione per estrarre il project ID dall'URL
    function getProjectId() {
        const match = window.location.pathname.match(/\/project\/([a-f0-9]+)/);
        return match ? match[1] : null;
    }

    // Funzione per scaricare ZIP con nome personalizzato
    function downloadZipWithCustomName(url) {
        const projectName = sanitizeFilename(getProjectName());
        const timestamp = getTimestamp();
        const customFilename = `${projectName}- ${timestamp}.zip`;

        fetch(url)
            .then(response => response.blob())
            .then(blob => {
                const link = document.createElement('a');
                link.href = URL.createObjectURL(blob);
                link.download = customFilename;
                document.body.appendChild(link);
                link.click();
                document.body.removeChild(link);
                URL.revokeObjectURL(link.href);
            })
            .catch(error => {
                console.error('ZIP Download failed:', error);
                window.open(url, '_blank');
            });
    }

    // Funzione per creare e inserire il pulsante ZIP
    function addZipDownloadButton() {
        const pdfButton = document.querySelector('a[aria-label="Download PDF"]');
        if (!pdfButton) return;

        // Verifica se il pulsante ZIP esiste già
        if (document.querySelector('.custom-zip-download-btn')) return;

        const projectId = getProjectId();
        if (!projectId) return;

        // Crea il pulsante ZIP
        const zipButton = document.createElement('a');
        zipButton.href = '#';
        zipButton.draggable = false;
        zipButton.setAttribute('aria-label', 'Download ZIP');
        zipButton.setAttribute('data-ol-loading', 'false');
        zipButton.className = 'd-inline-grid pdf-toolbar-btn btn btn-link custom-zip-download-btn';
        zipButton.style.cssText = 'pointer-events: auto;';
        zipButton.tabIndex = 0;

        zipButton.innerHTML = `
            <span class="button-content" aria-hidden="false">
                <span class="material-symbols" aria-hidden="true" translate="no">folder_zip</span>
            </span>
        `;

        // Aggiungi l'event listener per il click
        zipButton.addEventListener('click', function(e) {
            e.preventDefault();
            e.stopPropagation();
            const zipUrl = `/project/${projectId}/download/zip`;
            downloadZipWithCustomName(zipUrl);
        });

        // Inserisci il pulsante accanto al pulsante PDF
        pdfButton.parentNode.insertBefore(zipButton, pdfButton.nextSibling);
    }

    // Funzione per scaricare con nome personalizzato
    function downloadWithCustomName(url) {
        const projectName = sanitizeFilename(getProjectName());
        const timestamp = getTimestamp();
        const customFilename = `${projectName}- ${timestamp}.pdf`;

        fetch(url)
            .then(response => response.blob())
            .then(blob => {
                const link = document.createElement('a');
                link.href = URL.createObjectURL(blob);
                link.download = customFilename;
                document.body.appendChild(link);
                link.click();
                document.body.removeChild(link);
                URL.revokeObjectURL(link.href);
            })
            .catch(error => {
                console.error('Download failed:', error);
                // Fallback al download originale
                window.open(url, '_blank');
            });
    }

    // Intercetta i click sui pulsanti di download
    document.addEventListener('click', function(e) {
        const target = e.target.closest('a[aria-label="Download PDF"]');
        if (target && target.href && target.href.includes('/download/project/')) {
            e.preventDefault();
            e.stopPropagation();
            downloadWithCustomName(target.href);
        }
    }, true);

    // Osserva i cambiamenti nel DOM per aggiungere il pulsante ZIP quando necessario
    const observer = new MutationObserver(function(mutations) {
        addZipDownloadButton();
    });

    // Inizia a osservare
    observer.observe(document.body, {
        childList: true,
        subtree: true
    });

    // Aggiungi il pulsante inizialmente
    setTimeout(addZipDownloadButton, 2000);

})();
