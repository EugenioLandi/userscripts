// ==UserScript==
// @name         Claude Usage Monitor
// @namespace    http://tampermonkey.net/
// @version      2.1
// @description  Floating widget showing 5h and 7d Claude usage in real time
// @author       You
// @match        https://claude.ai/*
// @run-at       document-idle
// @grant        none
// ==/UserScript==

(function () {
    'use strict';

    const BASE     = 'https://claude.ai';
    const REFRESH_MS = 10_000;
    const POS_KEY    = 'claude_usage_monitor_pos';
    const OPEN_KEY   = 'claude_usage_monitor_open';

    // ── API ────────────────────────────────────────────────────────────────────

    async function getOrgId() {
        const r = await fetch(`${BASE}/api/organizations`, { credentials: 'include' });
        if (r.ok) {
            const arr = await r.json();
            const id = arr?.[0]?.uuid ?? null;
            if (id) return id;
        }
        // Fallback: scrape UUID from inline page scripts
        for (const s of document.querySelectorAll('script')) {
            const m = s.textContent.match(/"uuid"\s*:\s*"([0-9a-f-]{36})"/);
            if (m) return m[1];
        }
        return null;
    }

    const USAGE_PATHS = [
        id => `${BASE}/api/organizations/${id}/usage`,
        id => `${BASE}/api/organizations/${id}/limits`,
        id => `${BASE}/api/organizations/${id}/rate_limits`,
        id => `${BASE}/api/organizations/${id}/usage_limits`,
    ];

    async function getUsage(orgId) {
        let lastErr = null;
        for (const fn of USAGE_PATHS) {
            try {
                const r = await fetch(fn(orgId), { credentials: 'include' });
                if (!r.ok) { lastErr = `${fn(orgId)} → ${r.status}`; continue; }
                const json = await r.json();
                console.debug('[Claude Usage Monitor] endpoint:', fn(orgId), json);
                return json;
            } catch (e) {
                lastErr = e.message;
            }
        }
        throw new Error(`All endpoints failed. Last: ${lastErr}`);
    }

    // ── Normalise response → { five_hour, seven_day } ─────────────────────────

    function normalise(raw) {
        if (!raw || typeof raw !== 'object') return {};
        if (raw.five_hour !== undefined || raw.seven_day !== undefined) return raw;
        if (raw.fiveHour  !== undefined || raw.sevenDay  !== undefined)
            return { five_hour: raw.fiveHour, seven_day: raw.sevenDay };
        if (Array.isArray(raw)) {
            const out = {};
            for (const e of raw) {
                const wt = (e.window_type || e.windowType || '').toLowerCase();
                if (wt.includes('five') || wt.includes('5h')) out.five_hour = e;
                if (wt.includes('seven') || wt.includes('7d')) out.seven_day = e;
            }
            return out;
        }
        if (raw.usage)  return normalise(raw.usage);
        if (Array.isArray(raw.limits)) return normalise(raw.limits);
        console.warn('[Claude Usage Monitor] unknown shape:', raw);
        return {};
    }

    // ── Formatting ─────────────────────────────────────────────────────────────

    function fmtCountdown(iso) {
        if (!iso) return '–';
        const ms = new Date(iso) - Date.now();
        if (ms <= 0) return 'resetting…';
        const h = Math.floor(ms / 3_600_000);
        const m = Math.floor((ms % 3_600_000) / 60_000);
        return h > 0 ? `${h}h ${m}m` : `${m}m`;
    }

    function usageColor(pct) {
        if (pct < 50) return '#4ade80';
        if (pct < 75) return '#facc15';
        if (pct < 90) return '#fb923c';
        return '#f87171';
    }

    // ── Widget DOM ─────────────────────────────────────────────────────────────

    let widget, headerText, btnToggle, detailPanel;
    let bar5h, lbl5h, bar7d, lbl7d;
    let expanded = false;
    let orgId    = null;

    function makeBar(label, panel) {
        const wrap = document.createElement('div');
        wrap.style.cssText = 'margin-top:6px';
        const top = document.createElement('div');
        top.style.cssText = 'display:flex;justify-content:space-between;margin-bottom:3px;color:#aaa;font-size:11px';
        const name = document.createElement('span'); name.textContent = label;
        const time = document.createElement('span'); time.textContent = '–';
        top.append(name, time);
        const track = document.createElement('div');
        track.style.cssText = 'background:#333;border-radius:4px;height:6px;overflow:hidden';
        const fill = document.createElement('div');
        fill.style.cssText = 'height:100%;width:0%;border-radius:4px;background:#4ade80;transition:width .4s,background .4s';
        track.appendChild(fill);
        wrap.append(top, track);
        panel.appendChild(wrap);
        return { fill, time };
    }

    function buildWidget() {
        expanded = localStorage.getItem(OPEN_KEY) === '1';
        widget = document.createElement('div');
        widget.id = 'claude-usage-monitor';
        widget.style.cssText = [
            'position:fixed','bottom:20px','right:20px','z-index:99999',
            'background:#1e1e1e','border:1px solid #3a3a3a','border-radius:10px',
            'box-shadow:0 4px 16px rgba(0,0,0,.5)','font-family:system-ui,sans-serif',
            'font-size:13px','color:#d4d4d4','user-select:none','min-width:170px',
        ].join(';');

        const header = document.createElement('div');
        header.style.cssText = 'display:flex;align-items:center;justify-content:space-between;padding:7px 10px;cursor:move;gap:8px';

        headerText = document.createElement('span');
        headerText.style.fontWeight = '600';
        headerText.textContent = 'Usage –';

        btnToggle = document.createElement('button');
        btnToggle.textContent = expanded ? '−' : '+';
        btnToggle.style.cssText = 'background:none;border:1px solid #555;border-radius:4px;color:#aaa;cursor:pointer;font-size:14px;line-height:1;padding:1px 5px';
        btnToggle.addEventListener('click', e => {
            e.stopPropagation();
            expanded = !expanded;
            localStorage.setItem(OPEN_KEY, expanded ? '1' : '0');
            btnToggle.textContent     = expanded ? '−' : '+';
            detailPanel.style.display = expanded ? 'block' : 'none';
        });

        header.append(headerText, btnToggle);
        widget.appendChild(header);

        detailPanel = document.createElement('div');
        detailPanel.style.cssText = `display:${expanded ? 'block' : 'none'};padding:0 10px 10px`;

        ({ fill: bar5h, time: lbl5h } = makeBar('5h window', detailPanel));
        ({ fill: bar7d, time: lbl7d } = makeBar('7d window', detailPanel));

        widget.appendChild(detailPanel);
        document.body.appendChild(widget);
        makeDraggable(widget, header);
        restorePosition();
    }

    // ── Data → UI ──────────────────────────────────────────────────────────────

    function applyUsage(raw) {
        const data  = normalise(raw);
        const fh    = data?.five_hour;
        const sd    = data?.seven_day;
        const toPct = v => v == null ? null : (v <= 1 ? Math.round(v * 100) : Math.round(v));
        const pct5h = toPct(fh?.utilization);
        const pct7d = toPct(sd?.utilization);
        const worst = Math.max(pct5h ?? 0, pct7d ?? 0);

        headerText.textContent = `Usage ${worst}%`;
        headerText.style.color = usageColor(worst);

        if (pct5h !== null) {
            bar5h.style.width = `${Math.min(pct5h, 100)}%`;
            bar5h.style.background = usageColor(pct5h);
            lbl5h.textContent = `resets ${fmtCountdown(fh.resets_at)}`;
        } else {
            bar5h.style.width = '0%';
            lbl5h.textContent = 'no data';
        }

        const row7d = bar7d.closest('div[style*="margin-top"]');
        if (pct7d !== null) {
            if (row7d) row7d.style.display = 'block';
            bar7d.style.width = `${Math.min(pct7d, 100)}%`;
            bar7d.style.background = usageColor(pct7d);
            lbl7d.textContent = `resets ${fmtCountdown(sd.resets_at)}`;
        } else {
            if (row7d) row7d.style.display = 'none';
        }
    }

    async function refresh() {
        try {
            if (!orgId) orgId = await getOrgId();
            if (!orgId) { headerText.textContent = 'Usage (no org)'; return; }
            applyUsage(await getUsage(orgId));
        } catch (err) {
            console.warn('[Claude Usage Monitor]', err);
            headerText.textContent = 'Usage (error)';
            headerText.style.color = '#f87171';
            if (lbl5h) lbl5h.textContent = err.message.slice(0, 80);
        }
    }

    // ── Drag ───────────────────────────────────────────────────────────────────

    function makeDraggable(el, handle) {
        let ox, oy, sx, sy;
        handle.addEventListener('mousedown', e => {
            if (e.button !== 0) return;
            e.preventDefault();
            const r = el.getBoundingClientRect();
            ox = r.left; oy = r.top; sx = e.clientX; sy = e.clientY;
            const move = e => {
                el.style.left  = `${ox + e.clientX - sx}px`;
                el.style.top   = `${oy + e.clientY - sy}px`;
                el.style.right = el.style.bottom = 'auto';
            };
            const up = () => {
                document.removeEventListener('mousemove', move);
                document.removeEventListener('mouseup', up);
                const r = el.getBoundingClientRect();
                localStorage.setItem(POS_KEY, JSON.stringify({ x: r.left, y: r.top }));
            };
            document.addEventListener('mousemove', move);
            document.addEventListener('mouseup', up);
        });
    }

    function restorePosition() {
        try {
            const s = JSON.parse(localStorage.getItem(POS_KEY));
            if (s) {
                widget.style.left  = `${s.x}px`;
                widget.style.top   = `${s.y}px`;
                widget.style.right = widget.style.bottom = 'auto';
            }
        } catch { /* ignore */ }
    }

    // ── Boot ───────────────────────────────────────────────────────────────────

    buildWidget();
    refresh();
    setInterval(refresh, REFRESH_MS);
})();
