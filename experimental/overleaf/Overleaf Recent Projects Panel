// ==UserScript==
// @name         Overleaf Recent Projects Panel
// @namespace    http://tampermonkey.net/
// @version      0.1.0
// @description  Keep a local list of recently opened Overleaf projects for fast switching
// @match        https://*.overleaf.com/*
// @updateURL    https://raw.githubusercontent.com/EugenioLandi/userscripts/main/experimental/overleaf/Overleaf%20Recent%20Projects%20Panel
// @downloadURL  https://raw.githubusercontent.com/EugenioLandi/userscripts/main/experimental/overleaf/Overleaf%20Recent%20Projects%20Panel
// @grant        none
// @run-at       document-idle
// ==/UserScript==

(function () {
    'use strict';

    if (window.__overleafRecentProjectsPanelInitialized) return;
    window.__overleafRecentProjectsPanelInitialized = true;

    const ROOT_ID = 'overleaf-recent-projects-panel';
    const STORAGE_KEY = 'overleaf-recent-projects';
    const COLLAPSED_KEY = 'overleaf-recent-projects-collapsed';
    const LIMIT = 10;

    function getProjectId() {
        const match = window.location.pathname.match(/\/project\/([^/]+)/);
        return match ? match[1] : null;
    }

    function getProjectName() {
        const selectors = [
            '.ide-redesign-toolbar-project-name',
            '[data-testid="project-name"]',
            'input[aria-label="Project name"]',
            'input[name="projectName"]',
        ];

        for (const selector of selectors) {
            const element = document.querySelector(selector);
            const value = element?.value || element?.textContent;
            if (value && value.trim()) return value.trim();
        }

        return document.title.replace(/\s*-\s*Overleaf.*$/i, '').trim() || 'Untitled project';
    }

    function readProjects() {
        try {
            const parsed = JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]');
            return Array.isArray(parsed) ? parsed : [];
        } catch {
            return [];
        }
    }

    function writeProjects(projects) {
        localStorage.setItem(STORAGE_KEY, JSON.stringify(projects.slice(0, LIMIT)));
    }

    function rememberCurrentProject() {
        const projectId = getProjectId();
        if (!projectId) return;
        const entry = {
            id: projectId,
            name: getProjectName(),
            url: `${window.location.origin}/project/${encodeURIComponent(projectId)}`,
            updatedAt: Date.now(),
        };
        const remaining = readProjects().filter(project => project.id !== entry.id);
        writeProjects([entry, ...remaining].sort((left, right) => right.updatedAt - left.updatedAt));
    }

    function getCollapsed() {
        return localStorage.getItem(COLLAPSED_KEY) === '1';
    }

    function setCollapsed(collapsed) {
        localStorage.setItem(COLLAPSED_KEY, collapsed ? '1' : '0');
        const root = document.getElementById(ROOT_ID);
        if (!root) return;
        const body = root.querySelector('[data-role="body"]');
        const toggle = root.querySelector('[data-role="toggle"]');
        if (body) body.style.display = collapsed ? 'none' : 'block';
        if (toggle) toggle.textContent = collapsed ? 'Open' : 'Hide';
    }

    function formatTime(timestamp) {
        return new Date(timestamp).toLocaleString();
    }

    function ensurePanel() {
        let root = document.getElementById(ROOT_ID);
        if (!root) {
            root = document.createElement('section');
            root.id = ROOT_ID;
            root.style.cssText = 'position:fixed;top:16px;right:16px;z-index:2147483647;display:flex;flex-direction:column;gap:8px;max-width:min(90vw,320px);padding:10px 12px;background:rgba(255,255,255,0.97);border:1px solid #d0d7de;border-radius:14px;box-shadow:0 8px 24px rgba(31,35,40,0.12);backdrop-filter:blur(6px);';

            const header = document.createElement('div');
            header.style.cssText = 'display:flex;align-items:center;justify-content:space-between;gap:12px;';

            const title = document.createElement('strong');
            title.textContent = 'Recent projects';
            title.style.cssText = 'font:700 12px/1.2 system-ui,sans-serif;color:#24292f;';

            const controls = document.createElement('div');
            controls.style.cssText = 'display:flex;gap:6px;';

            const clear = document.createElement('button');
            clear.type = 'button';
            clear.textContent = 'Clear';
            clear.style.cssText = 'border:1px solid #d0d7de;border-radius:999px;background:#f6f8fa;padding:4px 8px;font:600 12px/1.2 system-ui,sans-serif;cursor:pointer;';
            clear.addEventListener('click', () => {
                writeProjects([]);
                ensurePanel();
            });

            const toggle = document.createElement('button');
            toggle.type = 'button';
            toggle.dataset.role = 'toggle';
            toggle.style.cssText = 'border:1px solid #d0d7de;border-radius:999px;background:#f6f8fa;padding:4px 8px;font:600 12px/1.2 system-ui,sans-serif;cursor:pointer;';
            toggle.addEventListener('click', () => setCollapsed(!getCollapsed()));

            controls.append(clear, toggle);
            header.append(title, controls);

            const body = document.createElement('div');
            body.dataset.role = 'body';
            body.style.cssText = 'display:block;';

            root.append(header, body);
            document.body.appendChild(root);
        }

        const body = root.querySelector('[data-role="body"]');
        body.textContent = '';
        const projects = readProjects();
        if (!projects.length) {
            const empty = document.createElement('p');
            empty.textContent = 'Open a project to start building this list.';
            empty.style.cssText = 'margin:0;font:500 12px/1.4 system-ui,sans-serif;color:#57606a;';
            body.appendChild(empty);
        } else {
            const list = document.createElement('ul');
            list.style.cssText = 'margin:0;padding:0;list-style:none;display:flex;flex-direction:column;gap:8px;';
            projects.forEach(project => {
                const item = document.createElement('li');
                const link = document.createElement('a');
                link.href = project.url;
                link.textContent = project.name || project.id;
                link.style.cssText = 'display:block;color:#0969da;text-decoration:none;font:600 12px/1.4 system-ui,sans-serif;';
                const meta = document.createElement('div');
                meta.textContent = `${project.id} · ${formatTime(project.updatedAt)}`;
                meta.style.cssText = 'font:500 11px/1.4 system-ui,sans-serif;color:#57606a;word-break:break-word;';
                item.append(link, meta);
                list.appendChild(item);
            });
            body.appendChild(list);
        }

        setCollapsed(getCollapsed());
    }

    function init() {
        rememberCurrentProject();
        ensurePanel();
        window.addEventListener('focus', () => {
            rememberCurrentProject();
            ensurePanel();
        });
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init, { once: true });
    } else {
        init();
    }
})();
