// ==UserScript==
// @name         Overleaf Dark PDF Preview Toggle
// @namespace    http://tampermonkey.net/
// @version      0.1.0
// @description  Add a toggle that darkens the Overleaf PDF preview for low-light reading
// @match        https://*.overleaf.com/project/*
// @updateURL    https://raw.githubusercontent.com/EugenioLandi/userscripts/main/experimental/overleaf/Overleaf%20Dark%20PDF%20Preview%20Toggle
// @downloadURL  https://raw.githubusercontent.com/EugenioLandi/userscripts/main/experimental/overleaf/Overleaf%20Dark%20PDF%20Preview%20Toggle
// @grant        none
// @run-at       document-idle
// ==/UserScript==

(function () {
    'use strict';

    if (window.__overleafDarkPdfPreviewToggleInitialized) return;
    window.__overleafDarkPdfPreviewToggleInitialized = true;

    const STORAGE_KEY = 'overleaf-dark-pdf-preview-enabled';
    const BUTTON_ID = 'overleaf-dark-pdf-preview-toggle';
    const STYLE_ID = 'overleaf-dark-pdf-preview-style';

    function isTypingTarget(target) {
        return Boolean(target && (target.closest('input, textarea, select, [contenteditable="true"], [contenteditable=""]') || target.isContentEditable));
    }

    function ensureStyle() {
        if (document.getElementById(STYLE_ID)) return;
        const style = document.createElement('style');
        style.id = STYLE_ID;
        style.textContent = `
            html[data-overleaf-dark-preview='1'] [data-testid*='pdf' i],
            html[data-overleaf-dark-preview='1'] [aria-label*='pdf' i],
            html[data-overleaf-dark-preview='1'] .pdf-pane,
            html[data-overleaf-dark-preview='1'] .pdf-viewer,
            html[data-overleaf-dark-preview='1'] .pdf {
                background: #0d1117 !important;
                color: #c9d1d9 !important;
            }

            html[data-overleaf-dark-preview='1'] iframe[src*='/output/'],
            html[data-overleaf-dark-preview='1'] embed[type='application/pdf'],
            html[data-overleaf-dark-preview='1'] object[type='application/pdf'],
            html[data-overleaf-dark-preview='1'] canvas,
            html[data-overleaf-dark-preview='1'] img[alt*='page' i] {
                filter: invert(0.92) hue-rotate(180deg) contrast(0.95) brightness(0.98) !important;
            }

            #${BUTTON_ID} {
                position: fixed;
                right: 16px;
                bottom: 100px;
                z-index: 2147483647;
                border: 1px solid #d0d7de;
                border-radius: 999px;
                background: #ffffff;
                color: #24292f;
                padding: 8px 12px;
                font: 600 12px/1.2 system-ui, sans-serif;
                cursor: pointer;
                box-shadow: 0 4px 12px rgba(31, 35, 40, 0.15);
            }

            html[data-overleaf-dark-preview='1'] #${BUTTON_ID} {
                background: #21262d;
                border-color: #30363d;
                color: #f0f6fc;
            }
        `;
        document.head.appendChild(style);
    }

    function getEnabled() {
        return localStorage.getItem(STORAGE_KEY) === '1';
    }

    function setEnabled(enabled) {
        document.documentElement.dataset.overleafDarkPreview = enabled ? '1' : '0';
        localStorage.setItem(STORAGE_KEY, enabled ? '1' : '0');
        const button = document.getElementById(BUTTON_ID);
        if (button) {
            button.textContent = enabled ? 'Preview: dark' : 'Preview: light';
            button.title = 'Toggle dark PDF preview (Alt+Shift+D)';
        }
    }

    function toggle() {
        setEnabled(!getEnabled());
    }

    function ensureButton() {
        let button = document.getElementById(BUTTON_ID);
        if (button) return button;
        button = document.createElement('button');
        button.id = BUTTON_ID;
        button.type = 'button';
        button.addEventListener('click', toggle);
        document.body.appendChild(button);
        setEnabled(getEnabled());
        return button;
    }

    function handleKeydown(event) {
        if (event.defaultPrevented || isTypingTarget(event.target)) return;
        if (event.altKey && event.shiftKey && event.key.toLowerCase() === 'd') {
            event.preventDefault();
            toggle();
        }
    }

    function init() {
        ensureStyle();
        ensureButton();
        setEnabled(getEnabled());
        document.addEventListener('keydown', handleKeydown, true);
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init, { once: true });
    } else {
        init();
    }
})();
