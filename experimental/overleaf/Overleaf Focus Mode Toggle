// ==UserScript==
// @name         Overleaf Focus Mode Toggle
// @namespace    http://tampermonkey.net/
// @version      0.1.0
// @description  Add a persistent focus-mode toggle that hides review and sidebar chrome in Overleaf
// @match        https://*.overleaf.com/project/*
// @updateURL    https://raw.githubusercontent.com/EugenioLandi/userscripts/main/experimental/overleaf/Overleaf%20Focus%20Mode%20Toggle
// @downloadURL  https://raw.githubusercontent.com/EugenioLandi/userscripts/main/experimental/overleaf/Overleaf%20Focus%20Mode%20Toggle
// @grant        none
// @run-at       document-idle
// ==/UserScript==

(function () {
    'use strict';

    if (window.__overleafFocusModeToggleInitialized) return;
    window.__overleafFocusModeToggleInitialized = true;

    const STORAGE_KEY = 'overleaf-focus-mode-enabled';
    const BUTTON_ID = 'overleaf-focus-mode-toggle';
    const STYLE_ID = 'overleaf-focus-mode-style';

    function isTypingTarget(target) {
        return Boolean(target && (target.closest('input, textarea, select, [contenteditable="true"], [contenteditable=""]') || target.isContentEditable));
    }

    function ensureStyle() {
        if (document.getElementById(STYLE_ID)) return;
        const style = document.createElement('style');
        style.id = STYLE_ID;
        style.textContent = `
            html[data-overleaf-focus-mode='1'] aside,
            html[data-overleaf-focus-mode='1'] [data-testid*='review' i],
            html[data-overleaf-focus-mode='1'] [data-testid*='comment' i],
            html[data-overleaf-focus-mode='1'] [data-testid*='chat' i],
            html[data-overleaf-focus-mode='1'] [aria-label*='review' i],
            html[data-overleaf-focus-mode='1'] [aria-label*='comment' i],
            html[data-overleaf-focus-mode='1'] [aria-label*='chat' i],
            html[data-overleaf-focus-mode='1'] .review-panel,
            html[data-overleaf-focus-mode='1'] .comments-panel,
            html[data-overleaf-focus-mode='1'] .chat-panel,
            html[data-overleaf-focus-mode='1'] .file-tree,
            html[data-overleaf-focus-mode='1'] .left-menu,
            html[data-overleaf-focus-mode='1'] .left-panel {
                display: none !important;
            }

            html[data-overleaf-focus-mode='1'] main,
            html[data-overleaf-focus-mode='1'] [role='main'],
            html[data-overleaf-focus-mode='1'] .ide,
            html[data-overleaf-focus-mode='1'] .ide-body,
            html[data-overleaf-focus-mode='1'] .editor,
            html[data-overleaf-focus-mode='1'] .editor-pane,
            html[data-overleaf-focus-mode='1'] .pdf-viewer,
            html[data-overleaf-focus-mode='1'] .pdf-pane {
                width: 100% !important;
                max-width: none !important;
                flex: 1 1 auto !important;
            }

            #${BUTTON_ID} {
                position: fixed;
                right: 16px;
                bottom: 16px;
                z-index: 2147483647;
                border: 1px solid #d0d7de;
                border-radius: 999px;
                background: #ffffff;
                color: #24292f;
                padding: 8px 12px;
                font: 600 12px/1.2 system-ui, sans-serif;
                cursor: pointer;
                box-shadow: 0 4px 12px rgba(31, 35, 40, 0.15);
            }

            html[data-overleaf-focus-mode='1'] #${BUTTON_ID} {
                background: #1f6feb;
                border-color: #1f6feb;
                color: #ffffff;
            }
        `;
        document.head.appendChild(style);
    }

    function getEnabled() {
        return localStorage.getItem(STORAGE_KEY) === '1';
    }

    function setEnabled(enabled) {
        document.documentElement.dataset.overleafFocusMode = enabled ? '1' : '0';
        localStorage.setItem(STORAGE_KEY, enabled ? '1' : '0');
        const button = document.getElementById(BUTTON_ID);
        if (button) {
            button.textContent = enabled ? 'Focus: on' : 'Focus: off';
            button.title = 'Toggle focus mode (Alt+Shift+F)';
        }
    }

    function toggle() {
        setEnabled(!getEnabled());
    }

    function ensureButton() {
        let button = document.getElementById(BUTTON_ID);
        if (button) return button;
        button = document.createElement('button');
        button.id = BUTTON_ID;
        button.type = 'button';
        button.addEventListener('click', toggle);
        document.body.appendChild(button);
        setEnabled(getEnabled());
        return button;
    }

    function handleKeydown(event) {
        if (event.defaultPrevented || isTypingTarget(event.target)) return;
        if (event.altKey && event.shiftKey && event.key.toLowerCase() === 'f') {
            event.preventDefault();
            toggle();
        }
    }

    function init() {
        ensureStyle();
        ensureButton();
        setEnabled(getEnabled());
        document.addEventListener('keydown', handleKeydown, true);
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init, { once: true });
    } else {
        init();
    }
})();
