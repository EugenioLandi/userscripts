// ==UserScript==
// @name         Overleaf Copy Project Info
// @namespace    http://tampermonkey.net/
// @version      0.1.0
// @description  Add a quick button that copies project name, id, and useful Overleaf links
// @match        https://*.overleaf.com/project/*
// @updateURL    https://raw.githubusercontent.com/EugenioLandi/userscripts/main/experimental/overleaf/Overleaf%20Copy%20Project%20Info
// @downloadURL  https://raw.githubusercontent.com/EugenioLandi/userscripts/main/experimental/overleaf/Overleaf%20Copy%20Project%20Info
// @grant        none
// @run-at       document-idle
// ==/UserScript==

(function () {
    'use strict';

    if (window.__overleafCopyProjectInfoInitialized) return;
    window.__overleafCopyProjectInfoInitialized = true;

    const BUTTON_ID = 'overleaf-copy-project-info';

    function getProjectId() {
        const match = window.location.pathname.match(/\/project\/([^/]+)/);
        return match ? match[1] : null;
    }

    function getProjectName() {
        const selectors = [
            '.ide-redesign-toolbar-project-name',
            '[data-testid="project-name"]',
            'input[aria-label="Project name"]',
            'input[name="projectName"]',
        ];

        for (const selector of selectors) {
            const element = document.querySelector(selector);
            const value = element?.value || element?.textContent;
            if (value && value.trim()) return value.trim();
        }

        return document.title.replace(/\s*-\s*Overleaf.*$/i, '').trim() || 'Untitled project';
    }

    async function copyText(text) {
        if (navigator.clipboard?.writeText) {
            await navigator.clipboard.writeText(text);
            return;
        }

        const textarea = document.createElement('textarea');
        textarea.value = text;
        textarea.setAttribute('readonly', 'readonly');
        textarea.style.cssText = 'position:fixed;left:-9999px;top:-9999px;';
        document.body.appendChild(textarea);
        textarea.select();
        document.execCommand('copy');
        textarea.remove();
    }

    function buildPayload() {
        const projectId = getProjectId();
        const origin = window.location.origin;
        const name = getProjectName();
        const editorUrl = `${origin}/project/${encodeURIComponent(projectId)}`;
        const historyUrl = `${editorUrl}/history`;
        const settingsUrl = `${editorUrl}/settings`;

        return [
            `Project: ${name}`,
            `Project ID: ${projectId}`,
            `Editor: ${editorUrl}`,
            `History: ${historyUrl}`,
            `Settings: ${settingsUrl}`,
            '',
            `Markdown: [${name}](${editorUrl})`,
        ].join('\n');
    }

    function setLabel(message, isError = false) {
        const button = document.getElementById(BUTTON_ID);
        if (!button) return;
        button.textContent = message;
        button.style.background = isError ? '#cf222e' : '#ffffff';
        button.style.borderColor = isError ? '#cf222e' : '#d0d7de';
        button.style.color = isError ? '#ffffff' : '#24292f';
    }

    async function handleClick() {
        const projectId = getProjectId();
        if (!projectId) {
            setLabel('No project id', true);
            window.setTimeout(() => setLabel('Copy project info'), 1600);
            return;
        }

        try {
            await copyText(buildPayload());
            setLabel('Copied');
        } catch (error) {
            console.error('[Overleaf copy project info]', error);
            setLabel('Copy failed', true);
        }

        window.setTimeout(() => setLabel('Copy project info'), 1600);
    }

    function ensureButton() {
        let button = document.getElementById(BUTTON_ID);
        if (button) return button;
        button = document.createElement('button');
        button.id = BUTTON_ID;
        button.type = 'button';
        button.textContent = 'Copy project info';
        button.title = 'Copy project name, id, and key Overleaf links';
        button.style.cssText = 'position:fixed;right:16px;bottom:142px;z-index:2147483647;border:1px solid #d0d7de;border-radius:999px;background:#ffffff;color:#24292f;padding:8px 12px;font:600 12px/1.2 system-ui,sans-serif;cursor:pointer;box-shadow:0 4px 12px rgba(31,35,40,0.15);';
        button.addEventListener('click', handleClick);
        document.body.appendChild(button);
        return button;
    }

    function init() {
        ensureButton();
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init, { once: true });
    } else {
        init();
    }
})();
