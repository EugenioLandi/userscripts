// ==UserScript==
// @name         Overleaf Sidebar Compile Insights (Experimental)
// @namespace    http://tampermonkey.net/
// @version      0.2.0
// @description  Add native-sidebar compile timing history to Overleaf
// @match        https://*.overleaf.com/project/*
// @require      https://raw.githubusercontent.com/EugenioLandi/userscripts/main/experimental/overleaf/sidebar/_nativeSidebarHost.js
// @updateURL    https://raw.githubusercontent.com/EugenioLandi/userscripts/main/experimental/overleaf/sidebar/Overleaf%20Sidebar%20Compile%20Insights%20%28Experimental%29
// @downloadURL  https://raw.githubusercontent.com/EugenioLandi/userscripts/main/experimental/overleaf/sidebar/Overleaf%20Sidebar%20Compile%20Insights%20%28Experimental%29
// @grant        none
// @run-at       document-idle
// ==/UserScript==

(function () {
    'use strict';

    if (window.__experimentalOverleafSidebarCompileInsightsInitialized) return;
    window.__experimentalOverleafSidebarCompileInsightsInitialized = true;

    const host = window.__experimentalOverleafNativeSidebarHost;
    const PANEL_ID = 'experimental-overleaf-sidebar-compile-insights';
    const HISTORY_LIMIT = 15;

    function ensureTracker() {
        if (window.__experimentalOverleafSidebarCompileTracker) return window.__experimentalOverleafSidebarCompileTracker;

        const state = {
            activeProjectId: null,
            active: false,
            pendingRequests: 0,
            startTime: 0,
            listeners: new Set(),
        };

        function storageKey(projectId) {
            return `experimental-overleaf-sidebar-compile-history:${projectId}`;
        }

        function readHistory(projectId) {
            return projectId ? host.readJson(storageKey(projectId), []) : [];
        }

        function writeHistory(projectId, entries) {
            if (!projectId) return;
            host.writeJson(storageKey(projectId), entries.slice(0, HISTORY_LIMIT));
        }

        function trackRequest(url) {
            try {
                const absoluteUrl = new URL(String(url), window.location.origin);
                return /\/compile\b|\/clsi\b/i.test(absoluteUrl.pathname);
            } catch {
                return false;
            }
        }

        function notify() {
            state.listeners.forEach(listener => listener());
        }

        function begin(projectId) {
            if (!projectId) return;
            if (!state.active) {
                state.active = true;
                state.startTime = Date.now();
                state.activeProjectId = projectId;
            }
            state.pendingRequests += 1;
            notify();
        }

        function complete(projectId) {
            if (!projectId || !state.active) return;
            state.pendingRequests = Math.max(0, state.pendingRequests - 1);
            if (state.pendingRequests === 0) {
                const duration = Date.now() - state.startTime;
                const history = readHistory(state.activeProjectId || projectId);
                history.unshift({ duration, completedAt: Date.now() });
                writeHistory(state.activeProjectId || projectId, history);
                state.active = false;
                state.startTime = 0;
                state.activeProjectId = null;
            }
            notify();
        }

        const originalFetch = window.fetch;
        window.fetch = async function (...args) {
            const requestUrl = args[0] instanceof Request ? args[0].url : args[0];
            const tracked = trackRequest(requestUrl);
            const projectId = host.getProjectId();
            if (tracked) begin(projectId);
            try {
                return await originalFetch.apply(this, args);
            } finally {
                if (tracked) complete(projectId);
            }
        };

        const originalOpen = XMLHttpRequest.prototype.open;
        const originalSend = XMLHttpRequest.prototype.send;
        XMLHttpRequest.prototype.open = function (method, url, ...rest) {
            this.__experimentalOverleafTrackedCompile = trackRequest(url);
            this.__experimentalOverleafTrackedProjectId = host.getProjectId();
            return originalOpen.call(this, method, url, ...rest);
        };
        XMLHttpRequest.prototype.send = function (...args) {
            if (this.__experimentalOverleafTrackedCompile) {
                begin(this.__experimentalOverleafTrackedProjectId);
                const finalize = () => {
                    this.removeEventListener('loadend', finalize);
                    complete(this.__experimentalOverleafTrackedProjectId);
                };
                this.addEventListener('loadend', finalize, { once: true });
            }
            return originalSend.apply(this, args);
        };

        window.__experimentalOverleafSidebarCompileTracker = {
            subscribe(listener) {
                state.listeners.add(listener);
                return () => state.listeners.delete(listener);
            },
            getSnapshot(projectId) {
                return {
                    active: state.active && (!projectId || state.activeProjectId === projectId),
                    currentDuration: state.active ? Date.now() - state.startTime : null,
                    history: readHistory(projectId),
                };
            },
        };

        return window.__experimentalOverleafSidebarCompileTracker;
    }

    const tracker = ensureTracker();
    tracker.subscribe(() => host.rerenderPanel(PANEL_ID));
    window.setInterval(() => {
        if (host.isPanelActive(PANEL_ID)) host.rerenderPanel(PANEL_ID);
    }, 1000);

    function formatSeconds(duration) {
        return `${(duration / 1000).toFixed(2)}s`;
    }

    host.registerPanel({
        id: PANEL_ID,
        order: 50,
        title: 'Compile insights',
        subtitle: 'Current compile plus recent timings',
        icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="13" r="8"/><path d="M12 13V9"/><path d="M12 13l3 2"/><path d="M9 3h6"/></svg>',
        render(container, api) {
            const snapshot = tracker.getSnapshot(api.getProjectId());
            const history = snapshot.history;
            const average = history.length ? history.reduce((total, entry) => total + entry.duration, 0) / history.length : null;
            const slowest = history.length ? Math.max(...history.map(entry => entry.duration)) : null;
            const stats = document.createElement('div');
            stats.style.cssText = 'display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:10px;';

            [
                ['Current', snapshot.active ? formatSeconds(snapshot.currentDuration || 0) : 'Idle'],
                ['Average', average !== null ? formatSeconds(average) : '—'],
                ['Slowest', slowest !== null ? formatSeconds(slowest) : '—'],
            ].forEach(([label, value]) => {
                const card = document.createElement('div');
                card.className = 'ol-native-sidebar-card';
                const heading = document.createElement('strong');
                heading.style.cssText = 'display:block;font-size:0.6875rem;letter-spacing:0.04em;text-transform:uppercase;margin-bottom:6px;opacity:0.8;';
                heading.textContent = label;
                const detail = document.createElement('div');
                detail.style.cssText = 'font-size:0.9375rem;font-weight:700;line-height:1.3;';
                detail.textContent = value;
                card.append(heading, detail);
                stats.appendChild(card);
            });
            container.appendChild(stats);

            const intro = document.createElement('p');
            intro.className = 'ol-native-sidebar-muted';
            intro.textContent = 'Tracked locally from compile-related network requests for this project.';
            container.appendChild(intro);

            if (!history.length) {
                const empty = document.createElement('p');
                empty.className = 'ol-native-sidebar-muted';
                empty.textContent = 'No compile history yet for this project.';
                container.appendChild(empty);
                api.setFooterText(snapshot.active ? 'Compile in progress…' : 'Waiting for compile data');
                return;
            }

            const list = document.createElement('ul');
            list.className = 'ol-native-sidebar-list';
            history.forEach(entry => {
                const item = document.createElement('li');
                item.className = 'ol-native-sidebar-card';
                const duration = document.createElement('strong');
                duration.style.cssText = 'display:block;font-size:0.875rem;';
                duration.textContent = formatSeconds(entry.duration);
                const time = document.createElement('div');
                time.style.cssText = 'margin-top:4px;font-size:0.75rem;opacity:0.82;';
                time.textContent = api.formatDateTime(entry.completedAt);
                item.append(duration, time);
                list.appendChild(item);
            });
            container.appendChild(list);
            api.setFooterText(history[0] ? `Last compile: ${formatSeconds(history[0].duration)}` : 'Waiting for compile data');
        },
    });
})();
