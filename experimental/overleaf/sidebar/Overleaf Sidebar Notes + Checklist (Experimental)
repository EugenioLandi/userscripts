// ==UserScript==
// @name         Overleaf Sidebar Notes + Checklist (Experimental)
// @namespace    http://tampermonkey.net/
// @version      0.3.0
// @description  Add centered Overleaf sidebar buttons that open draggable local notes and checklist panels
// @match        https://*.overleaf.com/project/*
// @require      https://raw.githubusercontent.com/EugenioLandi/userscripts/main/experimental/overleaf/sidebar/_nativeSidebarHost.js
// @updateURL    https://raw.githubusercontent.com/EugenioLandi/userscripts/main/experimental/overleaf/sidebar/Overleaf%20Sidebar%20Notes%20%2B%20Checklist%20%28Experimental%29
// @downloadURL  https://raw.githubusercontent.com/EugenioLandi/userscripts/main/experimental/overleaf/sidebar/Overleaf%20Sidebar%20Notes%20%2B%20Checklist%20%28Experimental%29
// @grant        none
// @run-at       document-idle
// ==/UserScript==

(function () {
    'use strict';

    if (window.__experimentalOverleafSidebarNotesChecklistInitialized) return;
    window.__experimentalOverleafSidebarNotesChecklistInitialized = true;

    const host = window.__experimentalOverleafNativeSidebarHost;
    const NOTES_PANEL_ID = 'experimental-overleaf-sidebar-local-notepad';
    const CHECKLIST_PANEL_ID = 'experimental-overleaf-sidebar-checklist';

    function getNotesStorageKey(api) {
        return `experimental-overleaf-sidebar-local-notepad:${api.getProjectId() || 'unknown-project'}`;
    }

    function getChecklistStorageKey(api) {
        return `experimental-overleaf-sidebar-checklist:${api.getProjectId() || 'unknown-project'}`;
    }

    function readChecklistItems(api) {
        return api.readJson(getChecklistStorageKey(api), []);
    }

    function writeChecklistItems(api, items) {
        api.writeJson(getChecklistStorageKey(api), items);
    }

    function createChecklistId() {
        return `${Date.now().toString(36)}-${Math.random().toString(36).slice(2, 7)}`;
    }

    host.registerPanel({
        id: NOTES_PANEL_ID,
        order: 10,
        title: 'Local notes',
        subtitle: 'Project notes stored only in this browser',
        icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 3h8l4 4v14H7z"/><path d="M15 3v4h4"/><path d="M10 11h6"/><path d="M10 15h6"/><path d="M10 19h4"/></svg>',
        render(container, api) {
            const key = getNotesStorageKey(api);
            const intro = document.createElement('p');
            intro.className = 'ol-native-sidebar-muted';
            intro.textContent = 'Keep reviewer feedback, TODOs, or reminders without touching the manuscript.';

            const actions = document.createElement('div');
            actions.style.cssText = 'display:flex;flex-wrap:wrap;gap:8px;';

            const copyButton = document.createElement('button');
            copyButton.type = 'button';
            copyButton.className = 'ol-native-sidebar-button';
            copyButton.textContent = 'Copy';

            const clearButton = document.createElement('button');
            clearButton.type = 'button';
            clearButton.className = 'ol-native-sidebar-button';
            clearButton.textContent = 'Clear';

            actions.append(copyButton, clearButton);

            const textarea = document.createElement('textarea');
            textarea.className = 'ol-native-sidebar-textarea';
            textarea.placeholder = 'Write project-specific notes here…';
            textarea.value = localStorage.getItem(key) || '';

            let saveTimer = null;
            textarea.addEventListener('input', () => {
                clearTimeout(saveTimer);
                api.setFooterText('Saving locally…');
                saveTimer = window.setTimeout(() => {
                    localStorage.setItem(key, textarea.value);
                    api.setFooterText(`Saved for ${api.getProjectName()}`);
                }, 150);
            });

            copyButton.addEventListener('click', async () => {
                await api.copyText(textarea.value);
                api.setFooterText('Notes copied to clipboard');
            });

            clearButton.addEventListener('click', () => {
                textarea.value = '';
                localStorage.removeItem(key);
                api.setFooterText('Notes cleared');
            });

            container.append(intro, actions, textarea);
            api.setFooterText(`Autosaves locally for ${api.getProjectName()}`);
        },
    });

    host.registerPanel({
        id: CHECKLIST_PANEL_ID,
        order: 60,
        title: 'Checklist',
        subtitle: 'Local project tasks in a draggable floating box',
        icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 11l2 2 4-4"/><path d="M9 17l2 2 4-4"/><path d="M5 6h14"/></svg>',
        render(container, api) {
            const items = readChecklistItems(api);

            const form = document.createElement('form');
            form.style.cssText = 'display:flex;gap:8px;';
            const input = document.createElement('input');
            input.className = 'ol-native-sidebar-input';
            input.placeholder = 'Add a task…';
            const addButton = document.createElement('button');
            addButton.type = 'submit';
            addButton.className = 'ol-native-sidebar-button';
            addButton.textContent = 'Add';
            form.append(input, addButton);
            container.appendChild(form);

            const actions = document.createElement('div');
            actions.style.cssText = 'display:flex;justify-content:flex-end;';
            const clearDone = document.createElement('button');
            clearDone.type = 'button';
            clearDone.className = 'ol-native-sidebar-button';
            clearDone.textContent = 'Clear done';
            clearDone.addEventListener('click', () => {
                writeChecklistItems(api, items.filter(item => !item.done));
                api.rerender();
            });
            actions.appendChild(clearDone);
            container.appendChild(actions);

            form.addEventListener('submit', event => {
                event.preventDefault();
                const text = input.value.trim();
                if (!text) return;
                writeChecklistItems(api, [{ id: createChecklistId(), text, done: false }, ...items]);
                api.rerender();
            });

            if (!items.length) {
                const empty = document.createElement('p');
                empty.className = 'ol-native-sidebar-muted';
                empty.textContent = 'Track figures, references, experiments, or submission checks here.';
                container.appendChild(empty);
                api.setFooterText('0 tasks stored locally');
                return;
            }

            const list = document.createElement('ul');
            list.className = 'ol-native-sidebar-list';
            items.forEach(item => {
                const row = document.createElement('li');
                row.className = 'ol-native-sidebar-card';
                row.style.cssText = 'display:flex;align-items:flex-start;gap:10px;';

                const checkbox = document.createElement('input');
                checkbox.type = 'checkbox';
                checkbox.checked = Boolean(item.done);
                checkbox.addEventListener('change', () => {
                    writeChecklistItems(api, items.map(entry => entry.id === item.id ? { ...entry, done: checkbox.checked } : entry));
                    api.rerender();
                });

                const text = document.createElement('div');
                text.style.cssText = `flex:1 1 auto;font-size:0.8125rem;line-height:1.5;text-decoration:${item.done ? 'line-through' : 'none'};opacity:${item.done ? '0.72' : '1'};`;
                text.textContent = item.text;

                const remove = document.createElement('button');
                remove.type = 'button';
                remove.className = 'ol-native-sidebar-button';
                remove.textContent = 'Remove';
                remove.addEventListener('click', () => {
                    writeChecklistItems(api, items.filter(entry => entry.id !== item.id));
                    api.rerender();
                });

                row.append(checkbox, text, remove);
                list.appendChild(row);
            });
            container.appendChild(list);
            const doneCount = items.filter(item => item.done).length;
            api.setFooterText(`${doneCount}/${items.length} tasks completed`);
        },
    });
})();
