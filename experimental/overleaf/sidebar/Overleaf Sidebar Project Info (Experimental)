// ==UserScript==
// @name         Overleaf Sidebar Project Info (Experimental)
// @namespace    http://tampermonkey.net/
// @version      0.2.0
// @description  Add native-sidebar project metadata and copy helpers to Overleaf
// @match        https://*.overleaf.com/project/*
// @require      https://raw.githubusercontent.com/EugenioLandi/userscripts/main/experimental/overleaf/sidebar/_nativeSidebarHost.js
// @updateURL    https://raw.githubusercontent.com/EugenioLandi/userscripts/main/experimental/overleaf/sidebar/Overleaf%20Sidebar%20Project%20Info%20%28Experimental%29
// @downloadURL  https://raw.githubusercontent.com/EugenioLandi/userscripts/main/experimental/overleaf/sidebar/Overleaf%20Sidebar%20Project%20Info%20%28Experimental%29
// @grant        none
// @run-at       document-idle
// ==/UserScript==

(function () {
    'use strict';

    if (window.__experimentalOverleafSidebarProjectInfoInitialized) return;
    window.__experimentalOverleafSidebarProjectInfoInitialized = true;

    const host = window.__experimentalOverleafNativeSidebarHost;

    function buildPayload(api) {
        return [
            `Project: ${api.getProjectName()}`,
            `Project ID: ${api.getProjectId() || 'unknown'}`,
            `Editor: ${api.buildProjectUrl('')}`,
            `History: ${api.buildProjectUrl('/history')}`,
            `Settings: ${api.buildProjectUrl('/settings')}`,
            '',
            `Markdown: [${api.getProjectName()}](${api.buildProjectUrl('')})`,
        ].join('\n');
    }

    host.registerPanel({
        id: 'experimental-overleaf-sidebar-project-info',
        order: 30,
        title: 'Project info',
        subtitle: 'Copy IDs and links for tickets, chats, and notes',
        icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M12 8h.01"/><path d="M11 12h1v4h1"/></svg>',
        render(container, api) {
            const rows = [
                ['Project', api.getProjectName()],
                ['Project ID', api.getProjectId() || 'Not available'],
                ['Editor URL', api.buildProjectUrl('')],
                ['History URL', api.buildProjectUrl('/history')],
            ];

            rows.forEach(([label, value]) => {
                const card = document.createElement('div');
                card.className = 'ol-native-sidebar-card';
                const title = document.createElement('strong');
                title.style.cssText = 'display:block;font-size:0.75rem;margin-bottom:6px;';
                title.textContent = label;
                const content = document.createElement('div');
                content.style.cssText = 'font-size:0.8125rem;line-height:1.45;word-break:break-word;';
                content.textContent = value;
                card.append(title, content);
                container.appendChild(card);
            });

            const actions = document.createElement('div');
            actions.style.cssText = 'display:flex;flex-wrap:wrap;gap:8px;';
            [
                ['Copy all', () => buildPayload(api), 'Project details copied'],
                ['Copy ID', () => api.getProjectId() || '', 'Project ID copied'],
                ['Copy Markdown', () => `[${api.getProjectName()}](${api.buildProjectUrl('')})`, 'Markdown link copied'],
            ].forEach(([label, valueFactory, footerText]) => {
                const button = document.createElement('button');
                button.type = 'button';
                button.className = 'ol-native-sidebar-button';
                button.textContent = label;
                button.addEventListener('click', async () => {
                    await api.copyText(valueFactory());
                    api.setFooterText(footerText);
                });
                actions.appendChild(button);
            });
            container.appendChild(actions);
            api.setFooterText('Metadata stays one click away in the native sidebar');
        },
    });
})();
