        guidedCard.appendChild(guidedIntro);

        const guidedGrid = document.createElement('div');
        guidedGrid.className = 'oncb-grid';
        guidedCard.appendChild(guidedGrid);

        const actionField = createSelectField('What do you want to do?', []);
        const declarationPreviewField = createInputField('Builder will use');
        declarationPreviewField.input.readOnly = true;
        guidedGrid.append(actionField.field, declarationPreviewField.field);

        const actionHelp = document.createElement('p');
        actionHelp.className = 'oncb-help';
        guidedCard.appendChild(actionHelp);

        const guidedArgsCard = document.createElement('div');
        guidedArgsCard.className = 'oncb-card';
        const guidedArgsTitle = document.createElement('p');
        guidedArgsTitle.className = 'oncb-muted';
        guidedArgsTitle.textContent = 'Guided arguments';
        const guidedArgsList = document.createElement('div');
        guidedArgsList.className = 'oncb-arg-list';
        const guidedArgButtons = document.createElement('div');
        guidedArgButtons.className = 'oncb-actions';
        const guidedUseCases = document.createElement('p');
        guidedUseCases.className = 'oncb-help';
        guidedArgsCard.append(guidedArgsTitle, guidedArgsList, guidedArgButtons, guidedUseCases);
        guidedCard.appendChild(guidedArgsCard);

        const guidedExampleField = createTextareaField('Live example call');
        guidedExampleField.textarea.readOnly = true;
        guidedExampleField.textarea.style.minHeight = '90px';
        guidedCard.appendChild(guidedExampleField.field);

        const guidedCommandField = createTextareaField('What should the command do?');
        guidedCommandField.textarea.placeholder = 'Example: Make the text bold and prefix it with “Remark:”.';
        guidedCard.appendChild(guidedCommandField.field);

        const guidedBeginField = createTextareaField('What should happen when the environment starts?');
        guidedBeginField.textarea.placeholder = 'Example: Start a boxed block with a bold title.';
        guidedCard.appendChild(guidedBeginField.field);

        const guidedEndField = createTextareaField('What should happen when the environment ends?');
        guidedEndField.textarea.placeholder = 'Example: Close the box and add a little spacing.';
        guidedCard.appendChild(guidedEndField.field);

        const expertCard = document.createElement('div');
        expertCard.className = 'oncb-card';
        form.appendChild(expertCard);

        const expertIntro = document.createElement('p');
        expertIntro.className = 'oncb-help';
        expertIntro.textContent = 'Expert mode exposes raw declarations, argument specs, and body fields directly. The shortcuts below cover common xparse patterns, including booleans and delimited/defaulted forms.';
        expertCard.appendChild(expertIntro);

        const expertGrid = document.createElement('div');
        expertGrid.className = 'oncb-grid';
        expertCard.appendChild(expertGrid);

        const declarationField = createSelectField('Declaration', []);
        const specField = createInputField('Argument spec', 'm O{default} s');
        expertGrid.append(declarationField.field, specField.field);

        const tokenCard = document.createElement('div');
        tokenCard.className = 'oncb-card';
        const tokenTitle = document.createElement('p');
        tokenTitle.className = 'oncb-muted';
        tokenTitle.textContent = 'Argument-spec shortcuts';
        const tokenRow = document.createElement('div');
        tokenRow.className = 'oncb-token-row';
        tokenCard.append(tokenTitle, tokenRow);
        expertCard.appendChild(tokenCard);

        const bodyField = createTextareaField('Command body');
        expertCard.appendChild(bodyField.field);

        const afterField = createTextareaField('End code');
        expertCard.appendChild(afterField.field);

        const snippetCard = document.createElement('div');
        snippetCard.className = 'oncb-preview';
        const snippetTitle = document.createElement('p');
        snippetTitle.className = 'oncb-muted';
        snippetTitle.textContent = 'Generated declaration';
        const snippetOutput = document.createElement('textarea');
        snippetOutput.className = 'oncb-input oncb-output';
        snippetOutput.readOnly = true;
        snippetCard.append(snippetTitle, snippetOutput);
        body.appendChild(snippetCard);

        const notesCard = document.createElement('div');
        notesCard.className = 'oncb-preview';
        const notesTitle = document.createElement('p');
        notesTitle.className = 'oncb-muted';
        notesTitle.textContent = 'Usage notes';
        const notesOutput = document.createElement('textarea');
        notesOutput.className = 'oncb-input';
        notesOutput.style.minHeight = '180px';
        notesOutput.readOnly = true;
        notesCard.append(notesTitle, notesOutput);
        body.appendChild(notesCard);

        const actions = document.createElement('div');
        actions.className = 'oncb-actions';
        const copySnippetButton = createButton('Copy declaration');
        const copyNotesButton = createButton('Copy usage notes');
        const resetButton = createButton('Reset draft');
        actions.append(copySnippetButton, copyNotesButton, resetButton);
        body.appendChild(actions);

        function syncActionOptions() {
            const options = getActionOptions(formState.mode);
            const nextValue = normalizeAction(formState.mode, formState.action);
            formState.action = nextValue;
            actionField.select.textContent = '';
            options.forEach(optionData => {
                const option = document.createElement('option');
                option.value = optionData.value;
                option.textContent = optionData.label;
                option.selected = optionData.value === nextValue;
                actionField.select.appendChild(option);
            });
        }

        function syncDeclarationOptions() {
            const options = getDeclarationOptions(formState.mode);
            const nextValue = options.includes(formState.declaration) ? formState.declaration : options[0];
            formState.declaration = nextValue;
            declarationField.select.textContent = '';
            options.forEach(value => {
                const option = document.createElement('option');
                option.value = value;
                option.textContent = value;
                option.selected = value === nextValue;
                declarationField.select.appendChild(option);
            });
        }

        function applyPreset(preset) {
            Object.assign(formState, normalizeFormState({
                ...cloneDefaultData(),
                ...JSON.parse(JSON.stringify(preset.data)),
            }));
            refreshOutputs({ rerenderArguments: true });
        }

        function moveGuidedArgument(index, direction) {
            const nextIndex = index + direction;
            if (nextIndex < 0 || nextIndex >= formState.guidedArguments.length) return;
            const swapped = formState.guidedArguments[index];
            formState.guidedArguments[index] = formState.guidedArguments[nextIndex];
            formState.guidedArguments[nextIndex] = swapped;
            refreshOutputs({ rerenderArguments: true });
        }

        function renderGuidedArguments() {
            guidedArgsList.textContent = '';
            guidedArgButtons.textContent = '';
            const options = getGuidedArgumentOptions(formState.mode);
            const optionPairs = options.map(option => [option.value, option.label]);
            const canAddMore = formState.guidedArguments.length < GUIDED_ARGUMENT_LIMIT;

            if (!formState.guidedArguments.length) {
                const empty = document.createElement('p');
                empty.className = 'oncb-help';
                empty.textContent = 'No guided arguments yet. Add one below if you want inputs, switches, delimiters, or body capture.';
                guidedArgsList.appendChild(empty);
            }

            formState.guidedArguments.forEach((argument, index) => {
                const meta = getGuidedArgumentMeta(argument.kind, formState.mode);
                const row = document.createElement('div');
                row.className = 'oncb-card oncb-arg-row';

                const header = document.createElement('div');
                header.className = 'oncb-arg-row-header';
                const title = document.createElement('p');
                title.className = 'oncb-muted';
                title.textContent = `Argument ${index + 1}`;
                const controls = document.createElement('div');
                controls.className = 'oncb-actions';
                const moveUp = createButton('↑');
                const moveDown = createButton('↓');
                const remove = createButton('Remove');
                moveUp.disabled = index === 0;
                moveDown.disabled = index === formState.guidedArguments.length - 1;
                moveUp.addEventListener('click', () => moveGuidedArgument(index, -1));
                moveDown.addEventListener('click', () => moveGuidedArgument(index, 1));
                remove.addEventListener('click', () => {
                    formState.guidedArguments.splice(index, 1);
                    refreshOutputs({ rerenderArguments: true });
                });
                controls.append(moveUp, moveDown, remove);
                header.append(title, controls);
                row.appendChild(header);

                const fields = document.createElement('div');
                fields.className = 'oncb-grid';
                const typeField = createSelectField('Type', optionPairs);
                typeField.select.value = argument.kind;
                fields.appendChild(typeField.field);

                const labelField = createInputField('Label / example', meta.example || 'value');
                labelField.input.value = getGuidedArgumentLabel(argument, index, formState.mode);
                fields.appendChild(labelField.field);

                let tokenField = null;
                let defaultField = null;
                let openField = null;
                let closeField = null;

                if (meta.supportsToken) {
                    tokenField = createInputField('Trigger token', meta.defaultToken || '+');
                    tokenField.input.maxLength = 1;
                    tokenField.input.value = normalizeSingleCharacter(argument.token, meta.defaultToken || '+');
                    fields.appendChild(tokenField.field);
                }

                if (meta.supportsDefault) {
                    defaultField = createInputField('Default value', 'default');
                    defaultField.input.value = String(argument.defaultValue || '');
                    fields.appendChild(defaultField.field);
                }

                if (meta.supportsDelimiters) {
                    openField = createInputField('Open delimiter', meta.defaultOpen || '(');
                    closeField = createInputField('Close delimiter', meta.defaultClose || ')');
                    openField.input.maxLength = 1;
                    closeField.input.maxLength = 1;
                    openField.input.value = normalizeSingleCharacter(argument.open, meta.defaultOpen || '(');
                    closeField.input.value = normalizeSingleCharacter(argument.close, meta.defaultClose || ')');
                    fields.append(openField.field, closeField.field);
                }

                row.appendChild(fields);

                const help = document.createElement('p');
                help.className = 'oncb-help';
                help.textContent = `${meta.help} Example syntax: ${buildGuidedUsageSegment(argument, index, formState.mode) || meta.example}.`;
                row.appendChild(help);
                guidedArgsList.appendChild(row);

                typeField.select.addEventListener('change', () => {
                    formState.guidedArguments[index] = createGuidedArgument(typeField.select.value, {
                        id: argument.id,
                        label: labelField.input.value,
                        defaultValue: defaultField?.input.value,
                        token: tokenField?.input.value,
                        open: openField?.input.value,
                        close: closeField?.input.value,
                    }, formState.mode, index);
                    refreshOutputs({ rerenderArguments: true });
                });

                labelField.input.addEventListener('input', () => {
                    formState.guidedArguments[index].label = labelField.input.value;
                    refreshOutputs();
                });

                tokenField?.input.addEventListener('input', () => {
                    formState.guidedArguments[index].token = tokenField.input.value;
                    refreshOutputs();
                });

                defaultField?.input.addEventListener('input', () => {
                    formState.guidedArguments[index].defaultValue = defaultField.input.value;
                    refreshOutputs();
                });

                openField?.input.addEventListener('input', () => {
                    formState.guidedArguments[index].open = openField.input.value;
                    refreshOutputs();
                });

                closeField?.input.addEventListener('input', () => {
                    formState.guidedArguments[index].close = closeField.input.value;
                    refreshOutputs();
                });
            });

            options.forEach(option => {
                const button = createButton(`+ ${option.shortLabel}`, 'oncb-chip');
                button.disabled = !canAddMore;
                button.title = canAddMore
                    ? option.help
                    : `Limit reached (${GUIDED_ARGUMENT_LIMIT}). Remove an argument before adding another.`;
                button.addEventListener('click', () => {
                    if (!canAddMore) return;
                    formState.guidedArguments.push(createGuidedArgument(option.value, {}, formState.mode, formState.guidedArguments.length));
                    refreshOutputs({ rerenderArguments: true });
                });
                guidedArgButtons.appendChild(button);
            });
        }

        function refreshOutputs(options = {}) {
            const { rerenderArguments = false } = options;
            formState.uiMode = normalizeUiMode(formState.uiMode);
            formState.mode = formState.mode === 'environment' ? 'environment' : 'command';
            formState.action = normalizeAction(formState.mode, formState.action);
            formState.guidedArguments = normalizeGuidedArguments(formState.guidedArguments, formState.mode, formState);
            if (formState.uiMode === 'guided') {
                syncGuidedFields(formState);
            }

            syncActionOptions();
            syncDeclarationOptions();
            if (rerenderArguments) renderGuidedArguments();

            const isEnvironment = formState.mode === 'environment';
            const actionDetails = getActionDetails(formState.mode, formState.action);

            editorModeField.select.value = formState.uiMode;
            modeField.select.value = formState.mode;
            nameField.input.placeholder = isEnvironment ? 'myenvironment' : '\\mycommand';
            nameField.input.value = formState.name;
            argSpecPreviewField.input.value = formState.argSpec || '(none)';

            guidedCard.hidden = formState.uiMode !== 'guided';
            expertCard.hidden = formState.uiMode !== 'expert';

            actionField.select.value = formState.action;
            declarationPreviewField.input.value = actionDetails.declaration;
            actionHelp.textContent = actionDetails.help;
            guidedUseCases.textContent = `Use cases: ${buildGuidedUseCases(formState).join(' ')}`;
            guidedExampleField.textarea.value = buildGuidedUsageExample(formState);

            guidedCommandField.field.hidden = isEnvironment;
            guidedBeginField.field.hidden = !isEnvironment;
            guidedEndField.field.hidden = !isEnvironment;
            guidedCommandField.textarea.value = formState.commandPurpose;
            guidedBeginField.textarea.value = formState.environmentStartDescription;
            guidedEndField.textarea.value = formState.environmentEndDescription;

            declarationField.select.value = formState.declaration;
            specField.input.value = formState.argSpec;
            bodyField.label.textContent = isEnvironment ? 'Begin code' : 'Command body';
            bodyField.textarea.value = getSuggestedBody(formState.mode, formState);
            afterField.field.hidden = !isEnvironment;
            afterField.textarea.value = formState.environmentAfter || '% end code';

            snippetOutput.value = buildSnippet(formState);
            notesOutput.value = buildUsageNotes(formState);
            writeData(formState);
            setFooterText(widget, `${formState.uiMode === 'guided' ? 'Guided' : 'Expert'} ${isEnvironment ? 'environment' : 'command'} draft saved locally for ${getProjectName()}`);
        }

        editorModeField.select.addEventListener('change', () => {
            formState.uiMode = editorModeField.select.value;
            refreshOutputs();
        });

        modeField.select.addEventListener('change', () => {
            const previousMode = formState.mode;
            formState.mode = modeField.select.value;
            formState.action = normalizeAction(formState.mode, formState.action);
            const defaultPreviousName = previousMode === 'environment' ? 'myenvironment' : '\\mycommand';
            if (!String(formState.name || '').trim() || formState.name === defaultPreviousName) {
                formState.name = formState.mode === 'environment' ? 'myenvironment' : '\\mycommand';
            }
            refreshOutputs({ rerenderArguments: true });
        });

        nameField.input.addEventListener('input', () => {
            formState.name = nameField.input.value;
            refreshOutputs();
        });

        actionField.select.addEventListener('change', () => {
            formState.action = actionField.select.value;
            refreshOutputs();
        });

        guidedCommandField.textarea.addEventListener('input', () => {
            formState.commandPurpose = guidedCommandField.textarea.value;
            refreshOutputs();
        });

        guidedBeginField.textarea.addEventListener('input', () => {
            formState.environmentStartDescription = guidedBeginField.textarea.value;
            refreshOutputs();
        });

        guidedEndField.textarea.addEventListener('input', () => {
            formState.environmentEndDescription = guidedEndField.textarea.value;
            refreshOutputs();
        });

        declarationField.select.addEventListener('change', () => {
            formState.declaration = declarationField.select.value;
            refreshOutputs();
        });

        specField.input.addEventListener('input', () => {
            formState.argSpec = specField.input.value;
            refreshOutputs();
        });

        bodyField.textarea.addEventListener('input', () => {
            if (formState.mode === 'environment') {
                formState.environmentBody = bodyField.textarea.value;
            } else {
                formState.commandBody = bodyField.textarea.value;
            }
            refreshOutputs();
        });

        afterField.textarea.addEventListener('input', () => {
            formState.environmentAfter = afterField.textarea.value;
            refreshOutputs();
        });

        SPEC_TOKENS.forEach(([token, label]) => {
            const button = document.createElement('button');
            button.type = 'button';
            button.className = 'oncb-token';
            button.innerHTML = `<code>${token}</code> · ${label}`;
            button.addEventListener('click', () => {
                formState.uiMode = 'expert';
                formState.argSpec = `${String(formState.argSpec || '').trim()} ${token}`.trim();
                refreshOutputs();
            });
            tokenRow.appendChild(button);
        });

        EXAMPLE_PRESETS.forEach(preset => {
            const button = document.createElement('button');
            button.type = 'button';
            button.className = 'oncb-chip';
            button.textContent = preset.label;
            button.addEventListener('click', () => applyPreset(preset));
            actions.prepend(button);
        });

        copySnippetButton.addEventListener('click', async () => {
            await copyText(snippetOutput.value);
            setFooterText(widget, 'Declaration copied to clipboard');
        });

        copyNotesButton.addEventListener('click', async () => {
            await copyText(notesOutput.value);
            setFooterText(widget, 'Usage notes copied to clipboard');
        });

        resetButton.addEventListener('click', () => {
            Object.assign(formState, normalizeFormState(cloneDefaultData()));
            refreshOutputs({ rerenderArguments: true });
        });

        renderGuidedArguments();
        refreshOutputs();
    }

    function openWidget() {
        const widget = ensureWidget();
        renderWidget();
        widget.hidden = false;
        widget.classList.add('is-open');
        restoreGeometry(widget);
        bringToFront();
        updateButtonState();
    }

    function closeWidget() {
        const widget = state.widget;
        if (!widget) return;
        captureGeometry();
        widget.classList.remove('is-open');
        widget.hidden = true;
        updateButtonState();
    }

    function toggleWidget() {
        const widget = ensureWidget();
        if (widget.classList.contains('is-open')) {
            closeWidget();
        } else {
            openWidget();
        }
    }

    function syncButton() {
        const context = resolveContext();
        if (!context.tabsWrapper || !context.templateButton) return;
        let button = context.tabsWrapper.querySelector(`[${BUTTON_ATTR}]`);
        if (!button) {
            button = createSidebarButton(context.templateButton);
            context.tabsWrapper.appendChild(button);
        }
        updateButtonState();
    }

    function scheduleSync(delay = 0) {
        window.clearTimeout(state.refreshTimer);
        state.refreshTimer = window.setTimeout(() => {
            syncButton();
            const widget = state.widget;
            if (widget) applyTheme(widget);
        }, delay);
    }

    function watchDom() {
        if (state.observer) return;
        state.observer = new MutationObserver(() => {
            if (state.lastHref !== window.location.href) {
                state.lastHref = window.location.href;
            }
            scheduleSync(DOM_SYNC_DEBOUNCE_MS);
        });
        state.observer.observe(document.documentElement, { childList: true, subtree: true });
        window.addEventListener('mouseup', captureGeometry, true);
        window.addEventListener('pointerup', captureGeometry, true);
        window.addEventListener('resize', () => {
            window.clearTimeout(state.resizeTimer);
            state.resizeTimer = window.setTimeout(() => {
                if (state.widget?.classList.contains('is-open')) {
                    captureGeometry();
                }
            }, DOM_SYNC_DEBOUNCE_MS);
        });
        window.addEventListener('focus', () => scheduleSync(0));
        window.addEventListener('popstate', () => scheduleSync(0));
        window.addEventListener('hashchange', () => scheduleSync(0));
    }

    function boot() {
        if (!document.body) {
            window.setTimeout(boot, 100);
            return;
        }
        ensureStyle();
        watchDom();
        scheduleSync(0);
    }

    boot();
})();
