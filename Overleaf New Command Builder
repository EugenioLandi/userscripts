// ==UserScript==
// @name         Overleaf New Command Builder
// @namespace    http://tampermonkey.net/
// @version      1.0.0
// @description  Add a sidebar button that opens a floating builder for LaTeX document commands and environments in Overleaf
// @author       You
// @match        https://*.overleaf.com/project/*
// @updateURL    https://raw.githubusercontent.com/EugenioLandi/userscripts/main/Overleaf%20New%20Command%20Builder
// @downloadURL  https://raw.githubusercontent.com/EugenioLandi/userscripts/main/Overleaf%20New%20Command%20Builder
// @grant        none
// @run-at       document-idle
// ==/UserScript==

(function () {
    'use strict';

    if (window.__overleafNewCommandBuilderInitialized) return;
    window.__overleafNewCommandBuilderInitialized = true;

    const CONFIG = {
        slug: 'new-command-builder',
        title: 'New command builder',
        subtitle: 'Generate xparse command and environment declarations with local draft persistence',
        icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M8 5 4 12l4 7"/><path d="M16 5l4 7-4 7"/><path d="M10 19h4"/><path d="M10 5h4"/></svg>',
        defaultWidth: 500,
        defaultHeight: 620,
        minWidth: 380,
        minHeight: 420,
        defaultData: {
            uiMode: 'guided',
            mode: 'command',
            action: 'new',
            declaration: '\\NewDocumentCommand',
            name: '\\mycommand',
            argSpec: 'm',
            requiredArgs: 1,
            hasOptionalArg: false,
            optionalDefault: '',
            commandPurpose: 'Describe what the command should do in plain language.',
            environmentStartDescription: 'Describe what should happen when the environment starts.',
            environmentEndDescription: 'Describe what should happen when the environment ends.',
            commandBody: '% #1',
            environmentBody: '% begin code',
            environmentAfter: '% end code',
            search: '',
        },
    };

    const STYLE_ID = `overleaf-floating-widget-style-${CONFIG.slug}`;
    const BUTTON_ATTR = `data-overleaf-floating-widget-button-${CONFIG.slug}`;
    const WIDGET_ID = `overleaf-floating-widget-${CONFIG.slug}`;
    const TABS_WRAPPER_SELECTOR = '.ide-rail-tabs-wrapper';
    const FILE_TREE_TAB_SELECTOR = '[data-rr-ui-event-key="file-tree"]';
    const DOM_SYNC_DEBOUNCE_MS = 150;
    const WIDGET_PADDING = 16;
    const WIDGET_MIN_TOP = 72;
    const DRAG_IGNORE_SELECTOR = 'button, input, textarea, select, a, label';

    const COMMAND_DECLARATIONS = [
        '\\NewDocumentCommand',
        '\\RenewDocumentCommand',
        '\\ProvideDocumentCommand',
        '\\DeclareDocumentCommand',
        '\\NewExpandableDocumentCommand',
        '\\RenewExpandableDocumentCommand',
        '\\ProvideExpandableDocumentCommand',
    ];

    const ENVIRONMENT_DECLARATIONS = [
        '\\NewDocumentEnvironment',
        '\\RenewDocumentEnvironment',
        '\\ProvideDocumentEnvironment',
        '\\DeclareDocumentEnvironment',
    ];

    const SPEC_TOKENS = [
        ['m', 'mandatory'],
        ['o', 'optional'],
        ['O{default}', 'optional with default'],
        ['s', 'optional star'],
        ['t+', 'literal token'],
        ['r()', 'delimited required'],
        ['d[]', 'delimited optional'],
        ['v', 'verbatim'],
        ['b', 'env body'],
    ];

    const state = {
        widget: null,
        refreshTimer: null,
        observer: null,
        resizeTimer: null,
        zIndex: 100000,
        lastHref: window.location.href,
    };

    function getProjectId() {
        const match = window.location.pathname.match(/\/project\/([^/]+)/);
        return match ? match[1] : null;
    }

    function getProjectName() {
        const selectors = [
            '.ide-redesign-toolbar-project-name',
            '[data-testid="project-name"]',
            'input[aria-label="Project name"]',
            'input[name="projectName"]',
        ];
        for (const selector of selectors) {
            const element = document.querySelector(selector);
            const value = element?.value || element?.textContent;
            if (value && value.trim()) return value.trim();
        }
        return document.title.replace(/\s*-\s*Overleaf.*$/i, '').trim() || 'Untitled project';
    }

    function getProjectStorageScope() {
        return getProjectId() || `fallback-page:${window.location.pathname}${window.location.search}`;
    }

    function getStorageKey(kind) {
        return `overleaf-floating-widget:${CONFIG.slug}:${getProjectStorageScope()}:${kind}`;
    }

    function cloneDefaultData() {
        return JSON.parse(JSON.stringify(CONFIG.defaultData));
    }

    function readJson(key, fallback) {
        try {
            const parsed = JSON.parse(localStorage.getItem(key) || 'null');
            return parsed ?? fallback;
        } catch {
            return fallback;
        }
    }

    function writeJson(key, value) {
        try {
            localStorage.setItem(key, JSON.stringify(value));
        } catch {
            // ignore quota errors
        }
    }

    function readData() {
        return readJson(getStorageKey('data'), cloneDefaultData());
    }

    function writeData(value) {
        writeJson(getStorageKey('data'), value);
    }

    async function copyText(text) {
        if (navigator.clipboard?.writeText) {
            await navigator.clipboard.writeText(text);
            return;
        }
        const textarea = document.createElement('textarea');
        textarea.value = text;
        textarea.setAttribute('readonly', 'readonly');
        textarea.style.cssText = 'position:fixed;left:-9999px;top:-9999px;';
        document.body.appendChild(textarea);
        textarea.select();
        if (typeof document.execCommand === 'function' && document.queryCommandSupported?.('copy') !== false) {
            document.execCommand('copy');
        }
        textarea.remove();
    }

    function resolveContext() {
        const tabsWrapper = document.querySelector(TABS_WRAPPER_SELECTOR);
        const fileTreeButton = tabsWrapper?.querySelector(FILE_TREE_TAB_SELECTOR) || null;
        const templateButton = fileTreeButton || tabsWrapper?.querySelector('button, [role="tab"]') || null;
        return { tabsWrapper, templateButton };
    }

    function detectTheme() {
        return {
            bg: '#1b222c',
            fg: '#dbe5f3',
            border: '#46566f',
            muted: '#aab6c8',
            buttonBg: '#273142',
            hover: '#354258',
            inputBg: '#2f3a4c',
            activeButtonBg: '#2f3a4c',
            accent: '#88b7ff',
        };
    }

    function ensureStyle() {
        if (document.getElementById(STYLE_ID)) return;
        const style = document.createElement('style');
        style.id = STYLE_ID;
        style.textContent = `
            [${BUTTON_ATTR}] {
                position: relative;
                display: inline-flex !important;
                align-items: center !important;
                justify-content: center !important;
                align-self: center !important;
                margin-inline: auto;
                padding: 0 !important;
                box-sizing: border-box;
            }
            [${BUTTON_ATTR}] .ide-rail-tab-link-icon {
                display: inline-flex;
                align-items: center;
                justify-content: center;
                width: 20px;
                height: 20px;
                pointer-events: none;
            }
            [${BUTTON_ATTR}] .ide-rail-tab-link-icon svg {
                width: 20px;
                height: 20px;
                display: block;
                flex: 0 0 auto;
            }
            [${BUTTON_ATTR}].is-open {
                background: var(--oncb-active-button-bg, #2f3a4c) !important;
                box-shadow: none !important;
            }
            #${WIDGET_ID}, #${WIDGET_ID} * {
                box-sizing: border-box;
            }
            #${WIDGET_ID} {
                position: fixed;
                z-index: 100000;
                display: none;
                flex-direction: column;
                width: ${CONFIG.defaultWidth}px;
                height: ${CONFIG.defaultHeight}px;
                min-width: ${CONFIG.minWidth}px;
                min-height: ${CONFIG.minHeight}px;
                max-width: calc(100vw - ${WIDGET_PADDING * 2}px);
                max-height: calc(100vh - ${WIDGET_MIN_TOP + WIDGET_PADDING}px);
                overflow: hidden;
                resize: both;
                border: 1px solid var(--oncb-border, #46566f);
                border-radius: 14px;
                background: var(--oncb-bg, #1b222c);
                color: var(--oncb-fg, #dbe5f3);
                box-shadow: 0 22px 48px rgba(15, 23, 42, 0.32);
            }
            #${WIDGET_ID}.is-open {
                display: flex;
            }
            #${WIDGET_ID} .oncb-header,
            #${WIDGET_ID} .oncb-footer {
                padding: 14px 16px;
                border-color: var(--oncb-border, #46566f);
            }
            #${WIDGET_ID} .oncb-header {
                display: flex;
                align-items: flex-start;
                justify-content: space-between;
                gap: 10px;
                border-bottom: 1px solid var(--oncb-border, #46566f);
                cursor: grab;
                user-select: none;
                touch-action: none;
            }
            #${WIDGET_ID} .oncb-heading {
                min-width: 0;
                flex: 1 1 auto;
            }
            #${WIDGET_ID} .oncb-title {
                margin: 0;
                font-size: 0.9375rem;
                font-weight: 700;
                line-height: 1.35;
            }
            #${WIDGET_ID} .oncb-subtitle,
            #${WIDGET_ID} .oncb-muted {
                margin: 4px 0 0;
                font-size: 0.75rem;
                line-height: 1.45;
                color: var(--oncb-muted, #aab6c8);
            }
            #${WIDGET_ID} .oncb-close,
            #${WIDGET_ID} .oncb-button,
            #${WIDGET_ID} .oncb-token,
            #${WIDGET_ID} .oncb-chip {
                border: 1px solid var(--oncb-border, #46566f);
                border-radius: 8px;
                background: var(--oncb-button-bg, #273142);
                color: inherit;
                cursor: pointer;
            }
            #${WIDGET_ID} .oncb-close {
                width: 28px;
                height: 28px;
                background: transparent;
                display: inline-flex;
                align-items: center;
                justify-content: center;
                font-size: 17px;
                line-height: 1;
            }
            #${WIDGET_ID} .oncb-close:hover,
            #${WIDGET_ID} .oncb-button:hover,
            #${WIDGET_ID} .oncb-token:hover,
            #${WIDGET_ID} .oncb-chip:hover {
                background: var(--oncb-hover, #354258);
            }
            #${WIDGET_ID} .oncb-body {
                flex: 1 1 auto;
                min-height: 0;
                overflow: auto;
                padding: 14px 16px;
                display: flex;
                flex-direction: column;
                gap: 12px;
            }
            #${WIDGET_ID} .oncb-footer {
                border-top: 1px solid var(--oncb-border, #46566f);
                font-size: 0.6875rem;
                line-height: 1.45;
                color: var(--oncb-muted, #aab6c8);
                min-height: 14px;
            }
            #${WIDGET_ID} .oncb-form,
            #${WIDGET_ID} .oncb-grid,
            #${WIDGET_ID} .oncb-actions,
            #${WIDGET_ID} .oncb-token-row,
            #${WIDGET_ID} .oncb-preview-actions {
                display: flex;
                flex-wrap: wrap;
                gap: 8px;
            }
            #${WIDGET_ID} .oncb-form {
                flex-direction: column;
            }
            #${WIDGET_ID} .oncb-grid {
                display: grid;
                grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
            }
            #${WIDGET_ID} .oncb-field {
                display: flex;
                flex-direction: column;
                gap: 6px;
                min-width: 0;
                font-size: 0.75rem;
                font-weight: 600;
            }
            #${WIDGET_ID} .oncb-input,
            #${WIDGET_ID} textarea,
            #${WIDGET_ID} select {
                width: 100%;
                border: 1px solid var(--oncb-border, #46566f);
                border-radius: 8px;
                padding: 8px 10px;
                background: var(--oncb-input-bg, #2f3a4c);
                color: inherit;
                font: inherit;
                font-size: 0.8125rem;
            }
            #${WIDGET_ID} textarea {
                min-height: 110px;
                resize: vertical;
                font-family: ui-monospace, SFMono-Regular, Consolas, monospace;
                line-height: 1.55;
            }
            #${WIDGET_ID} .oncb-preview {
                border: 1px solid var(--oncb-border, #46566f);
                border-radius: 10px;
                background: var(--oncb-input-bg, #2f3a4c);
                padding: 12px;
                display: flex;
                flex-direction: column;
                gap: 10px;
            }
            #${WIDGET_ID} .oncb-output {
                min-height: 180px;
            }
            #${WIDGET_ID} .oncb-token,
            #${WIDGET_ID} .oncb-chip,
            #${WIDGET_ID} .oncb-button {
                padding: 7px 10px;
                font-size: 0.75rem;
                font-weight: 600;
                line-height: 1.3;
            }
            #${WIDGET_ID} .oncb-token code,
            #${WIDGET_ID} .oncb-chip code {
                font-family: ui-monospace, SFMono-Regular, Consolas, monospace;
                font-size: 0.72rem;
            }
            #${WIDGET_ID} .oncb-card {
                border: 1px solid var(--oncb-border, #46566f);
                border-radius: 10px;
                background: var(--oncb-input-bg, #2f3a4c);
                padding: 12px;
                display: flex;
                flex-direction: column;
                gap: 8px;
            }
            #${WIDGET_ID} .oncb-help {
                margin: 0;
                font-size: 0.75rem;
                line-height: 1.55;
                color: var(--oncb-muted, #aab6c8);
            }
            #${WIDGET_ID} .oncb-help code {
                font-family: ui-monospace, SFMono-Regular, Consolas, monospace;
                font-size: 0.72rem;
            }
        `;
        document.head.appendChild(style);
    }

    function replaceButtonIcon(button) {
        const wrapper = document.createElement('span');
        wrapper.innerHTML = CONFIG.icon.trim();
        const icon = wrapper.firstElementChild;
        if (!icon) return;
        const iconSlot = document.createElement('span');
        iconSlot.className = 'ide-rail-tab-link-icon';
        iconSlot.setAttribute('aria-hidden', 'true');
        iconSlot.appendChild(icon);
        button.replaceChildren(iconSlot);
    }

    function createSidebarButton(templateButton) {
        const button = document.createElement('button');
        const classList = templateButton
            ? [...templateButton.classList].filter(cls => !['d-flex', 'flex-column', 'align-items-center', 'justify-content-center', 'text-center', 'p-0', 'px-0', 'py-0'].includes(cls))
            : ['nav-link'];
        button.className = classList.join(' ');
        button.type = 'button';
        button.setAttribute(BUTTON_ATTR, '1');
        button.setAttribute('aria-label', CONFIG.title);
        button.setAttribute('title', CONFIG.title);
        replaceButtonIcon(button);
        button.addEventListener('click', event => {
            event.preventDefault();
            event.stopPropagation();
            toggleWidget();
        }, true);
        return button;
    }

    function bringToFront() {
        const widget = state.widget;
        if (!widget) return;
        state.zIndex += 1;
        widget.style.zIndex = String(state.zIndex);
    }

    function clampSize(size) {
        return {
            width: Math.min(Math.max(CONFIG.minWidth, Math.round(size.width || CONFIG.defaultWidth)), Math.max(CONFIG.minWidth, window.innerWidth - WIDGET_PADDING * 2)),
            height: Math.min(Math.max(CONFIG.minHeight, Math.round(size.height || CONFIG.defaultHeight)), Math.max(CONFIG.minHeight, window.innerHeight - WIDGET_MIN_TOP - WIDGET_PADDING)),
        };
    }

    function clampPosition(widget, position) {
        const width = widget.offsetWidth || CONFIG.defaultWidth;
        const height = widget.offsetHeight || CONFIG.defaultHeight;
        return {
            x: Math.min(Math.max(WIDGET_PADDING, Math.round(position.x)), Math.max(WIDGET_PADDING, window.innerWidth - width - WIDGET_PADDING)),
            y: Math.min(Math.max(WIDGET_MIN_TOP, Math.round(position.y)), Math.max(WIDGET_MIN_TOP, window.innerHeight - height - WIDGET_PADDING)),
        };
    }

    function getDefaultPosition() {
        return {
            x: Math.max(WIDGET_PADDING, Math.round((window.innerWidth - CONFIG.defaultWidth) / 2)),
            y: 112,
        };
    }

    function applySize(widget, size, persist = true) {
        const next = clampSize(size);
        widget.style.width = `${next.width}px`;
        widget.style.height = `${next.height}px`;
        if (persist) writeJson(getStorageKey('size'), next);
    }

    function applyPosition(widget, position, persist = true) {
        const next = clampPosition(widget, position);
        widget.style.left = `${next.x}px`;
        widget.style.top = `${next.y}px`;
        if (persist) writeJson(getStorageKey('position'), next);
    }

    function restoreGeometry(widget) {
        applySize(widget, readJson(getStorageKey('size'), { width: CONFIG.defaultWidth, height: CONFIG.defaultHeight }), false);
        applyPosition(widget, readJson(getStorageKey('position'), getDefaultPosition()), false);
    }

    function captureGeometry() {
        const widget = state.widget;
        if (!widget || !widget.classList.contains('is-open')) return;
        const rect = widget.getBoundingClientRect();
        applySize(widget, { width: rect.width, height: rect.height });
        applyPosition(widget, { x: rect.left, y: rect.top });
    }

    function setFooterText(widget, text) {
        const footer = widget.querySelector('.oncb-footer');
        if (footer) footer.textContent = String(text || '');
    }

    function applyTheme(widget) {
        const theme = detectTheme();
        widget.style.setProperty('--oncb-bg', theme.bg);
        widget.style.setProperty('--oncb-fg', theme.fg);
        widget.style.setProperty('--oncb-border', theme.border);
        widget.style.setProperty('--oncb-muted', theme.muted);
        widget.style.setProperty('--oncb-button-bg', theme.buttonBg);
        widget.style.setProperty('--oncb-hover', theme.hover);
        widget.style.setProperty('--oncb-input-bg', theme.inputBg);
        widget.style.setProperty('--oncb-accent', theme.accent);
        document.documentElement.style.setProperty('--oncb-active-button-bg', theme.activeButtonBg);
    }

    function updateButtonState() {
        const button = document.querySelector(`[${BUTTON_ATTR}]`);
        const open = Boolean(state.widget && state.widget.classList.contains('is-open'));
        if (!button) return;
        button.classList.toggle('is-open', open);
        button.setAttribute('aria-pressed', open ? 'true' : 'false');
    }

    function makeDraggable(widget, handle) {
        let pointerId = null;
        let originX = 0;
        let originY = 0;
        let startX = 0;
        let startY = 0;

        handle.addEventListener('pointerdown', event => {
            if (event.button !== 0) return;
            if (event.target instanceof Element && event.target.closest(DRAG_IGNORE_SELECTOR)) return;
            pointerId = event.pointerId;
            handle.setPointerCapture(pointerId);
            const rect = widget.getBoundingClientRect();
            originX = rect.left;
            originY = rect.top;
            startX = event.clientX;
            startY = event.clientY;
            handle.style.cursor = 'grabbing';
            bringToFront();
            event.preventDefault();
        });

        handle.addEventListener('pointermove', event => {
            if (event.pointerId !== pointerId) return;
            applyPosition(widget, {
                x: originX + event.clientX - startX,
                y: originY + event.clientY - startY,
            });
        });

        const release = event => {
            if (event.pointerId !== pointerId) return;
            pointerId = null;
            handle.style.cursor = 'grab';
        };

        handle.addEventListener('pointerup', release);
        handle.addEventListener('pointercancel', release);
    }

    function ensureWidget() {
        if (state.widget?.isConnected) return state.widget;

        const widget = document.createElement('section');
        widget.id = WIDGET_ID;
        widget.hidden = true;

        const header = document.createElement('div');
        header.className = 'oncb-header';

        const heading = document.createElement('div');
        heading.className = 'oncb-heading';

        const title = document.createElement('h2');
        title.className = 'oncb-title';
        title.textContent = CONFIG.title;

        const subtitle = document.createElement('p');
        subtitle.className = 'oncb-subtitle';
        subtitle.textContent = CONFIG.subtitle;
        heading.append(title, subtitle);

        const close = document.createElement('button');
        close.type = 'button';
        close.className = 'oncb-close';
        close.textContent = '×';
        close.setAttribute('aria-label', `Close ${CONFIG.title}`);
        close.addEventListener('click', closeWidget);

        header.append(heading, close);

        const body = document.createElement('div');
        body.className = 'oncb-body';
        const footer = document.createElement('div');
        footer.className = 'oncb-footer';

        widget.append(header, body, footer);
        widget.addEventListener('pointerdown', bringToFront, true);
        document.body.appendChild(widget);
        applyTheme(widget);
        makeDraggable(widget, header);
        state.widget = widget;
        return widget;
    }

    function normalizeName(value, mode) {
        const raw = String(value || '').trim();
        if (!raw) return mode === 'environment' ? 'myenvironment' : '\\mycommand';
        if (mode === 'environment') return raw.replace(/^\\+/, '');
        return raw.startsWith('\\') ? raw : `\\${raw}`;
    }

    function getDeclarationOptions(mode) {
        return mode === 'environment' ? ENVIRONMENT_DECLARATIONS : COMMAND_DECLARATIONS;
    }

    function getActionOptions(mode) {
        return mode === 'environment'
            ? [
                { value: 'new', label: 'Create a new environment', declaration: '\\NewDocumentEnvironment', help: 'Use this when the environment name is brand new. It errors if that environment already exists.' },
                { value: 'renew', label: 'Replace an existing environment', declaration: '\\RenewDocumentEnvironment', help: 'Use this when the environment already exists and you want to redefine it.' },
                { value: 'provide', label: 'Create it only if missing', declaration: '\\ProvideDocumentEnvironment', help: 'Use this when you want a fallback that will not overwrite an existing environment.' },
                { value: 'declare', label: 'Advanced declaration form', declaration: '\\DeclareDocumentEnvironment', help: 'This is the low-level xparse-style declaration form. Choose it if you specifically want the declare variant.' },
            ]
            : [
                { value: 'new', label: 'Create a new command', declaration: '\\NewDocumentCommand', help: 'Use this when the command name is brand new. It errors if that command already exists.' },
                { value: 'renew', label: 'Replace an existing command', declaration: '\\RenewDocumentCommand', help: 'Use this when the command already exists and you want to redefine it.' },
                { value: 'provide', label: 'Create it only if missing', declaration: '\\ProvideDocumentCommand', help: 'Use this when you want a fallback that will not overwrite an existing command.' },
                { value: 'declare', label: 'Advanced declaration form', declaration: '\\DeclareDocumentCommand', help: 'This is the low-level xparse-style declaration form. Choose it if you specifically want the declare variant.' },
            ];
    }

    function normalizeUiMode(value) {
        return value === 'expert' ? 'expert' : 'guided';
    }

    function normalizeAction(mode, value) {
        const options = getActionOptions(mode);
        return options.some(option => option.value === value) ? value : options[0].value;
    }

    function getActionDetails(mode, action) {
        return getActionOptions(mode).find(option => option.value === action) || getActionOptions(mode)[0];
    }

    function normalizeRequiredArgs(value) {
        const numeric = Number.parseInt(String(value ?? ''), 10);
        if (Number.isNaN(numeric)) return 1;
        return Math.min(Math.max(numeric, 0), 4);
    }

    function commentize(text, fallback) {
        const lines = String(text || '')
            .split(/\r?\n/)
            .map(line => line.trim())
            .filter(Boolean);
        const source = lines.length ? lines : [fallback];
        return source.map(line => `% ${line}`);
    }

    function buildGuidedArgSpec(data) {
        const parts = [];
        if (data.hasOptionalArg) {
            const defaultValue = String(data.optionalDefault || '').trim();
            parts.push(defaultValue ? `O{${defaultValue}}` : 'o');
        }
        for (let index = 0; index < normalizeRequiredArgs(data.requiredArgs); index += 1) {
            parts.push('m');
        }
        return parts.join(' ');
    }

    function buildGuidedParameterNotes(data) {
        const notes = [];
        let parameterIndex = 1;
        if (data.hasOptionalArg) {
            const defaultValue = String(data.optionalDefault || '').trim();
            notes.push(defaultValue
                ? `% #${parameterIndex} = optional input (defaults to "${defaultValue}")`
                : `% #${parameterIndex} = optional input`);
            parameterIndex += 1;
        }
        const requiredArgs = normalizeRequiredArgs(data.requiredArgs);
        for (let index = 0; index < requiredArgs; index += 1) {
            notes.push(`% #${parameterIndex} = required input ${index + 1}`);
            parameterIndex += 1;
        }
        if (!notes.length) {
            notes.push('% This definition takes no user inputs.');
        }
        return notes;
    }

    function buildGuidedUsageExample(data) {
        const optionalPart = data.hasOptionalArg
            ? `[${String(data.optionalDefault || '').trim() || 'optional'}]`
            : '';
        const requiredPart = Array.from({ length: normalizeRequiredArgs(data.requiredArgs) }, (_, index) => `{value${index + 1}}`).join('');
        if (data.mode === 'environment') {
            const envName = normalizeName(data.name, 'environment');
            return `\\begin{${envName}}${optionalPart}${requiredPart}\n    % environment content\n\\end{${envName}}`;
        }
        return `${normalizeName(data.name, 'command')}${optionalPart}${requiredPart}`;
    }

    function buildGuidedCommandBody(data) {
        return [
            ...commentize(data.commandPurpose, 'Goal: describe what the command should do.'),
            ...buildGuidedParameterNotes(data),
            '% Replace the comment block below with the LaTeX code you want to run.',
            '% TODO: write the command body here',
        ].join('\n');
    }

    function buildGuidedEnvironmentBody(data) {
        return [
            ...commentize(data.environmentStartDescription, 'Start behavior: describe what should happen when the environment begins.'),
            ...buildGuidedParameterNotes(data),
            '% Replace the comment block below with the LaTeX code that should run at \\begin.',
            '% TODO: write the begin code here',
        ].join('\n');
    }

    function buildGuidedEnvironmentAfter(data) {
        return [
            ...commentize(data.environmentEndDescription, 'End behavior: describe what should happen when the environment ends.'),
            '% Replace the comment block below with the LaTeX code that should run at \\end.',
            '% TODO: write the end code here',
        ].join('\n');
    }

    function syncGuidedFields(data) {
        const actionDetails = getActionDetails(data.mode, data.action);
        data.declaration = actionDetails.declaration;
        data.argSpec = buildGuidedArgSpec(data);
        if (data.mode === 'environment') {
            data.environmentBody = buildGuidedEnvironmentBody(data);
            data.environmentAfter = buildGuidedEnvironmentAfter(data);
        } else {
            data.commandBody = buildGuidedCommandBody(data);
        }
    }

    function normalizeFormState(data) {
        const merged = {
            ...cloneDefaultData(),
            ...data,
        };
        merged.uiMode = normalizeUiMode(merged.uiMode);
        merged.mode = merged.mode === 'environment' ? 'environment' : 'command';
        merged.action = normalizeAction(merged.mode, merged.action);
        merged.requiredArgs = normalizeRequiredArgs(merged.requiredArgs);
        merged.hasOptionalArg = Boolean(merged.hasOptionalArg);
        merged.optionalDefault = String(merged.optionalDefault || '');
        merged.commandPurpose = String(merged.commandPurpose || '');
        merged.environmentStartDescription = String(merged.environmentStartDescription || '');
        merged.environmentEndDescription = String(merged.environmentEndDescription || '');
        merged.declaration = String(merged.declaration || getDeclarationOptions(merged.mode)[0]);
        merged.name = String(merged.name || (merged.mode === 'environment' ? 'myenvironment' : '\\mycommand'));
        merged.argSpec = String(merged.argSpec ?? '');
        merged.commandBody = String(merged.commandBody || '% #1');
        merged.environmentBody = String(merged.environmentBody || '% begin code');
        merged.environmentAfter = String(merged.environmentAfter || '% end code');
        return merged;
    }

    function getSuggestedBody(mode, data) {
        if (mode === 'environment') return data.environmentBody || '% begin code';
        return data.commandBody || '% #1';
    }

    function buildSnippet(data) {
        const mode = data.mode === 'environment' ? 'environment' : 'command';
        const declaration = getDeclarationOptions(mode).includes(data.declaration)
            ? data.declaration
            : getDeclarationOptions(mode)[0];
        const name = normalizeName(data.name, mode);
        const argSpec = String(data.argSpec || '').trim();
        if (mode === 'environment') {
            const beginBody = String(data.environmentBody || '% begin code').trim() || '% begin code';
            const endBody = String(data.environmentAfter || '% end code').trim() || '% end code';
            return `${declaration}{${name}}{${argSpec}}{\n    ${beginBody.replace(/\n/g, '\n    ')}\n}{\n    ${endBody.replace(/\n/g, '\n    ')}\n}`;
        }
        const commandBody = String(data.commandBody || '% #1').trim() || '% #1';
        return `${declaration}{${name}}{${argSpec}}{\n    ${commandBody.replace(/\n/g, '\n    ')}\n}`;
    }

    function buildUsageNotes(data) {
        const mode = data.mode === 'environment' ? 'environment' : 'command';
        const normalized = normalizeName(data.name, mode);
        const bareName = mode === 'environment' ? normalized : normalized.replace(/^\\/, '');
        const spec = String(data.argSpec || '').trim();
        if (data.uiMode === 'guided') {
            const actionDetails = getActionDetails(mode, data.action);
            const notes = [
                `Project: ${getProjectName()}`,
                `Builder mode: Guided`,
                `Declaration: ${actionDetails.declaration}`,
                `Why this variant: ${actionDetails.help}`,
                spec ? `Argument spec: ${spec}` : 'Argument spec: (none)',
                `Example call:\n${buildGuidedUsageExample(data)}`,
                'Paste the generated declaration in your project preamble or in a .sty file that the project loads.',
            ];
            return notes.join('\n\n');
        }
        const notes = [
            `Project: ${getProjectName()}`,
            `Builder mode: Expert`,
            mode === 'environment' ? `Environment name: ${bareName}` : `Command name: ${normalized}`,
            `Declaration: ${data.declaration}`,
            spec ? `Argument spec: ${spec}` : 'Argument spec: (none)',
            mode === 'environment'
                ? `Usage:\n\\begin{${bareName}} ... \\end{${bareName}}`
                : `Usage:\n${normalized}{...}`,
        ];
        return notes.join('\n\n');
    }

    function renderWidget() {
        const widget = ensureWidget();
        const body = widget.querySelector('.oncb-body');
        if (!body) return;
        body.textContent = '';
        applyTheme(widget);

        const formState = normalizeFormState(readData());

        const intro = document.createElement('p');
        intro.className = 'oncb-muted';
        intro.textContent = 'Use Guided mode for plain-language prompts, or switch to Expert mode if you already know the xparse syntax you want.';
        body.appendChild(intro);

        const form = document.createElement('div');
        form.className = 'oncb-form';
        body.appendChild(form);

        const setupCard = document.createElement('div');
        setupCard.className = 'oncb-card';
        const setupGrid = document.createElement('div');
        setupGrid.className = 'oncb-grid';
        setupCard.appendChild(setupGrid);
        form.appendChild(setupCard);

        function createSelectField(labelText, options) {
            const field = document.createElement('label');
            field.className = 'oncb-field';
            const label = document.createElement('span');
            label.textContent = labelText;
            const select = document.createElement('select');
            select.className = 'oncb-input';
            options.forEach(([value, text]) => {
                const option = document.createElement('option');
                option.value = value;
                option.textContent = text;
                select.appendChild(option);
            });
            field.append(label, select);
            return { field, select };
        }

        function createInputField(labelText, placeholder = '') {
            const field = document.createElement('label');
            field.className = 'oncb-field';
            const label = document.createElement('span');
            label.textContent = labelText;
            const input = document.createElement('input');
            input.className = 'oncb-input';
            input.placeholder = placeholder;
            field.append(label, input);
            return { field, input };
        }

        function createTextareaField(labelText) {
            const field = document.createElement('label');
            field.className = 'oncb-field';
            const label = document.createElement('span');
            label.textContent = labelText;
            const textarea = document.createElement('textarea');
            textarea.className = 'oncb-input';
            field.append(label, textarea);
            return { field, label, textarea };
        }

        const editorModeField = createSelectField('Editor mode', [['guided', 'Guided'], ['expert', 'Expert']]);
        const modeField = createSelectField('Build', [['command', 'Command'], ['environment', 'Environment']]);
        const nameField = createInputField('Name');
        setupGrid.append(editorModeField.field, modeField.field, nameField.field);

        const guidedCard = document.createElement('div');
        guidedCard.className = 'oncb-card';
        form.appendChild(guidedCard);

        const guidedIntro = document.createElement('p');
        guidedIntro.className = 'oncb-help';
        guidedIntro.textContent = 'Answer a few plain-language questions and the builder will choose the declaration form, argument spec, and starter template for you.';
        guidedCard.appendChild(guidedIntro);

        const guidedGrid = document.createElement('div');
        guidedGrid.className = 'oncb-grid';
        guidedCard.appendChild(guidedGrid);

        const actionField = createSelectField('What do you want to do?', []);
        const declarationPreviewField = createInputField('Builder will use');
        declarationPreviewField.input.readOnly = true;
        const requiredArgsField = createSelectField('How many required inputs?', [['0', '0'], ['1', '1'], ['2', '2'], ['3', '3'], ['4', '4']]);
        const optionalArgField = createSelectField('Add an optional first input?', [['false', 'No'], ['true', 'Yes']]);
        const optionalDefaultField = createInputField('Optional default value', 'leave blank for a plain optional input');
        const argSpecPreviewField = createInputField('Generated argument spec');
        argSpecPreviewField.input.readOnly = true;
        guidedGrid.append(
            actionField.field,
            declarationPreviewField.field,
            requiredArgsField.field,
            optionalArgField.field,
            optionalDefaultField.field,
            argSpecPreviewField.field,
        );

        const actionHelp = document.createElement('p');
        actionHelp.className = 'oncb-help';
        guidedCard.appendChild(actionHelp);

        const guidedCommandField = createTextareaField('What should the command do?');
        guidedCommandField.textarea.placeholder = 'Example: Make the text bold and prefix it with “Remark:”.';
        guidedCard.appendChild(guidedCommandField.field);

        const guidedBeginField = createTextareaField('What should happen when the environment starts?');
        guidedBeginField.textarea.placeholder = 'Example: Start a boxed block with a bold title.';
        guidedCard.appendChild(guidedBeginField.field);

        const guidedEndField = createTextareaField('What should happen when the environment ends?');
        guidedEndField.textarea.placeholder = 'Example: Close the box and add a little spacing.';
        guidedCard.appendChild(guidedEndField.field);

        const expertCard = document.createElement('div');
        expertCard.className = 'oncb-card';
        form.appendChild(expertCard);

        const expertIntro = document.createElement('p');
        expertIntro.className = 'oncb-help';
        expertIntro.textContent = 'Expert mode exposes the raw declaration, argument spec, and body fields directly.';
        expertCard.appendChild(expertIntro);

        const expertGrid = document.createElement('div');
        expertGrid.className = 'oncb-grid';
        expertCard.appendChild(expertGrid);

        const declarationField = createSelectField('Declaration', []);
        const specField = createInputField('Argument spec', 'm O{default} s');
        expertGrid.append(declarationField.field, specField.field);

        const tokenCard = document.createElement('div');
        tokenCard.className = 'oncb-card';
        const tokenTitle = document.createElement('p');
        tokenTitle.className = 'oncb-muted';
        tokenTitle.textContent = 'Argument-spec shortcuts';
        const tokenRow = document.createElement('div');
        tokenRow.className = 'oncb-token-row';
        tokenCard.append(tokenTitle, tokenRow);
        expertCard.appendChild(tokenCard);

        const bodyField = createTextareaField('Command body');
        expertCard.appendChild(bodyField.field);

        const afterField = createTextareaField('End code');
        expertCard.appendChild(afterField.field);

        const snippetCard = document.createElement('div');
        snippetCard.className = 'oncb-preview';
        const snippetTitle = document.createElement('p');
        snippetTitle.className = 'oncb-muted';
        snippetTitle.textContent = 'Generated declaration';
        const snippetOutput = document.createElement('textarea');
        snippetOutput.className = 'oncb-input oncb-output';
        snippetCard.append(snippetTitle, snippetOutput);
        body.appendChild(snippetCard);

        const notesCard = document.createElement('div');
        notesCard.className = 'oncb-preview';
        const notesTitle = document.createElement('p');
        notesTitle.className = 'oncb-muted';
        notesTitle.textContent = 'Usage notes';
        const notesOutput = document.createElement('textarea');
        notesOutput.className = 'oncb-input';
        notesOutput.style.minHeight = '140px';
        notesCard.append(notesTitle, notesOutput);
        body.appendChild(notesCard);

        const actions = document.createElement('div');
        actions.className = 'oncb-actions';
        const copySnippetButton = document.createElement('button');
        copySnippetButton.type = 'button';
        copySnippetButton.className = 'oncb-button';
        copySnippetButton.textContent = 'Copy declaration';
        const copyNotesButton = document.createElement('button');
        copyNotesButton.type = 'button';
        copyNotesButton.className = 'oncb-button';
        copyNotesButton.textContent = 'Copy usage notes';
        const resetButton = document.createElement('button');
        resetButton.type = 'button';
        resetButton.className = 'oncb-button';
        resetButton.textContent = 'Reset draft';
        actions.append(copySnippetButton, copyNotesButton, resetButton);
        body.appendChild(actions);

        function syncActionOptions() {
            const options = getActionOptions(formState.mode);
            const nextValue = normalizeAction(formState.mode, formState.action);
            formState.action = nextValue;
            actionField.select.textContent = '';
            options.forEach(optionData => {
                const option = document.createElement('option');
                option.value = optionData.value;
                option.textContent = optionData.label;
                option.selected = optionData.value === nextValue;
                actionField.select.appendChild(option);
            });
        }

        function syncDeclarationOptions() {
            const options = getDeclarationOptions(formState.mode);
            const nextValue = options.includes(formState.declaration) ? formState.declaration : options[0];
            formState.declaration = nextValue;
            declarationField.select.textContent = '';
            options.forEach(value => {
                const option = document.createElement('option');
                option.value = value;
                option.textContent = value;
                option.selected = value === nextValue;
                declarationField.select.appendChild(option);
            });
        }

        function refreshOutputs() {
            formState.uiMode = normalizeUiMode(formState.uiMode);
            formState.mode = formState.mode === 'environment' ? 'environment' : 'command';
            formState.action = normalizeAction(formState.mode, formState.action);
            formState.requiredArgs = normalizeRequiredArgs(formState.requiredArgs);
            formState.hasOptionalArg = Boolean(formState.hasOptionalArg);
            if (formState.uiMode === 'guided') {
                syncGuidedFields(formState);
            }

            syncActionOptions();
            syncDeclarationOptions();

            const isEnvironment = formState.mode === 'environment';
            const actionDetails = getActionDetails(formState.mode, formState.action);

            editorModeField.select.value = formState.uiMode;
            modeField.select.value = formState.mode;
            nameField.input.placeholder = isEnvironment ? 'myenvironment' : '\\mycommand';
            nameField.input.value = formState.name;

            guidedCard.hidden = formState.uiMode !== 'guided';
            expertCard.hidden = formState.uiMode !== 'expert';

            actionField.select.value = formState.action;
            declarationPreviewField.input.value = actionDetails.declaration;
            requiredArgsField.select.value = String(formState.requiredArgs);
            optionalArgField.select.value = String(formState.hasOptionalArg);
            optionalDefaultField.field.hidden = !formState.hasOptionalArg;
            optionalDefaultField.input.value = formState.optionalDefault;
            argSpecPreviewField.input.value = formState.argSpec || '(none)';
            actionHelp.textContent = actionDetails.help;

            guidedCommandField.field.hidden = isEnvironment;
            guidedBeginField.field.hidden = !isEnvironment;
            guidedEndField.field.hidden = !isEnvironment;
            guidedCommandField.textarea.value = formState.commandPurpose;
            guidedBeginField.textarea.value = formState.environmentStartDescription;
            guidedEndField.textarea.value = formState.environmentEndDescription;

            declarationField.select.value = formState.declaration;
            specField.input.value = formState.argSpec;
            bodyField.label.textContent = isEnvironment ? 'Begin code' : 'Command body';
            bodyField.textarea.value = getSuggestedBody(formState.mode, formState);
            afterField.field.hidden = !isEnvironment;
            afterField.textarea.value = formState.environmentAfter || '% end code';

            snippetOutput.value = buildSnippet(formState);
            notesOutput.value = buildUsageNotes(formState);
            writeData(formState);
            setFooterText(widget, `${formState.uiMode === 'guided' ? 'Guided' : 'Expert'} ${isEnvironment ? 'environment' : 'command'} draft saved locally for ${getProjectName()}`);
        }

        editorModeField.select.addEventListener('change', () => {
            formState.uiMode = editorModeField.select.value;
            refreshOutputs();
        });

        modeField.select.addEventListener('change', () => {
            const previousMode = formState.mode;
            formState.mode = modeField.select.value;
            formState.action = normalizeAction(formState.mode, formState.action);
            const defaultPreviousName = previousMode === 'environment' ? 'myenvironment' : '\\mycommand';
            if (!String(formState.name || '').trim() || formState.name === defaultPreviousName) {
                formState.name = formState.mode === 'environment' ? 'myenvironment' : '\\mycommand';
            }
            refreshOutputs();
        });

        nameField.input.addEventListener('input', () => {
            formState.name = nameField.input.value;
            refreshOutputs();
        });

        actionField.select.addEventListener('change', () => {
            formState.action = actionField.select.value;
            refreshOutputs();
        });

        requiredArgsField.select.addEventListener('change', () => {
            formState.requiredArgs = Number(requiredArgsField.select.value);
            refreshOutputs();
        });

        optionalArgField.select.addEventListener('change', () => {
            formState.hasOptionalArg = optionalArgField.select.value === 'true';
            refreshOutputs();
        });

        optionalDefaultField.input.addEventListener('input', () => {
            formState.optionalDefault = optionalDefaultField.input.value;
            refreshOutputs();
        });

        guidedCommandField.textarea.addEventListener('input', () => {
            formState.commandPurpose = guidedCommandField.textarea.value;
            refreshOutputs();
        });

        guidedBeginField.textarea.addEventListener('input', () => {
            formState.environmentStartDescription = guidedBeginField.textarea.value;
            refreshOutputs();
        });

        guidedEndField.textarea.addEventListener('input', () => {
            formState.environmentEndDescription = guidedEndField.textarea.value;
            refreshOutputs();
        });

        declarationField.select.addEventListener('change', () => {
            formState.declaration = declarationField.select.value;
            refreshOutputs();
        });

        specField.input.addEventListener('input', () => {
            formState.argSpec = specField.input.value;
            refreshOutputs();
        });

        bodyField.textarea.addEventListener('input', () => {
            if (formState.mode === 'environment') {
                formState.environmentBody = bodyField.textarea.value;
            } else {
                formState.commandBody = bodyField.textarea.value;
            }
            refreshOutputs();
        });

        afterField.textarea.addEventListener('input', () => {
            formState.environmentAfter = afterField.textarea.value;
            refreshOutputs();
        });

        SPEC_TOKENS.forEach(([token, label]) => {
            const button = document.createElement('button');
            button.type = 'button';
            button.className = 'oncb-token';
            button.innerHTML = `<code>${token}</code> · ${label}`;
            button.addEventListener('click', () => {
                formState.uiMode = 'expert';
                formState.argSpec = `${String(formState.argSpec || '').trim()} ${token}`.trim();
                refreshOutputs();
            });
            tokenRow.appendChild(button);
        });

        [
            ['Zero-arg command', { uiMode: 'expert', mode: 'command', declaration: '\\NewDocumentCommand', name: '\\alertbox', argSpec: '', commandBody: '\\textbf{Alert}', environmentBody: formState.environmentBody, environmentAfter: formState.environmentAfter }],
            ['Optional argument command', { uiMode: 'expert', mode: 'command', declaration: '\\NewDocumentCommand', name: '\\todoitem', argSpec: 'O{TODO} m', commandBody: '\\textbf{#1}: #2', environmentBody: formState.environmentBody, environmentAfter: formState.environmentAfter }],
            ['Simple environment', { uiMode: 'expert', mode: 'environment', declaration: '\\NewDocumentEnvironment', name: 'infobox', argSpec: 'm', commandBody: formState.commandBody, environmentBody: '\\par\\noindent\\textbf{#1}\\par', environmentAfter: '\\par' }],
        ].forEach(([label, preset]) => {
            const button = document.createElement('button');
            button.type = 'button';
            button.className = 'oncb-chip';
            button.textContent = label;
            button.addEventListener('click', () => {
                Object.assign(formState, preset);
                refreshOutputs();
            });
            actions.prepend(button);
        });

        copySnippetButton.addEventListener('click', async () => {
            await copyText(snippetOutput.value);
            setFooterText(widget, 'Declaration copied to clipboard');
        });

        copyNotesButton.addEventListener('click', async () => {
            await copyText(notesOutput.value);
            setFooterText(widget, 'Usage notes copied to clipboard');
        });

        resetButton.addEventListener('click', () => {
            Object.assign(formState, normalizeFormState(cloneDefaultData()));
            refreshOutputs();
        });

        refreshOutputs();
    }

    function openWidget() {
        const widget = ensureWidget();
        renderWidget();
        widget.hidden = false;
        widget.classList.add('is-open');
        restoreGeometry(widget);
        bringToFront();
        updateButtonState();
    }

    function closeWidget() {
        const widget = state.widget;
        if (!widget) return;
        captureGeometry();
        widget.classList.remove('is-open');
        widget.hidden = true;
        updateButtonState();
    }

    function toggleWidget() {
        const widget = ensureWidget();
        if (widget.classList.contains('is-open')) {
            closeWidget();
        } else {
            openWidget();
        }
    }

    function syncButton() {
        const context = resolveContext();
        if (!context.tabsWrapper || !context.templateButton) return;
        let button = context.tabsWrapper.querySelector(`[${BUTTON_ATTR}]`);
        if (!button) {
            button = createSidebarButton(context.templateButton);
            context.tabsWrapper.appendChild(button);
        }
        updateButtonState();
    }

    function scheduleSync(delay = 0) {
        window.clearTimeout(state.refreshTimer);
        state.refreshTimer = window.setTimeout(() => {
            syncButton();
            const widget = state.widget;
            if (widget) applyTheme(widget);
        }, delay);
    }

    function watchDom() {
        if (state.observer) return;
        state.observer = new MutationObserver(() => {
            if (state.lastHref !== window.location.href) {
                state.lastHref = window.location.href;
            }
            scheduleSync(DOM_SYNC_DEBOUNCE_MS);
        });
        state.observer.observe(document.documentElement, { childList: true, subtree: true });
        window.addEventListener('mouseup', captureGeometry, true);
        window.addEventListener('pointerup', captureGeometry, true);
        window.addEventListener('resize', () => {
            window.clearTimeout(state.resizeTimer);
            state.resizeTimer = window.setTimeout(() => {
                if (state.widget?.classList.contains('is-open')) {
                    captureGeometry();
                }
            }, DOM_SYNC_DEBOUNCE_MS);
        });
        window.addEventListener('focus', () => scheduleSync(0));
        window.addEventListener('popstate', () => scheduleSync(0));
        window.addEventListener('hashchange', () => scheduleSync(0));
    }

    function boot() {
        if (!document.body) {
            window.setTimeout(boot, 100);
            return;
        }
        ensureStyle();
        watchDom();
        scheduleSync(0);
    }

    boot();
})();
