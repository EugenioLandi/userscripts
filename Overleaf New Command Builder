    function replaceButtonIcon(button) {
        const wrapper = document.createElement('span');
        wrapper.innerHTML = CONFIG.icon.trim();
        const icon = wrapper.firstElementChild;
        if (!icon) return;
        const iconSlot = document.createElement('span');
        iconSlot.className = 'ide-rail-tab-link-icon';
        iconSlot.setAttribute('aria-hidden', 'true');
        iconSlot.appendChild(icon);
        button.replaceChildren(iconSlot);
    }

    function createSidebarButton(templateButton) {
        const button = document.createElement('button');
        const classList = templateButton
            ? [...templateButton.classList].filter(cls => !['d-flex', 'flex-column', 'align-items-center', 'justify-content-center', 'text-center', 'p-0', 'px-0', 'py-0'].includes(cls))
            : ['nav-link'];
        button.className = classList.join(' ');
        button.type = 'button';
        button.setAttribute(BUTTON_ATTR, '1');
        button.setAttribute('aria-label', CONFIG.title);
        button.setAttribute('title', CONFIG.title);
        replaceButtonIcon(button);
        button.addEventListener('click', event => {
            event.preventDefault();
            event.stopPropagation();
            toggleWidget();
        }, true);
        return button;
    }

    function bringToFront() {
        const widget = state.widget;
        if (!widget) return;
        state.zIndex += 1;
        widget.style.zIndex = String(state.zIndex);
    }

    function clampSize(size) {
        return {
            width: Math.min(Math.max(CONFIG.minWidth, Math.round(size.width || CONFIG.defaultWidth)), Math.max(CONFIG.minWidth, window.innerWidth - WIDGET_PADDING * 2)),
            height: Math.min(Math.max(CONFIG.minHeight, Math.round(size.height || CONFIG.defaultHeight)), Math.max(CONFIG.minHeight, window.innerHeight - WIDGET_MIN_TOP - WIDGET_PADDING)),
        };
    }

    function clampPosition(widget, position) {
        const width = widget.offsetWidth || CONFIG.defaultWidth;
        const height = widget.offsetHeight || CONFIG.defaultHeight;
        return {
            x: Math.min(Math.max(WIDGET_PADDING, Math.round(position.x)), Math.max(WIDGET_PADDING, window.innerWidth - width - WIDGET_PADDING)),
            y: Math.min(Math.max(WIDGET_MIN_TOP, Math.round(position.y)), Math.max(WIDGET_MIN_TOP, window.innerHeight - height - WIDGET_PADDING)),
        };
    }

    function getDefaultPosition() {
        return {
            x: Math.max(WIDGET_PADDING, Math.round((window.innerWidth - CONFIG.defaultWidth) / 2)),
            y: 112,
        };
    }

    function applySize(widget, size, persist = true) {
        const next = clampSize(size);
        widget.style.width = `${next.width}px`;
        widget.style.height = `${next.height}px`;
        if (persist) writeJson(getStorageKey('size'), next);
    }

    function applyPosition(widget, position, persist = true) {
        const next = clampPosition(widget, position);
        widget.style.left = `${next.x}px`;
        widget.style.top = `${next.y}px`;
        if (persist) writeJson(getStorageKey('position'), next);
    }

    function restoreGeometry(widget) {
        applySize(widget, readJson(getStorageKey('size'), { width: CONFIG.defaultWidth, height: CONFIG.defaultHeight }), false);
        applyPosition(widget, readJson(getStorageKey('position'), getDefaultPosition()), false);
    }

    function captureGeometry() {
        const widget = state.widget;
        if (!widget || !widget.classList.contains('is-open')) return;
        const rect = widget.getBoundingClientRect();
        applySize(widget, { width: rect.width, height: rect.height });
        applyPosition(widget, { x: rect.left, y: rect.top });
    }

    function setFooterText(widget, text) {
        const footer = widget.querySelector('.oncb-footer');
        if (footer) footer.textContent = String(text || '');
    }

    function applyTheme(widget) {
        const theme = detectTheme();
        widget.style.setProperty('--oncb-bg', theme.bg);
        widget.style.setProperty('--oncb-fg', theme.fg);
        widget.style.setProperty('--oncb-border', theme.border);
        widget.style.setProperty('--oncb-muted', theme.muted);
        widget.style.setProperty('--oncb-button-bg', theme.buttonBg);
        widget.style.setProperty('--oncb-hover', theme.hover);
        widget.style.setProperty('--oncb-input-bg', theme.inputBg);
        widget.style.setProperty('--oncb-accent', theme.accent);
        document.documentElement.style.setProperty('--oncb-active-button-bg', theme.activeButtonBg);
    }

    function updateButtonState() {
        const button = document.querySelector(`[${BUTTON_ATTR}]`);
        const open = Boolean(state.widget && state.widget.classList.contains('is-open'));
        if (!button) return;
        button.classList.toggle('is-open', open);
        button.setAttribute('aria-pressed', open ? 'true' : 'false');
    }

    function makeDraggable(widget, handle) {
        let pointerId = null;
        let originX = 0;
        let originY = 0;
        let startX = 0;
        let startY = 0;

        handle.addEventListener('pointerdown', event => {
            if (event.button !== 0) return;
            if (event.target instanceof Element && event.target.closest(DRAG_IGNORE_SELECTOR)) return;
            pointerId = event.pointerId;
            handle.setPointerCapture(pointerId);
            const rect = widget.getBoundingClientRect();
            originX = rect.left;
            originY = rect.top;
            startX = event.clientX;
            startY = event.clientY;
            handle.style.cursor = 'grabbing';
            bringToFront();
            event.preventDefault();
        });

        handle.addEventListener('pointermove', event => {
            if (event.pointerId !== pointerId) return;
            applyPosition(widget, {
                x: originX + event.clientX - startX,
                y: originY + event.clientY - startY,
            });
        });

        const release = event => {
            if (event.pointerId !== pointerId) return;
            pointerId = null;
            handle.style.cursor = 'grab';
        };

        handle.addEventListener('pointerup', release);
        handle.addEventListener('pointercancel', release);
    }

    function ensureWidget() {
        if (state.widget?.isConnected) return state.widget;

        const widget = document.createElement('section');
        widget.id = WIDGET_ID;
        widget.hidden = true;

        const header = document.createElement('div');
        header.className = 'oncb-header';

        const heading = document.createElement('div');
        heading.className = 'oncb-heading';

        const title = document.createElement('h2');
        title.className = 'oncb-title';
        title.textContent = CONFIG.title;

        const subtitle = document.createElement('p');
        subtitle.className = 'oncb-subtitle';
        subtitle.textContent = CONFIG.subtitle;
        heading.append(title, subtitle);

        const close = document.createElement('button');
        close.type = 'button';
        close.className = 'oncb-close';
        close.textContent = '×';
        close.setAttribute('aria-label', `Close ${CONFIG.title}`);
        close.addEventListener('click', closeWidget);

        header.append(heading, close);

        const body = document.createElement('div');
        body.className = 'oncb-body';
        const footer = document.createElement('div');
        footer.className = 'oncb-footer';

        widget.append(header, body, footer);
        widget.addEventListener('pointerdown', bringToFront, true);
        document.body.appendChild(widget);
        applyTheme(widget);
        makeDraggable(widget, header);
        state.widget = widget;
        return widget;
    }

    function normalizeName(value, mode) {
        const raw = String(value || '').trim();
        if (!raw) return mode === 'environment' ? 'myenvironment' : '\\mycommand';
        if (mode === 'environment') return raw.replace(/^\\+/, '');
        return raw.startsWith('\\') ? raw : `\\${raw}`;
    }

    function getDeclarationOptions(mode) {
        return mode === 'environment' ? ENVIRONMENT_DECLARATIONS : COMMAND_DECLARATIONS;
    }

    function getActionOptions(mode) {
        return mode === 'environment'
            ? [
                { value: 'new', label: 'Create a new environment', declaration: '\\NewDocumentEnvironment', help: 'Use this when the environment name is brand new. It errors if that environment already exists.' },
                { value: 'renew', label: 'Replace an existing environment', declaration: '\\RenewDocumentEnvironment', help: 'Use this when the environment already exists and you want to redefine it.' },
                { value: 'provide', label: 'Create it only if missing', declaration: '\\ProvideDocumentEnvironment', help: 'Use this when you want a fallback that will not overwrite an existing environment.' },
                { value: 'declare', label: 'Advanced declaration form', declaration: '\\DeclareDocumentEnvironment', help: 'This is the low-level xparse-style declaration form. Choose it if you specifically want the declare variant.' },
            ]
            : [
                { value: 'new', label: 'Create a new command', declaration: '\\NewDocumentCommand', help: 'Use this when the command name is brand new. It errors if that command already exists.' },
                { value: 'renew', label: 'Replace an existing command', declaration: '\\RenewDocumentCommand', help: 'Use this when the command already exists and you want to redefine it.' },
                { value: 'provide', label: 'Create it only if missing', declaration: '\\ProvideDocumentCommand', help: 'Use this when you want a fallback that will not overwrite an existing command.' },
                { value: 'declare', label: 'Advanced declaration form', declaration: '\\DeclareDocumentCommand', help: 'This is the low-level xparse-style declaration form. Choose it if you specifically want the declare variant.' },
            ];
    }

    function normalizeUiMode(value) {
        return value === 'expert' ? 'expert' : 'guided';
    }

    function normalizeAction(mode, value) {
        const options = getActionOptions(mode);
        return options.some(option => option.value === value) ? value : options[0].value;
    }

    function getActionDetails(mode, action) {
        return getActionOptions(mode).find(option => option.value === action) || getActionOptions(mode)[0];
    }

    function normalizeRequiredArgs(value) {
        const numeric = Number.parseInt(String(value ?? ''), 10);
        if (Number.isNaN(numeric)) return 1;
        return Math.min(Math.max(numeric, 0), 4);
    }

    function createUniqueId(prefix = 'id') {
        return `${prefix}-${Date.now().toString(36)}-${Math.random().toString(36).slice(2, 8)}`;
    }

    function getGuidedArgumentOptions(mode) {
        return GUIDED_ARGUMENT_TYPES.filter(option => mode === 'environment' || !option.environmentOnly);
    }

    function getGuidedArgumentMeta(kind, mode = 'command') {
        return getGuidedArgumentOptions(mode).find(option => option.value === kind) || getGuidedArgumentOptions(mode)[0];
    }

    function normalizeSingleCharacter(value, fallback) {
        const text = String(value ?? '').trim();
        return text ? text[0] : fallback;
    }

    function getSuggestedGuidedLabel(kind, mode, index = 0) {
        const meta = getGuidedArgumentMeta(kind, mode);
        if (meta.defaultLabel === 'value') return `value ${index + 1}`;
        return meta.defaultLabel;
    }

    function createGuidedArgument(kind = 'm', overrides = {}, mode = 'command', index = 0) {
        const meta = getGuidedArgumentMeta(kind, mode);
        return {
            id: String(overrides.id || createUniqueId('arg')),
            kind: meta.value,
            label: String(overrides.label || getSuggestedGuidedLabel(meta.value, mode, index)),
            defaultValue: String(overrides.defaultValue || ''),
            token: normalizeSingleCharacter(overrides.token, meta.defaultToken || '+'),
            open: normalizeSingleCharacter(overrides.open, meta.defaultOpen || '('),
            close: normalizeSingleCharacter(overrides.close, meta.defaultClose || ')'),
        };
    }

    function getLegacyGuidedArguments(source, mode) {
        const items = [];
        if (!source || typeof source !== 'object') return items;
        if (source.hasOptionalArg) {
            const defaultValue = String(source.optionalDefault || '');
            items.push(createGuidedArgument(defaultValue.trim() ? 'O' : 'o', {
                label: 'optional value',
                defaultValue,
            }, mode, items.length));
        }
        const requiredArgs = normalizeRequiredArgs(source.requiredArgs);
        for (let index = 0; index < requiredArgs; index += 1) {
            items.push(createGuidedArgument('m', { label: `value ${index + 1}` }, mode, items.length));
        }
        return items;
    }

    function normalizeGuidedArguments(rawArguments, mode, legacySource) {
        const source = Array.isArray(rawArguments) ? rawArguments : getLegacyGuidedArguments(legacySource, mode);
        const allowedKinds = new Set(getGuidedArgumentOptions(mode).map(option => option.value));
        const seenIds = new Set();
        return source.map((item, index) => {
            const kind = allowedKinds.has(item?.kind) ? item.kind : 'm';
            const normalized = createGuidedArgument(kind, item || {}, mode, index);
            if (seenIds.has(normalized.id)) normalized.id = createUniqueId('arg');
            seenIds.add(normalized.id);
            return normalized;
        });
    }

    function commentize(text, fallback) {
        const lines = String(text || '')
            .split(/\r?\n/)
            .map(line => line.trim())
            .filter(Boolean);
        const source = lines.length ? lines : [fallback];
        return source.map(line => `% ${line}`);
    }

    function commentizeBlock(text) {
        return String(text || '')
            .split(/\r?\n/)
            .filter(Boolean)
            .map(line => `% ${line}`);
    }

    function getGuidedArgumentLabel(argument, index, mode) {
        const label = String(argument?.label || '').trim();
        return label || getSuggestedGuidedLabel(argument?.kind || 'm', mode, index);
    }

    function buildGuidedArgumentSpecToken(argument) {
        const open = normalizeSingleCharacter(argument.open, '(');
        const close = normalizeSingleCharacter(argument.close, ')');
        const defaultValue = String(argument.defaultValue || '').trim();
        switch (argument.kind) {
            case 'o':
                return 'o';
            case 'O':
                return `O{${defaultValue}}`;
            case 's':
                return 's';
            case 't':
                return `t${normalizeSingleCharacter(argument.token, '+')}`;
            case 'r':
                return `r${open}${close}`;
            case 'd':
                return `d${open}${close}`;
            case 'D':
                return `D${open}${close}{${defaultValue}}`;
            case 'v':
                return 'v';
            case 'b':
                return 'b';
            case 'm':
            default:
                return 'm';
        }
    }

    function buildGuidedArgSpec(data) {
        return (data.guidedArguments || []).map(buildGuidedArgumentSpecToken).join(' ');
    }

    function buildGuidedParameterNotes(data) {
        const notes = [];
        const argumentsList = data.guidedArguments || [];
        argumentsList.forEach((argument, index) => {
            const position = index + 1;
            const label = getGuidedArgumentLabel(argument, index, data.mode);
            const defaultValue = String(argument.defaultValue || '').trim();
            const token = normalizeSingleCharacter(argument.token, '+');
            const open = normalizeSingleCharacter(argument.open, '(');
            const close = normalizeSingleCharacter(argument.close, ')');
            switch (argument.kind) {
                case 'o':
                    notes.push(`% #${position} = optional ${label}`);
                    break;
                case 'O':
                    notes.push(`% #${position} = optional ${label} (defaults to "${defaultValue}")`);
                    break;
                case 's':
                    notes.push(`% #${position} = boolean for the optional star; test with \\IfBooleanTF{#${position}}{<starred>}{<plain>}`);
                    break;
                case 't':
                    notes.push(`% #${position} = boolean for the literal token "${token}"; test with \\IfBooleanTF{#${position}}{<token present>}{<token absent>}`);
                    break;
                case 'r':
                    notes.push(`% #${position} = required ${label} read between ${open} and ${close}`);
                    break;
                case 'd':
                    notes.push(`% #${position} = optional ${label} read between ${open} and ${close}`);
                    break;
                case 'D':
                    notes.push(`% #${position} = optional ${label} read between ${open} and ${close} (defaults to "${defaultValue}")`);
                    break;
                case 'v':
                    notes.push(`% #${position} = verbatim ${label}`);
                    break;
                case 'b':
                    notes.push(`% #${position} = environment body (${label})`);
                    break;
                case 'm':
                default:
                    notes.push(`% #${position} = required ${label}`);
                    break;
            }
        });
        if (!notes.length) notes.push('% This definition takes no user inputs.');
        return notes;
    }

    function buildGuidedBooleanExamples(data) {
        const lines = [];
        (data.guidedArguments || []).forEach((argument, index) => {
            const position = index + 1;
            if (argument.kind === 's') {
                lines.push(`% Boolean example for #${position}: \\IfBooleanTF{#${position}}{% handle the starred form}{% handle the plain form}`);
            }
            if (argument.kind === 't') {
                const token = normalizeSingleCharacter(argument.token, '+');
                lines.push(`% Boolean example for #${position}: \\IfBooleanTF{#${position}}{% handle the "${token}" form}{% handle the plain form}`);
            }
        });
        return lines;
    }

    function buildGuidedUsageSegment(argument, index, mode) {
        const label = getGuidedArgumentLabel(argument, index, mode);
        const defaultValue = String(argument.defaultValue || '').trim();
        const token = normalizeSingleCharacter(argument.token, '+');
        const open = normalizeSingleCharacter(argument.open, '(');
        const close = normalizeSingleCharacter(argument.close, ')');
        switch (argument.kind) {
            case 'o':
                return `[${label}]`;
            case 'O':
                return `[${defaultValue || label}]`;
            case 's':
                return '*';
            case 't':
                return token;
            case 'r':
                return `${open}${label}${close}`;
            case 'd':
                return `${open}${label}${close}`;
            case 'D':
                return `${open}${defaultValue || label}${close}`;
            case 'v':
                return `|${label}|`;
            case 'b':
                return '';
            case 'm':
            default:
                return `{${label}}`;
        }
    }

    function buildGuidedUsageExample(data) {
        const argumentsList = data.guidedArguments || [];
        const invocation = argumentsList
            .map((argument, index) => buildGuidedUsageSegment(argument, index, data.mode))
            .filter(Boolean)
            .join('');
        if (data.mode === 'environment') {
            const envName = normalizeName(data.name, 'environment');
            const bodyArgumentIndex = argumentsList.findIndex(argument => argument.kind === 'b');
            const bodyLabel = bodyArgumentIndex >= 0
                ? getGuidedArgumentLabel(argumentsList[bodyArgumentIndex], bodyArgumentIndex, data.mode)
                : 'environment content';
            return `\\begin{${envName}}${invocation}\n    % ${bodyLabel}\n\\end{${envName}}`;
        }
        return `${normalizeName(data.name, 'command')}${invocation}`;
    }

    function buildGuidedUseCases(data) {
        const kinds = new Set((data.guidedArguments || []).map(argument => argument.kind));
        const notes = [];
        if (!kinds.size) {
            notes.push('No-argument definitions are useful for shorthands, wrappers, and reusable snippets.');
        }
        if (kinds.has('m') || kinds.has('r')) {
            notes.push('Required inputs fit titles, text, labels, lengths, and other values that should always be provided.');
        }
        if (kinds.has('o') || kinds.has('O') || kinds.has('d') || kinds.has('D')) {
            notes.push('Optional inputs keep the short call ergonomic while still allowing custom overrides when needed.');
        }
        if (kinds.has('s') || kinds.has('t')) {
            notes.push('Boolean switches are great for starred/plain, compact/full, or strict/relaxed variants inside one definition.');
        }
        if (kinds.has('v')) {
            notes.push('Verbatim inputs are handy for file paths, code fragments, URLs, and other text that should pass through untouched.');
        }
        if (kinds.has('b')) {
            notes.push('Body capture lets an environment wrap or post-process the content placed between \\begin and \\end.');
        }
        if (!notes.length) {
            notes.push('Guided mode is best when you want a starter template, usage example, and parameter notes without hand-writing xparse syntax.');
        }
        return notes;
    }

    function buildGuidedCommandBody(data) {
        return [
            ...commentize(data.commandPurpose, 'Goal: describe what the command should do.'),
            '% Example call:',
            ...commentizeBlock(buildGuidedUsageExample(data)),
            ...buildGuidedParameterNotes(data),
            ...buildGuidedBooleanExamples(data),
            '% Good fit when:',
            ...buildGuidedUseCases(data).map(line => `% - ${line}`),
            '% Replace the comment block below with the LaTeX code you want to run.',
            '% TODO: write the command body here',
        ].join('\n');
    }

    function buildGuidedEnvironmentBody(data) {
        return [
            ...commentize(data.environmentStartDescription, 'Start behavior: describe what should happen when the environment begins.'),
            '% Example call:',
            ...commentizeBlock(buildGuidedUsageExample(data)),
            ...buildGuidedParameterNotes(data),
            ...buildGuidedBooleanExamples(data),
            '% Good fit when:',
            ...buildGuidedUseCases(data).map(line => `% - ${line}`),
            '% Replace the comment block below with the LaTeX code that should run at \\begin.',
            '% TODO: write the begin code here',
        ].join('\n');
    }

    function buildGuidedEnvironmentAfter(data) {
        return [
            ...commentize(data.environmentEndDescription, 'End behavior: describe what should happen when the environment ends.'),
            '% Example call:',
            ...commentizeBlock(buildGuidedUsageExample(data)),
            ...buildGuidedParameterNotes(data),
            '% Replace the comment block below with the LaTeX code that should run at \\end.',
            '% TODO: write the end code here',
        ].join('\n');
    }

    function syncGuidedFields(data) {
        const actionDetails = getActionDetails(data.mode, data.action);
        data.declaration = actionDetails.declaration;
        data.argSpec = buildGuidedArgSpec(data);
        if (data.mode === 'environment') {
            data.environmentBody = buildGuidedEnvironmentBody(data);
            data.environmentAfter = buildGuidedEnvironmentAfter(data);
        } else {
            data.commandBody = buildGuidedCommandBody(data);
        }
    }

    function normalizeFormState(data) {
        const raw = data && typeof data === 'object' ? data : {};
        const merged = {
            ...cloneDefaultData(),
            ...raw,
        };
        merged.uiMode = normalizeUiMode(merged.uiMode);
        merged.mode = merged.mode === 'environment' ? 'environment' : 'command';
        merged.action = normalizeAction(merged.mode, merged.action);
        merged.commandPurpose = String(merged.commandPurpose || '');
        merged.environmentStartDescription = String(merged.environmentStartDescription || '');
        merged.environmentEndDescription = String(merged.environmentEndDescription || '');
        merged.declaration = String(merged.declaration || getDeclarationOptions(merged.mode)[0]);
        merged.name = String(merged.name || (merged.mode === 'environment' ? 'myenvironment' : '\\mycommand'));
        merged.argSpec = String(merged.argSpec ?? '');
        merged.guidedArguments = normalizeGuidedArguments(
            Object.prototype.hasOwnProperty.call(raw, 'guidedArguments') ? raw.guidedArguments : null,
            merged.mode,
            raw,
        );
        merged.commandBody = String(merged.commandBody || '% #1');
        merged.environmentBody = String(merged.environmentBody || '% begin code');
        merged.environmentAfter = String(merged.environmentAfter || '% end code');
        return merged;
    }

    function getSuggestedBody(mode, data) {
        if (mode === 'environment') return data.environmentBody || '% begin code';
        return data.commandBody || '% #1';
    }

    function buildSnippet(data) {
        const mode = data.mode === 'environment' ? 'environment' : 'command';
        const declaration = getDeclarationOptions(mode).includes(data.declaration)
            ? data.declaration
            : getDeclarationOptions(mode)[0];
        const name = normalizeName(data.name, mode);
        const argSpec = String(data.argSpec || '').trim();
        if (mode === 'environment') {
            const beginBody = String(data.environmentBody || '% begin code').trim() || '% begin code';
            const endBody = String(data.environmentAfter || '% end code').trim() || '% end code';
            return `${declaration}{${name}}{${argSpec}}{\n    ${beginBody.replace(/\n/g, '\n    ')}\n}{\n    ${endBody.replace(/\n/g, '\n    ')}\n}`;
        }
        const commandBody = String(data.commandBody || '% #1').trim() || '% #1';
        return `${declaration}{${name}}{${argSpec}}{\n    ${commandBody.replace(/\n/g, '\n    ')}\n}`;
    }

    function buildUsageNotes(data) {
        const mode = data.mode === 'environment' ? 'environment' : 'command';
        const normalized = normalizeName(data.name, mode);
        const bareName = mode === 'environment' ? normalized : normalized.replace(/^\\/, '');
        const spec = String(data.argSpec || '').trim();
        if (data.uiMode === 'guided') {
            const actionDetails = getActionDetails(mode, data.action);
            const notes = [
                `Project: ${getProjectName()}`,
                'Builder mode: Guided',
                `Declaration: ${actionDetails.declaration}`,
                `Why this variant: ${actionDetails.help}`,
                spec ? `Argument spec: ${spec}` : 'Argument spec: (none)',
                `Example call:\n${buildGuidedUsageExample(data)}`,
                `Parameter map:\n${buildGuidedParameterNotes(data).join('\n')}`,
                `Use cases:\n${buildGuidedUseCases(data).map(line => `- ${line}`).join('\n')}`,
                mode === 'environment'
                    ? `Starter brief:\nAt \\begin: ${String(data.environmentStartDescription || '').trim() || 'Describe the setup behavior.'}\nAt \\end: ${String(data.environmentEndDescription || '').trim() || 'Describe the teardown behavior.'}`
                    : `Starter brief:\n${String(data.commandPurpose || '').trim() || 'Describe what the command should do.'}`,
                'Guided mode already generated a starter template with comments, usage hints, and boolean notes. Replace the comments with real LaTeX when ready.',
                'Paste the generated declaration in your project preamble or in a .sty file that the project loads.',
            ];
            return notes.join('\n\n');
        }
        const notes = [
            `Project: ${getProjectName()}`,
            'Builder mode: Expert',
            mode === 'environment' ? `Environment name: ${bareName}` : `Command name: ${normalized}`,
            `Declaration: ${data.declaration}`,
            spec ? `Argument spec: ${spec}` : 'Argument spec: (none)',
            mode === 'environment'
                ? `Usage:\n\\begin{${bareName}} ... \\end{${bareName}}`
                : `Usage:\n${normalized}{...}`,
            'Need richer examples, boolean helpers, or starter comments? Switch back to Guided mode and then return to Expert mode for final manual edits.',
        ];
        return notes.join('\n\n');
    }

    function renderWidget() {
        const widget = ensureWidget();
        const body = widget.querySelector('.oncb-body');
        if (!body) return;
        body.textContent = '';
        applyTheme(widget);

        const formState = normalizeFormState(readData());

        const intro = document.createElement('p');
        intro.className = 'oncb-muted';
        intro.textContent = 'Use Guided mode for structured xparse building with live examples and boolean helpers, or switch to Expert mode for full manual control.';
        body.appendChild(intro);

        const form = document.createElement('div');
        form.className = 'oncb-form';
        body.appendChild(form);

        function createSelectField(labelText, options) {
            const field = document.createElement('label');
            field.className = 'oncb-field';
            const label = document.createElement('span');
            label.textContent = labelText;
            const select = document.createElement('select');
            select.className = 'oncb-input';
            options.forEach(([value, text]) => {
                const option = document.createElement('option');
                option.value = value;
                option.textContent = text;
                select.appendChild(option);
            });
            field.append(label, select);
            return { field, label, select };
        }

