                font-size: 0.75rem;
                line-height: 1.45;
                color: var(--overleaf-notes-checklist-muted, rgba(90,100,110,0.88));
            }
            [${WIDGET_ATTR}] .onc-close {
                flex: 0 0 auto;
                width: 28px;
                height: 28px;
                border: 0;
                border-radius: 6px;
                background: transparent;
                color: inherit;
                cursor: pointer;
                font-size: 17px;
                line-height: 1;
                display: inline-flex;
