// ==UserScript==
// @name         Overleaf Notes and Checklist
// @namespace    http://tampermonkey.net/
// @version      1.1.0
// @description  Add centered Overleaf sidebar buttons for independent floating notes and checklist widgets
// @author       You
// @match        https://*.overleaf.com/project/*
// @updateURL    https://raw.githubusercontent.com/EugenioLandi/userscripts/main/Overleaf%20Notes%20and%20Checklist
// @downloadURL  https://raw.githubusercontent.com/EugenioLandi/userscripts/main/Overleaf%20Notes%20and%20Checklist
// @grant        none
// @run-at       document-idle
// ==/UserScript==

(function () {
    'use strict';

    if (window.__overleafNotesChecklistInitialized) return;
    window.__overleafNotesChecklistInitialized = true;

    const STYLE_ID = 'overleaf-notes-checklist-style';
    const BUTTON_ATTR = 'data-overleaf-notes-checklist-button';
    const WIDGET_ATTR = 'data-overleaf-notes-checklist-widget';
    const TABS_WRAPPER_SELECTOR = '.ide-rail-tabs-wrapper';
    const FILE_TREE_TAB_SELECTOR = '[data-rr-ui-event-key="file-tree"]';
    const NATIVE_TAB_CONTENT_SELECTOR = '.ide-rail-content .ide-rail-tab-content';
    const DRAG_IGNORE_SELECTOR = 'button, input, textarea, select, a, label';
    const DOM_SYNC_DEBOUNCE_MS = 150;
    const WIDGET_PADDING = 16;
    const WIDGET_MIN_TOP = 72;
    const DEFAULT_WIDGET_WIDTH = 360;
    const DEFAULT_WIDGET_HEIGHT = 360;
    const MIN_WIDGET_WIDTH = 320;
    const MIN_WIDGET_HEIGHT = 220;

    const PANEL_DEFS = [
        {
            id: 'notes',
            title: 'Local notes',
            subtitle: 'Project notes stored only in this browser',
            icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 3h8l4 4v14H7z"/><path d="M15 3v4h4"/><path d="M10 11h6"/><path d="M10 15h6"/><path d="M10 19h4"/></svg>',
            defaultPosition: { x: 120, y: 112 },
            defaultSize: { width: 360, height: 380 },
        },
        {
            id: 'checklist',
            title: 'Checklist',
            subtitle: 'Local project tasks stored only in this browser',
            icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 11l2 2 4-4"/><path d="M9 17l2 2 4-4"/><path d="M5 6h14"/></svg>',
            defaultPosition: { x: 520, y: 112 },
            defaultSize: { width: 380, height: 420 },
        },
    ];

    const state = {
        widgets: new Map(),
        refreshTimer: null,
        observer: null,
        resizeTimer: null,
        zIndex: 100_000,
        lastHref: window.location.href,
        lastProjectId: getProjectId(),
    };

    function getProjectId() {
        const match = window.location.pathname.match(/\/project\/([^/]+)/);
        return match ? match[1] : null;
    }

    function getProjectName() {
        const selectors = [
            '.ide-redesign-toolbar-project-name',
            '[data-testid="project-name"]',
            'input[aria-label="Project name"]',
            'input[name="projectName"]',
        ];
        for (const selector of selectors) {
            const element = document.querySelector(selector);
            const value = element?.value || element?.textContent;
            if (value && value.trim()) return value.trim();
        }
        return document.title.replace(/\s*-\s*Overleaf.*$/i, '').trim() || 'Untitled project';
    }

    function getNotesStorageKey() {
        return `experimental-overleaf-sidebar-local-notepad:${getProjectId() || 'unknown-project'}`;
    }

    function getChecklistStorageKey() {
        return `experimental-overleaf-sidebar-checklist:${getProjectId() || 'unknown-project'}`;
    }

    function getPositionStorageKey(panelId) {
        return `overleaf-notes-checklist:${panelId}:position`;
    }

    function getSizeStorageKey(panelId) {
        return `overleaf-notes-checklist:${panelId}:size`;
    }

    function readJson(key, fallback) {
        try {
            const parsed = JSON.parse(localStorage.getItem(key) || 'null');
            return parsed ?? fallback;
        } catch {
            return fallback;
        }
    }

    function writeJson(key, value) {
        try {
            localStorage.setItem(key, JSON.stringify(value));
        } catch {
            // ignore quota errors
        }
    }

    async function copyText(text) {
        if (navigator.clipboard?.writeText) {
            await navigator.clipboard.writeText(text);
            return;
        }
        const textarea = document.createElement('textarea');
        textarea.value = text;
        textarea.setAttribute('readonly', 'readonly');
        textarea.style.cssText = 'position:fixed;left:-9999px;top:-9999px;';
        document.body.appendChild(textarea);
        textarea.select();
        if (typeof document.execCommand === 'function' && document.queryCommandSupported?.('copy') !== false) {
            document.execCommand('copy');
        }
        textarea.remove();
    }

    function resolveContext() {
        const tabsWrapper = document.querySelector(TABS_WRAPPER_SELECTOR);
        const fileTreeButton = tabsWrapper?.querySelector(FILE_TREE_TAB_SELECTOR) || null;
        const templateButton = fileTreeButton || tabsWrapper?.querySelector('button, [role="tab"]') || null;
        const tabContent = document.querySelector(NATIVE_TAB_CONTENT_SELECTOR);
        return { tabsWrapper, fileTreeButton, templateButton, tabContent };
    }

    function parseLuminance(colorString) {
        const match = colorString.match(/rgba?\(\s*(\d+)\s*,\s*(\d+)\s*,\s*(\d+)/);
        if (!match) return 0.5;
        const [r, g, b] = [+match[1], +match[2], +match[3]];
        return (0.299 * r + 0.587 * g + 0.114 * b) / 255;
    }

    function colorWithAlpha(colorString, alpha, fallback) {
        const match = colorString.match(/rgba?\(\s*(\d+)\s*,\s*(\d+)\s*,\s*(\d+)/);
        if (!match) return fallback;
        return `rgba(${match[1]}, ${match[2]}, ${match[3]}, ${alpha})`;
    }

    function detectTheme() {
        const nativePane = document.querySelector(`${NATIVE_TAB_CONTENT_SELECTOR} .tab-pane.active`) || document.querySelector(NATIVE_TAB_CONTENT_SELECTOR);
        const styles = nativePane ? getComputedStyle(nativePane) : null;
        const bg = styles?.backgroundColor || '';
        const fg = styles?.color || '';
        const border = styles?.borderColor || '';
        const isDark = bg && parseLuminance(bg) < 0.35;
        return {
            bg: colorWithAlpha(bg, isDark ? 0.96 : 0.97, isDark ? 'rgba(27, 39, 51, 0.96)' : 'rgba(255, 255, 255, 0.97)'),
            fg: fg || (isDark ? '#d9e0e8' : '#1b2733'),
            border: colorWithAlpha(border, isDark ? 0.3 : 0.22, isDark ? 'rgba(200,210,220,0.3)' : 'rgba(125,125,125,0.22)'),
            muted: isDark ? 'rgba(196,206,216,0.88)' : 'rgba(75,85,95,0.92)',
            buttonBg: isDark ? 'rgba(200,210,220,0.12)' : 'rgba(125,125,125,0.12)',
            hover: isDark ? 'rgba(200,210,220,0.18)' : 'rgba(125,125,125,0.16)',
            inputBg: isDark ? 'rgba(0,0,0,0.3)' : 'rgba(255,255,255,0.94)',
            focus: isDark ? '#79b8ff' : '#1a73e8',
            cardBg: isDark ? 'rgba(255,255,255,0.08)' : 'rgba(255,255,255,0.82)',
            activeButtonBg: isDark ? 'rgba(200,210,220,0.24)' : 'rgba(20, 115, 230, 0.18)',
        };
    }

    function ensureStyle() {
        if (document.getElementById(STYLE_ID)) return;
        const style = document.createElement('style');
        style.id = STYLE_ID;
        style.textContent = `
            [${BUTTON_ATTR}] {
                position: relative;
                display: inline-flex !important;
                align-items: center !important;
                justify-content: center !important;
                align-self: center !important;
                margin-inline: auto;
                padding: 0 !important;
                box-sizing: border-box;
            }
            [${BUTTON_ATTR}] .ide-rail-tab-link-icon {
                display: inline-flex;
                align-items: center;
                justify-content: center;
                width: 20px;
                height: 20px;
                pointer-events: none;
            }
            [${BUTTON_ATTR}] .ide-rail-tab-link-icon svg {
                width: 20px;
                height: 20px;
                display: block;
                flex: 0 0 auto;
            }
            [${BUTTON_ATTR}].is-open {
                background: var(--overleaf-notes-checklist-active-button-bg, rgba(20, 115, 230, 0.12)) !important;
                box-shadow: none !important;
            }
            [${WIDGET_ATTR}] {
                position: fixed;
                z-index: 100000;
                display: none;
                flex-direction: column;
                width: ${DEFAULT_WIDGET_WIDTH}px;
                height: ${DEFAULT_WIDGET_HEIGHT}px;
                min-width: ${MIN_WIDGET_WIDTH}px;
                min-height: ${MIN_WIDGET_HEIGHT}px;
                max-width: calc(100vw - ${WIDGET_PADDING * 2}px);
                max-height: calc(100vh - ${WIDGET_MIN_TOP + WIDGET_PADDING}px);
                overflow: hidden;
                resize: both;
                border: 1px solid var(--overleaf-notes-checklist-border, rgba(125,125,125,0.18));
                border-radius: 14px;
                background: var(--overleaf-notes-checklist-bg, rgba(255, 255, 255, 0.97));
                color: var(--overleaf-notes-checklist-fg, #1b2733);
                box-shadow: 0 22px 48px rgba(15, 23, 42, 0.22);
            }
            [${WIDGET_ATTR}].is-open {
                display: flex;
            }
            [${WIDGET_ATTR}] .onc-header {
                display: flex;
                align-items: flex-start;
                justify-content: space-between;
                gap: 10px;
                padding: 14px 16px;
                border-bottom: 1px solid var(--overleaf-notes-checklist-border, rgba(125,125,125,0.18));
                cursor: grab;
                user-select: none;
                touch-action: none;
            }
            [${WIDGET_ATTR}] .onc-heading {
                min-width: 0;
