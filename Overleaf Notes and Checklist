            }
            [${WIDGET_ATTR}] .onc-body {
                flex: 1 1 auto;
                min-height: 0;
                overflow: auto;
                padding: 14px 16px;
                display: flex;
                flex-direction: column;
                gap: 10px;
                box-sizing: border-box;
            }
            [${WIDGET_ATTR}] .onc-footer {
                padding: 10px 16px 14px;
                border-top: 1px solid var(--overleaf-notes-checklist-border, rgba(125,125,125,0.18));
                font-size: 0.6875rem;
                line-height: 1.45;
                color: var(--overleaf-notes-checklist-muted, rgba(90,100,110,0.88));
                min-height: 14px;
            }
            [${WIDGET_ATTR}] .onc-muted {
                margin: 0;
                font-size: 0.8125rem;
                line-height: 1.5;
                color: var(--overleaf-notes-checklist-muted, rgba(90,100,110,0.88));
            }
            [${WIDGET_ATTR}] .onc-actions,
            [${WIDGET_ATTR}] .onc-form {
                display: flex;
                flex-wrap: wrap;
                gap: 8px;
            }
            [${WIDGET_ATTR}] .onc-form {
                flex-wrap: nowrap;
            }
            [${WIDGET_ATTR}] .onc-input,
            [${WIDGET_ATTR}] .onc-textarea {
                width: 100%;
                box-sizing: border-box;
                border: 1px solid var(--overleaf-notes-checklist-border, rgba(125,125,125,0.22));
                border-radius: 6px;
                padding: 8px 10px;
                background: var(--overleaf-notes-checklist-input-bg, rgba(255,255,255,0.88));
                color: inherit;
                font: inherit;
                font-size: 0.8125rem;
            }
            [${WIDGET_ATTR}] .onc-textarea {
                min-height: 220px;
                resize: vertical;
                font-family: ui-monospace, SFMono-Regular, Consolas, monospace;
                font-size: 0.75rem;
                line-height: 1.55;
            }
            [${WIDGET_ATTR}] .onc-button {
                border: 1px solid var(--overleaf-notes-checklist-border, rgba(125,125,125,0.22));
                border-radius: 6px;
                padding: 6px 10px;
                background: var(--overleaf-notes-checklist-button-bg, rgba(125,125,125,0.06));
                color: inherit;
                cursor: pointer;
                display: inline-flex;
                align-items: center;
                justify-content: center;
                gap: 5px;
                font-size: 0.75rem;
                font-weight: 600;
                line-height: 1.3;
            }
            [${WIDGET_ATTR}] .onc-button:hover {
                background: var(--overleaf-notes-checklist-hover, rgba(125,125,125,0.1));
            }
            [${WIDGET_ATTR}] .onc-list {
                list-style: none;
                padding: 0;
                margin: 0;
                display: flex;
                flex-direction: column;
                gap: 8px;
            }
            [${WIDGET_ATTR}] .onc-card {
                display: flex;
                align-items: flex-start;
                gap: 10px;
                border: 1px solid var(--overleaf-notes-checklist-border, rgba(125,125,125,0.18));
                border-radius: 6px;
                padding: 10px 12px;
                background: var(--overleaf-notes-checklist-card-bg, rgba(255,255,255,0.5));
                box-sizing: border-box;
            }
        `;
        document.head.appendChild(style);
    }

    function replaceButtonIcon(button, iconMarkup) {
        const wrapper = document.createElement('span');
        wrapper.innerHTML = iconMarkup.trim();
        const icon = wrapper.firstElementChild;
        if (!icon) return;
        const iconSlot = document.createElement('span');
        iconSlot.className = 'ide-rail-tab-link-icon';
        iconSlot.setAttribute('aria-hidden', 'true');
        iconSlot.appendChild(icon);
        button.replaceChildren(iconSlot);
    }

    function createSidebarButton(panel, templateButton) {
        const button = document.createElement('button');
        const classList = templateButton
            ? [...templateButton.classList].filter(cls => !['d-flex', 'flex-column', 'align-items-center', 'justify-content-center', 'text-center', 'p-0', 'px-0', 'py-0'].includes(cls))
            : ['nav-link'];
        button.className = classList.join(' ');
        button.type = 'button';
        button.setAttribute(BUTTON_ATTR, panel.id);
        button.dataset.panelId = panel.id;
        button.setAttribute('aria-label', panel.title);
        button.setAttribute('title', panel.title);
        replaceButtonIcon(button, panel.icon);
        button.addEventListener('click', event => {
            event.preventDefault();
            event.stopPropagation();
            toggleWidget(panel.id);
        }, true);
        return button;
    }

    function bringToFront(widget) {
        state.zIndex += 1;
        widget.style.zIndex = String(state.zIndex);
    }

    function clampPosition(widget, position) {
        const width = widget.offsetWidth || DEFAULT_WIDGET_WIDTH;
        const height = widget.offsetHeight || DEFAULT_WIDGET_HEIGHT;
        return {
            x: Math.min(Math.max(WIDGET_PADDING, Math.round(position.x)), Math.max(WIDGET_PADDING, window.innerWidth - width - WIDGET_PADDING)),
            y: Math.min(Math.max(WIDGET_MIN_TOP, Math.round(position.y)), Math.max(WIDGET_MIN_TOP, window.innerHeight - height - WIDGET_PADDING)),
        };
    }

    function applyPosition(widget, panelId, position, persist = true) {
        const next = clampPosition(widget, position);
        widget.style.left = `${next.x}px`;
        widget.style.top = `${next.y}px`;
        if (persist) writeJson(getPositionStorageKey(panelId), next);
    }

    function clampSize(size) {
        return {
            width: Math.min(Math.max(MIN_WIDGET_WIDTH, Math.round(size.width || DEFAULT_WIDGET_WIDTH)), Math.max(MIN_WIDGET_WIDTH, window.innerWidth - WIDGET_PADDING * 2)),
            height: Math.min(Math.max(MIN_WIDGET_HEIGHT, Math.round(size.height || DEFAULT_WIDGET_HEIGHT)), Math.max(MIN_WIDGET_HEIGHT, window.innerHeight - WIDGET_MIN_TOP - WIDGET_PADDING)),
        };
    }

    function applySize(widget, panelId, size, persist = true) {
        const next = clampSize(size);
        widget.style.width = `${next.width}px`;
        widget.style.height = `${next.height}px`;
        if (persist) writeJson(getSizeStorageKey(panelId), next);
    }

    function restoreSize(widget, panel) {
        const saved = readJson(getSizeStorageKey(panel.id), null) || panel.defaultSize || { width: DEFAULT_WIDGET_WIDTH, height: DEFAULT_WIDGET_HEIGHT };
        applySize(widget, panel.id, saved, false);
    }

    function captureWidgetGeometry(panel) {
        const widget = state.widgets.get(panel.id);
        if (!widget || !widget.classList.contains('is-open')) return;
        const rect = widget.getBoundingClientRect();
        applySize(widget, panel.id, { width: rect.width, height: rect.height });
        applyPosition(widget, panel.id, { x: rect.left, y: rect.top });
    }

    function restorePosition(widget, panel) {
        const saved = readJson(getPositionStorageKey(panel.id), null) || panel.defaultPosition;
        applyPosition(widget, panel.id, saved, false);
    }

    function setWidgetFooter(widget, text) {
        const footer = widget.querySelector('.onc-footer');
        if (footer) footer.textContent = String(text || '');
    }

    function applyTheme(widget) {
        const theme = detectTheme();
        widget.style.setProperty('--overleaf-notes-checklist-bg', theme.bg);
        widget.style.setProperty('--overleaf-notes-checklist-fg', theme.fg);
        widget.style.setProperty('--overleaf-notes-checklist-border', theme.border);
        widget.style.setProperty('--overleaf-notes-checklist-muted', theme.muted);
        widget.style.setProperty('--overleaf-notes-checklist-button-bg', theme.buttonBg);
        widget.style.setProperty('--overleaf-notes-checklist-hover', theme.hover);
        widget.style.setProperty('--overleaf-notes-checklist-input-bg', theme.inputBg);
        widget.style.setProperty('--overleaf-notes-checklist-focus', theme.focus);
        widget.style.setProperty('--overleaf-notes-checklist-card-bg', theme.cardBg);
        widget.style.setProperty('--overleaf-notes-checklist-active-button-bg', theme.activeButtonBg);
    }

    function makeDraggable(widget, handle, panel) {
        let pointerId = null;
        let originX = 0;
        let originY = 0;
        let startX = 0;
        let startY = 0;

        handle.addEventListener('pointerdown', event => {
            if (event.button !== 0) return;
            if (event.target instanceof Element && event.target.closest(DRAG_IGNORE_SELECTOR)) return;
            pointerId = event.pointerId;
            handle.setPointerCapture(pointerId);
            const rect = widget.getBoundingClientRect();
            originX = rect.left;
            originY = rect.top;
            startX = event.clientX;
            startY = event.clientY;
            handle.style.cursor = 'grabbing';
            bringToFront(widget);
            event.preventDefault();
        });

        handle.addEventListener('pointermove', event => {
            if (event.pointerId !== pointerId) return;
            applyPosition(widget, panel.id, {
                x: originX + event.clientX - startX,
                y: originY + event.clientY - startY,
            });
        });

        const release = event => {
            if (event.pointerId !== pointerId) return;
            pointerId = null;
            handle.style.cursor = 'grab';
        };

        handle.addEventListener('pointerup', release);
        handle.addEventListener('pointercancel', release);
    }

    function ensureWidget(panel) {
        const existing = state.widgets.get(panel.id);
        if (existing?.isConnected) return existing;

        const widget = document.createElement('section');
        widget.setAttribute(WIDGET_ATTR, panel.id);
        widget.dataset.panelId = panel.id;
        widget.hidden = true;

        const header = document.createElement('div');
        header.className = 'onc-header';

        const heading = document.createElement('div');
        heading.className = 'onc-heading';

        const title = document.createElement('h2');
        title.className = 'onc-title';
        title.textContent = panel.title;

        const subtitle = document.createElement('p');
        subtitle.className = 'onc-subtitle';
        subtitle.textContent = panel.subtitle;

        const close = document.createElement('button');
        close.type = 'button';
        close.className = 'onc-close';
        close.textContent = '×';
        close.setAttribute('aria-label', `Close ${panel.title}`);
        close.addEventListener('click', () => closeWidget(panel.id));

        heading.append(title, subtitle);
        header.append(heading, close);

        const body = document.createElement('div');
        body.className = 'onc-body';
        const footer = document.createElement('div');
        footer.className = 'onc-footer';

        widget.append(header, body, footer);
        widget.addEventListener('pointerdown', () => bringToFront(widget), true);
        document.body.appendChild(widget);
        applyTheme(widget);
        makeDraggable(widget, header, panel);
        state.widgets.set(panel.id, widget);
        return widget;
    }

    function renderNotesWidget(widget) {
        const body = widget.querySelector('.onc-body');
        if (!body) return;
        body.textContent = '';

        const intro = document.createElement('p');
        intro.className = 'onc-muted';
        intro.textContent = 'Keep reviewer feedback, TODOs, or reminders without touching the manuscript.';

        const actions = document.createElement('div');
        actions.className = 'onc-actions';

        const copyButton = document.createElement('button');
        copyButton.type = 'button';
        copyButton.className = 'onc-button';
        copyButton.textContent = 'Copy';

        const clearButton = document.createElement('button');
        clearButton.type = 'button';
        clearButton.className = 'onc-button';
        clearButton.textContent = 'Clear';

        actions.append(copyButton, clearButton);

        const textarea = document.createElement('textarea');
        textarea.className = 'onc-textarea';
        textarea.placeholder = 'Write project-specific notes here…';
        textarea.value = localStorage.getItem(getNotesStorageKey()) || '';

        let saveTimer = null;
        textarea.addEventListener('input', () => {
            clearTimeout(saveTimer);
            setWidgetFooter(widget, 'Saving locally…');
            saveTimer = window.setTimeout(() => {
                localStorage.setItem(getNotesStorageKey(), textarea.value);
                setWidgetFooter(widget, `Saved for ${getProjectName()}`);
            }, 150);
        });

        copyButton.addEventListener('click', async () => {
            await copyText(textarea.value);
            setWidgetFooter(widget, 'Notes copied to clipboard');
        });

        clearButton.addEventListener('click', () => {
            textarea.value = '';
            localStorage.removeItem(getNotesStorageKey());
            setWidgetFooter(widget, 'Notes cleared');
        });

        body.append(intro, actions, textarea);
        setWidgetFooter(widget, `Autosaves locally for ${getProjectName()}`);
    }

    function readChecklistItems() {
        return readJson(getChecklistStorageKey(), []);
    }

    function writeChecklistItems(items) {
        writeJson(getChecklistStorageKey(), items);
    }

    function createChecklistId() {
        return `${Date.now().toString(36)}-${Math.random().toString(36).slice(2, 7)}`;
    }

    function renderChecklistWidget(widget) {
        const body = widget.querySelector('.onc-body');
        if (!body) return;
        body.textContent = '';

        const items = readChecklistItems();

        const form = document.createElement('form');
        form.className = 'onc-form';

        const input = document.createElement('input');
        input.className = 'onc-input';
        input.placeholder = 'Add a task…';

        const addButton = document.createElement('button');
        addButton.type = 'submit';
        addButton.className = 'onc-button';
        addButton.textContent = 'Add';

        form.append(input, addButton);
        body.appendChild(form);

        const actions = document.createElement('div');
        actions.className = 'onc-actions';
        actions.style.justifyContent = 'flex-end';

        const clearDoneButton = document.createElement('button');
        clearDoneButton.type = 'button';
        clearDoneButton.className = 'onc-button';
        clearDoneButton.textContent = 'Clear done';
        clearDoneButton.addEventListener('click', () => {
            writeChecklistItems(items.filter(item => !item.done));
            renderChecklistWidget(widget);
        });

        actions.appendChild(clearDoneButton);
        body.appendChild(actions);

        form.addEventListener('submit', event => {
            event.preventDefault();
            const text = input.value.trim();
            if (!text) return;
            writeChecklistItems([{ id: createChecklistId(), text, done: false }, ...items]);
            renderChecklistWidget(widget);
        });

        if (!items.length) {
            const empty = document.createElement('p');
            empty.className = 'onc-muted';
            empty.textContent = 'Track figures, references, experiments, or submission checks here.';
            body.appendChild(empty);
            setWidgetFooter(widget, '0 tasks stored locally');
            return;
        }

        const list = document.createElement('ul');
        list.className = 'onc-list';

        items.forEach(item => {
            const row = document.createElement('li');
            row.className = 'onc-card';

            const checkbox = document.createElement('input');
            checkbox.type = 'checkbox';
            checkbox.checked = Boolean(item.done);
            checkbox.addEventListener('change', () => {
                writeChecklistItems(items.map(entry => entry.id === item.id ? { ...entry, done: checkbox.checked } : entry));
                renderChecklistWidget(widget);
            });

            const text = document.createElement('div');
            text.style.cssText = `flex:1 1 auto;font-size:0.8125rem;line-height:1.5;text-decoration:${item.done ? 'line-through' : 'none'};opacity:${item.done ? '0.72' : '1'};`;
            text.textContent = item.text;

            const removeButton = document.createElement('button');
            removeButton.type = 'button';
            removeButton.className = 'onc-button';
            removeButton.textContent = 'Remove';
            removeButton.addEventListener('click', () => {
                writeChecklistItems(items.filter(entry => entry.id !== item.id));
                renderChecklistWidget(widget);
            });

            row.append(checkbox, text, removeButton);
            list.appendChild(row);
        });

        body.appendChild(list);
        setWidgetFooter(widget, `${items.filter(item => item.done).length}/${items.length} tasks completed`);
    }

    function renderWidget(panelId) {
        const panel = PANEL_DEFS.find(entry => entry.id === panelId);
        if (!panel) return;
        const widget = ensureWidget(panel);
        applyTheme(widget);
        if (panel.id === 'notes') {
            renderNotesWidget(widget);
        } else {
            renderChecklistWidget(widget);
        }
    }

    function isWidgetOpen(panelId) {
        const widget = state.widgets.get(panelId);
        return Boolean(widget && widget.classList.contains('is-open'));
    }

    function updateButtonState(panelId) {
        const button = document.querySelector(`[${BUTTON_ATTR}="${panelId}"]`);
        if (!button) return;
        button.classList.toggle('is-open', isWidgetOpen(panelId));
        button.setAttribute('aria-pressed', isWidgetOpen(panelId) ? 'true' : 'false');
    }

    function openWidget(panelId) {
        const panel = PANEL_DEFS.find(entry => entry.id === panelId);
        if (!panel) return;
        const widget = ensureWidget(panel);
        renderWidget(panelId);
        widget.hidden = false;
        widget.classList.add('is-open');
        restoreSize(widget, panel);
        restorePosition(widget, panel);
        bringToFront(widget);
        updateButtonState(panelId);
    }

    function closeWidget(panelId) {
        const widget = state.widgets.get(panelId);
        if (!widget) return;
        widget.classList.remove('is-open');
        widget.hidden = true;
        updateButtonState(panelId);
    }

    function toggleWidget(panelId) {
        if (isWidgetOpen(panelId)) {
            closeWidget(panelId);
        } else {
            openWidget(panelId);
        }
    }

    function syncButtons() {
        const context = resolveContext();
        if (!context.tabsWrapper || !context.templateButton) return;

        const theme = detectTheme();
        document.documentElement.style.setProperty('--overleaf-notes-checklist-active-button-bg', theme.activeButtonBg);

        PANEL_DEFS.forEach(panel => {
            let button = context.tabsWrapper.querySelector(`[${BUTTON_ATTR}="${panel.id}"]`);
            if (!button) {
                button = createSidebarButton(panel, context.templateButton);
                context.tabsWrapper.appendChild(button);
            }
            updateButtonState(panel.id);
        });
    }

    function refreshOpenWidgets(forceRender = false) {
        PANEL_DEFS.forEach(panel => {
            const widget = state.widgets.get(panel.id);
            if (!widget) return;
            applyTheme(widget);
            if (widget.classList.contains('is-open') && forceRender) {
                renderWidget(panel.id);
                restoreSize(widget, panel);
                restorePosition(widget, panel);
            }
        });
    }

    function scheduleSync(delay = 0, forceRender = false) {
        window.clearTimeout(state.refreshTimer);
        state.refreshTimer = window.setTimeout(() => {
            syncButtons();
            const currentProjectId = getProjectId();
            const shouldRender = forceRender || currentProjectId !== state.lastProjectId;
            state.lastProjectId = currentProjectId;
            refreshOpenWidgets(shouldRender);
        }, delay);
    }

    function watchDom() {
        if (state.observer) return;
        state.observer = new MutationObserver(() => {
            if (state.lastHref !== window.location.href) {
                state.lastHref = window.location.href;
            }
            scheduleSync(DOM_SYNC_DEBOUNCE_MS);
        });
        state.observer.observe(document.documentElement, { childList: true, subtree: true });
        window.addEventListener('popstate', () => scheduleSync(0));
        window.addEventListener('hashchange', () => scheduleSync(0));
        window.addEventListener('focus', () => scheduleSync(0));
        window.addEventListener('mouseup', () => PANEL_DEFS.forEach(captureWidgetGeometry), true);
        window.addEventListener('pointerup', () => PANEL_DEFS.forEach(captureWidgetGeometry), true);
        window.addEventListener('resize', () => {
            window.clearTimeout(state.resizeTimer);
            state.resizeTimer = window.setTimeout(() => {
                PANEL_DEFS.forEach(panel => {
                    const widget = state.widgets.get(panel.id);
                    if (widget && widget.classList.contains('is-open')) {
                        captureWidgetGeometry(panel);
                    }
                });
            }, DOM_SYNC_DEBOUNCE_MS);
        });
    }

    function boot() {
        if (!document.body) {
            window.setTimeout(boot, 100);
            return;
        }
        ensureStyle();
        watchDom();
        scheduleSync(0);
    }

    boot();
})();
