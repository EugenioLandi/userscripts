// ==UserScript==
// @name         Force font Domani
// @namespace    http://tampermonkey.net/
// @version      1.0
// @description  Force a consistent Barlow-based reading font on Domani with a persistent on/off toggle
// @author       You
// @match        *://www.editorialedomani.it/*
// @icon         https://e7.pngegg.com/pngimages/656/766/png-clipart-computer-terminal-computer-icons-bash-others-miscellaneous-angle.png
// @grant        none
// @run-at       document-idle
// ==/UserScript==

(function () {
    'use strict';

    if (window.__domaniFontForceInitialized) return;
    window.__domaniFontForceInitialized = true;

    const STORAGE_KEY = 'domani_force_font_enabled';
    const STYLE_ID = 'domani-force-font-style';
    const TOGGLE_ID = 'domani-force-font-toggle';

    function injectStyle() {
        let style = document.getElementById(STYLE_ID);
        if (style) return style;

        style = document.createElement('style');
        style.id = STYLE_ID;
        style.textContent = `
            html.${STYLE_ID}-enabled,
            html.${STYLE_ID}-enabled body,
            html.${STYLE_ID}-enabled body *:not(.material-symbols):not(.fa):not([class*="icon"]):not(svg):not(path) {
                font-family: "Barlow", system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif !important;
            }
        `;
        document.head.appendChild(style);
        return style;
    }

    function getEnabled() {
        return localStorage.getItem(STORAGE_KEY) !== '0';
    }

    function setEnabled(enabled) {
        localStorage.setItem(STORAGE_KEY, enabled ? '1' : '0');
        document.documentElement.classList.toggle(`${STYLE_ID}-enabled`, enabled);
        updateToggle(enabled);
    }

    function updateToggle(enabled) {
        const button = document.getElementById(TOGGLE_ID);
        if (!button) return;
        button.textContent = enabled ? 'Barlow: on' : 'Barlow: off';
        button.style.background = enabled ? '#111827' : '#4b5563';
        button.style.borderColor = enabled ? '#111827' : '#6b7280';
        button.title = enabled ? 'Disable custom font' : 'Enable custom font';
    }

    function ensureToggle() {
        if (!document.body) return;
        let button = document.getElementById(TOGGLE_ID);
        if (button) return;

        button = document.createElement('button');
        button.id = TOGGLE_ID;
        button.type = 'button';
        button.style.cssText = [
            'position:fixed',
            'left:16px',
            'bottom:16px',
            'z-index:2147483647',
            'padding:8px 12px',
            'border:1px solid #111827',
            'border-radius:999px',
            'color:#fff',
            'font:600 12px/1 system-ui,sans-serif',
            'cursor:pointer',
            'box-shadow:0 8px 18px rgba(0,0,0,.25)',
        ].join(';');
        button.addEventListener('click', () => setEnabled(!getEnabled()));
        document.body.appendChild(button);
        updateToggle(getEnabled());
    }

    function init() {
        if (!document.head || !document.body) {
            window.setTimeout(init, 100);
            return;
        }

        injectStyle();
        setEnabled(getEnabled());
        ensureToggle();

        const observer = new MutationObserver(() => ensureToggle());
        observer.observe(document.documentElement, { childList: true, subtree: true });
    }

    init();
})();
