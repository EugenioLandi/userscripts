// ==UserScript==
// @name         GitHub Copilot Model Multipliers
// @namespace    http://tampermonkey.net/
// @version      5.3
// @description  Display premium request multipliers next to Copilot models with improved parsing, caching, and selection badges
// @author       You
// @match        https://github.com/copilot*
// @match        https://github.com/features/copilot*
// @match        https://github.com/settings/copilot*
// @updateURL    https://raw.githubusercontent.com/EugenioLandi/userscripts/main/github%20copilot%20model%20multiplier
// @downloadURL  https://raw.githubusercontent.com/EugenioLandi/userscripts/main/github%20copilot%20model%20multiplier
// @run-at       document-idle
// @grant        GM_xmlhttpRequest
// @connect      docs.github.com
// ==/UserScript==

(function () {
    'use strict';

    if (window.__copilotModelMultipliersInitialized) return;
    window.__copilotModelMultipliersInitialized = true;

    const DOCS_URL = 'https://docs.github.com/en/copilot/concepts/billing/copilot-requests';
    const DOCS_TABLE_URL = `${DOCS_URL}#model-multipliers`;
    const CACHE_KEY = 'copilot_model_multipliers_v5';
    const CACHE_TTL = 24 * 60 * 60 * 1000;
    const MAX_DECORATABLE_TEXT_LENGTH = 200;
    // Refresh live data sooner than full expiry so the UI can serve cached values while updating in the background.
    const CACHE_REFRESH_AFTER = 6 * 60 * 60 * 1000;

    const FALLBACK_MULTIPLIERS = {
        'claude haiku 4.5': 0.33,
        'claude opus 4.5': 3,
        'claude opus 4.6': 3,
        'claude opus 4.6 (fast mode)': 30,
        'claude sonnet 4': 1,
        'claude sonnet 4.5': 1,
        'claude sonnet 4.6': 1,
        'gemini 2.5 pro': 1,
        'gemini 3 flash': 0.33,
        'gemini 3 pro': 1,
        'gemini 3.1 pro': 1,
        'gpt-4.1': 0,
        'gpt-4o': 0,
        'gpt-5 mini': 0,
        'gpt-5.1': 1,
        'gpt-5.1-codex': 1,
        'gpt-5.1-codex-mini': 0.33,
        'gpt-5.1-codex-max': 1,
        'gpt-5.2': 1,
        'gpt-5.2-codex': 1,
        'gpt-5.3-codex': 1,
        'gpt-5.4': 1,
        'grok code fast 1': 0.25,
        'raptor mini': 0,
    };

    let modelMultipliers = { ...FALLBACK_MULTIPLIERS };
    let metadata = { source: 'fallback', timestamp: Date.now() };

    function normalize(name) {
        return String(name || '')
            .toLowerCase()
            .replace(/\s*\(preview\)\s*/gi, '')
            .replace(/\s+/g, ' ')
            .trim();
    }

    function formatMultiplier(multiplier) {
        return typeof multiplier === 'number' && !Number.isNaN(multiplier) ? `(${multiplier}×)` : '';
    }

    function formatTimestamp(timestamp) {
        return new Date(timestamp ?? metadata.timestamp).toLocaleString();
    }

    function isVisible(element) {
        return Boolean(element && element.isConnected && (element.offsetParent || element.getClientRects().length));
    }

    function cleanCandidateText(text) {
        return String(text || '')
            .replace(/\s*\(.+?×\)\s*/g, ' ')
            .replace(/\b(selected|default|preview|included|premium|requests?)\b/gi, ' ')
            .replace(/\s+/g, ' ')
            .trim();
    }

    function looksLikeModelText(text) {
        const name = normalize(text);
        if (!name) return false;
        if (Object.keys(modelMultipliers).some(key => name.includes(key) || key.includes(name))) return true;
        return /\b(claude|gemini|gpt|grok|raptor|sonnet|opus|haiku|codex|o1|o3|o4)\b/.test(name);
    }

    function loadCache() {
        try {
            const raw = localStorage.getItem(CACHE_KEY);
            if (!raw) return null;
            const parsed = JSON.parse(raw);
            if (!parsed?.data || !Object.keys(parsed.data).length) return null;
            if (Date.now() - parsed.timestamp > CACHE_TTL) return null;
            return parsed;
        } catch {
            return null;
        }
    }

    function saveCache(data, source = 'live') {
        const payload = { timestamp: Date.now(), data, source };
        metadata = { source, timestamp: payload.timestamp };
        localStorage.setItem(CACHE_KEY, JSON.stringify(payload));
    }

    function fetchHtml(url) {
        if (typeof GM_xmlhttpRequest === 'function') {
            return new Promise((resolve, reject) => {
                GM_xmlhttpRequest({
                    method: 'GET',
                    url,
                    headers: { Accept: 'text/html' },
                    onload: response => {
                        if (response.status >= 200 && response.status < 300) {
                            resolve(response.responseText);
                        } else {
                            reject(new Error(`HTTP ${response.status}`));
                        }
                    },
                    onerror: error => reject(error),
                    ontimeout: () => reject(new Error('timeout')),
                });
            });
        }

        return fetch(url).then(response => {
            if (!response.ok) throw new Error(`HTTP ${response.status}`);
            return response.text();
        });
    }

    function findTableByHeaders(doc) {
        const tables = [...doc.querySelectorAll('table')];
        return tables.find(table => {
            const headerTexts = [...table.querySelectorAll('tr:first-child th, thead th')]
                .map(cell => normalize(cell.textContent));
            return headerTexts.some(text => text.includes('model')) && headerTexts.some(text => text.includes('multiplier'));
        }) || null;
    }

    function parseMultiplierValue(text) {
        const cleaned = String(text || '').trim();
        if (/not applicable|n\/a/i.test(cleaned)) return null;
        const match = cleaned.match(/\d+(?:\.\d+)?/);
        if (!match) return null;
        const value = Number(match[0]);
        return Number.isFinite(value) ? value : null;
    }

    function parseMultipliersFromHtml(html) {
        const doc = new DOMParser().parseFromString(html, 'text/html');
        const table = findTableByHeaders(doc);
        if (!table) throw new Error('Model multiplier table not found');

        const result = {};
        for (const row of table.querySelectorAll('tr')) {
            const cells = [...row.querySelectorAll('th, td')];
            if (cells.length < 2) continue;

            const rawName = cells[0].textContent || '';
            const rawMultiplier = cells[1].textContent || '';
            if (/model/i.test(rawName) && /multiplier/i.test(rawMultiplier)) continue;

            const name = normalize(rawName);
            const value = parseMultiplierValue(rawMultiplier);
            if (name && value !== null) result[name] = value;
        }

        if (!Object.keys(result).length) throw new Error('Parsed multiplier table was empty');
        return result;
    }

    async function loadMultipliers(forceRefresh = false) {
        const cached = !forceRefresh && loadCache();
        if (cached) {
            modelMultipliers = cached.data;
            metadata = { source: cached.source || 'cache', timestamp: cached.timestamp };
            if (Date.now() - cached.timestamp < CACHE_REFRESH_AFTER) return;
        }

        try {
            const parsed = parseMultipliersFromHtml(await fetchHtml(DOCS_URL));
            modelMultipliers = parsed;
            saveCache(parsed, 'live');
        } catch (error) {
            console.warn('[Copilot Multipliers] Live fetch failed, using fallback:', error);
            modelMultipliers = cached?.data || { ...FALLBACK_MULTIPLIERS };
            metadata = { source: cached ? 'cache' : 'fallback', timestamp: cached?.timestamp || Date.now() };
        }
    }

    function getMultiplier(rawName) {
        const name = normalize(rawName);
        if (!name) return null;

        if (Object.prototype.hasOwnProperty.call(modelMultipliers, name)) {
            return modelMultipliers[name];
        }

        let best = null;
        let bestLength = 0;
        for (const key of Object.keys(modelMultipliers)) {
            if ((name.includes(key) || key.includes(name)) && key.length > bestLength) {
                best = modelMultipliers[key];
                bestLength = key.length;
            }
        }
        return best;
    }

    function extractModelName(element) {
        const texts = [
            element.getAttribute('aria-label'),
            element.getAttribute('title'),
            element.textContent,
            ...[...element.querySelectorAll('span, div, strong')].map(node => node.textContent),
        ]
            .map(cleanCandidateText)
            .filter(text => text && !/^\(.+×\)$/.test(text) && !/^models?$/i.test(text));

        const ranked = texts.sort((a, b) => b.length - a.length);
        return ranked.find(text => getMultiplier(text) !== null) || ranked.find(looksLikeModelText) || '';
    }

    function badgeTitle() {
        return `Multiplier source: ${metadata.source}. Last update: ${formatTimestamp()}.`;
    }

    function modelsLabelTitle() {
        return `Model multipliers last updated by the script: ${formatTimestamp()}. Source: ${metadata.source}.`;
    }

    function ensureBadge(element, attributeName) {
        let badge = element.querySelector(`span[${attributeName}]`);
        if (!badge) {
            badge = document.createElement('span');
            badge.setAttribute(attributeName, 'true');
            badge.style.cssText = 'margin-left:8px;color:#6e7781;font-size:.9em;font-weight:normal;white-space:nowrap;';
            element.appendChild(badge);
        }
        badge.title = badgeTitle();
        return badge;
    }

    function isInteractiveElement(element) {
        return Boolean(element && (
            /^(A|BUTTON|SUMMARY)$/.test(element.tagName) ||
            ['button', 'link', 'menuitem', 'option', 'tab'].includes(element.getAttribute('role'))
        ));
    }

    function ensureModelsDocsLink(element) {
        if (!element || !element.parentElement) return;
        element.title = modelsLabelTitle();

        if (element.tagName === 'A') {
            element.href = DOCS_TABLE_URL;
            element.target = '_blank';
            element.rel = 'noopener noreferrer';
            return;
        }

        let link = element.parentElement.querySelector('a[data-cm-docs-link]');
        if (!link) {
            link = document.createElement('a');
            link.dataset.cmDocsLink = 'true';
            link.href = DOCS_TABLE_URL;
            link.target = '_blank';
            link.rel = 'noopener noreferrer';
            link.textContent = 'table';
            link.style.cssText = 'margin-left:6px;color:#0969da;font-size:.9em;font-weight:500;text-decoration:none;white-space:nowrap;';
            link.title = 'Open the GitHub Copilot model multipliers table';
            if (isInteractiveElement(element)) {
                element.insertAdjacentElement('afterend', link);
            } else {
                element.appendChild(document.createTextNode(' '));
                element.appendChild(link);
            }
        }
    }

    function collectDecoratableElements(selectors) {
        const seen = new Set();
        const result = [];
        for (const selector of selectors) {
            for (const element of document.querySelectorAll(selector)) {
                if (seen.has(element) || !isVisible(element)) continue;
                if (element.closest('[data-cm-docs-link]')) continue;
                if ((element.textContent || '').trim().length > MAX_DECORATABLE_TEXT_LENGTH && !isInteractiveElement(element)) continue;
                seen.add(element);
                result.push(element);
            }
        }
        return result;
    }

    function decorateElements(selectors, attributeName) {
        for (const element of collectDecoratableElements(selectors)) {
            const modelName = extractModelName(element);
            if (!looksLikeModelText(modelName)) continue;

            const multiplier = getMultiplier(modelName);
            const badge = element.querySelector(`span[${attributeName}]`);

            if (multiplier === null) {
                badge?.remove();
                continue;
            }

            const text = formatMultiplier(multiplier);
            if (!text) continue;
            element.title = badgeTitle();
            ensureBadge(element, attributeName).textContent = ` ${text}`;
        }
    }

    function decoratePage() {
        decorateElements([
            '.prc-ActionList-ItemLabel-81ohH',
            '.ActionListItem-label',
            '.ActionList-content',
            '[role="menuitem"]',
            '[role="option"]',
            'button[role="menuitem"]',
            'div[role="menuitem"]',
            'summary',
            'button[aria-haspopup="menu"]',
            'button[aria-haspopup="dialog"]',
            '[data-testid*="model"]',
            '[data-testid*="model-selector"] *',
            '[data-testid*="agent"]',
            '[aria-label*="model" i]',
            '[title*="model" i]',
            'button',
            'summary',
            '[role="button"]',
            '[role="tab"]',
        ], 'data-cm-badge');

        decorateElements([
            'button[aria-haspopup="true"]',
            '[data-testid*="model"] button',
            '[data-testid*="model-selector"]',
            '[data-testid*="model-picker"]',
            '[data-testid*="agent-model"]',
            '[data-testid*="agent"] button',
            '[aria-haspopup="menu"]',
            'summary',
        ], 'data-cm-current-badge');

        const labelSelectors = [
            '[data-testid*="model"]',
            '[data-testid*="model-selector"]',
            '[data-testid*="model-picker"]',
            '[aria-label="Models"]',
            '[aria-label*="models" i]',
            '[data-testid*="agent"] [aria-label]',
            'main summary',
            'main label',
            'button',
        ];

        for (const element of collectDecoratableElements(labelSelectors)) {
            const labelText = normalize(element.textContent || element.getAttribute('aria-label'));
            if (labelText !== 'models') continue;
            ensureModelsDocsLink(element);
        }
    }

    async function init() {
        await loadMultipliers();
        decoratePage();

        const observer = new MutationObserver(() => {
            clearTimeout(observer.__timer);
            observer.__timer = setTimeout(decoratePage, 120);
        });
        observer.observe(document.body, { childList: true, subtree: true });
        document.addEventListener('click', () => setTimeout(decoratePage, 120));
    }

    init();
})();
