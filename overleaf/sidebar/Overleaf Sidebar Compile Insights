// ==UserScript==
// @name         Overleaf Sidebar Compile Insights
// @namespace    http://tampermonkey.net/
// @version      0.1.0
// @description  Add a native-like sidebar panel that tracks recent compile durations for the current project
// @match        https://*.overleaf.com/project/*
// @updateURL    https://raw.githubusercontent.com/EugenioLandi/userscripts/main/overleaf/sidebar/Overleaf%20Sidebar%20Compile%20Insights
// @downloadURL  https://raw.githubusercontent.com/EugenioLandi/userscripts/main/overleaf/sidebar/Overleaf%20Sidebar%20Compile%20Insights
// @grant        none
// @run-at       document-idle
// ==/UserScript==

(function () {
    'use strict';

    if (window.__overleafSidebarCompileInsightsInitialized) return;
    window.__overleafSidebarCompileInsightsInitialized = true;

    function ensureSidebarHost() {
        if (window.__overleafSidebarHost) return window.__overleafSidebarHost;

        const HOST_ID = 'overleaf-native-sidebar-host';
        const STYLE_ID = 'overleaf-native-sidebar-style';
        const ACTIVE_KEY = 'overleaf-native-sidebar-active';
        const OPEN_KEY = 'overleaf-native-sidebar-open';

        const state = {
            panels: new Map(),
            activeId: localStorage.getItem(ACTIVE_KEY) || null,
            isOpen: localStorage.getItem(OPEN_KEY) === '1',
            currentHref: window.location.href,
        };

        let refs = null;

        function getProjectId() {
            const match = window.location.pathname.match(/\/project\/([^/]+)/);
            return match ? match[1] : null;
        }

        function getProjectName() {
            const selectors = [
                '.ide-redesign-toolbar-project-name',
                '[data-testid="project-name"]',
                'input[aria-label="Project name"]',
                'input[name="projectName"]',
            ];

            for (const selector of selectors) {
                const element = document.querySelector(selector);
                const value = element?.value || element?.textContent;
                if (value && value.trim()) return value.trim();
            }

            return document.title.replace(/\s*-\s*Overleaf.*$/i, '').trim() || 'Untitled project';
        }

        function buildProjectUrl(suffix = '') {
            const projectId = getProjectId();
            if (!projectId) return window.location.origin;
            return `${window.location.origin}/project/${encodeURIComponent(projectId)}${suffix}`;
        }

        async function copyText(text) {
            if (navigator.clipboard?.writeText) {
                await navigator.clipboard.writeText(text);
                return;
            }

            const textarea = document.createElement('textarea');
            textarea.value = text;
            textarea.setAttribute('readonly', 'readonly');
            textarea.style.cssText = 'position:fixed;left:-9999px;top:-9999px;';
            document.body.appendChild(textarea);
            textarea.select();
            document.execCommand('copy');
            textarea.remove();
        }

        function readJson(key, fallback) {
            try {
                const parsed = JSON.parse(localStorage.getItem(key) || 'null');
                return parsed ?? fallback;
            } catch {
                return fallback;
            }
        }

        function writeJson(key, value) {
            localStorage.setItem(key, JSON.stringify(value));
        }

        function formatDateTime(timestamp) {
            return new Date(timestamp).toLocaleString();
        }

        function persistState() {
            localStorage.setItem(ACTIVE_KEY, state.activeId || '');
            localStorage.setItem(OPEN_KEY, state.isOpen && state.activeId ? '1' : '0');
        }

        function ensureStyle() {
            if (document.getElementById(STYLE_ID)) return;
            const style = document.createElement('style');
            style.id = STYLE_ID;
            style.textContent = `
                #${HOST_ID} {
                    position: fixed;
                    top: 72px;
                    left: 12px;
                    bottom: 12px;
                    z-index: 2147483000;
                    display: flex;
                    align-items: stretch;
                    font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
                    color: #24292f;
                    pointer-events: none;
                }

                #${HOST_ID}[data-open='0'] [data-role='panel'] {
                    width: 0;
                    opacity: 0;
                    transform: translateX(-8px);
                    visibility: hidden;
                }

                #${HOST_ID}[data-open='1'] [data-role='panel'] {
                    width: min(360px, calc(100vw - 96px));
                    opacity: 1;
                    transform: translateX(0);
                    visibility: visible;
                }

                #${HOST_ID} [data-role='rail'] {
                    width: 44px;
                    display: flex;
                    flex-direction: column;
                    gap: 6px;
                    padding: 8px 6px;
                    border: 1px solid #d0d7de;
                    border-radius: 16px;
                    background: rgba(255, 255, 255, 0.98);
                    box-shadow: 0 12px 30px rgba(31, 35, 40, 0.16);
                    backdrop-filter: blur(10px);
                    pointer-events: auto;
                }

                #${HOST_ID} [data-role='tab'] {
                    width: 32px;
                    height: 32px;
                    border: 0;
                    border-radius: 10px;
                    background: transparent;
                    color: #57606a;
                    display: inline-flex;
                    align-items: center;
                    justify-content: center;
                    cursor: pointer;
                    transition: background 0.16s ease, color 0.16s ease, transform 0.16s ease;
                }

                #${HOST_ID} [data-role='tab']:hover {
                    background: #f6f8fa;
                    color: #24292f;
                    transform: translateY(-1px);
                }

                #${HOST_ID} [data-role='tab'].is-active {
                    background: #e7f0ff;
                    color: #0969da;
                }

                #${HOST_ID} [data-role='panel'] {
                    margin-left: 10px;
                    display: flex;
                    flex-direction: column;
                    border: 1px solid #d0d7de;
                    border-radius: 18px;
                    background: rgba(255, 255, 255, 0.98);
                    box-shadow: 0 16px 36px rgba(31, 35, 40, 0.18);
                    backdrop-filter: blur(12px);
                    overflow: hidden;
                    transition: width 0.2s ease, opacity 0.2s ease, transform 0.2s ease, visibility 0.2s ease;
                    pointer-events: auto;
                }

                #${HOST_ID} [data-role='header'] {
                    display: flex;
                    align-items: flex-start;
                    justify-content: space-between;
                    gap: 12px;
                    padding: 16px 16px 12px;
                    border-bottom: 1px solid #d8dee4;
                }

                #${HOST_ID} [data-role='heading'] {
                    display: flex;
                    flex-direction: column;
                    gap: 4px;
                    min-width: 0;
                }

                #${HOST_ID} [data-role='title'] {
                    font: 700 14px/1.3 system-ui, sans-serif;
                    color: #24292f;
                    margin: 0;
                }

                #${HOST_ID} [data-role='subtitle'] {
                    font: 500 12px/1.4 system-ui, sans-serif;
                    color: #57606a;
                    margin: 0;
                }

                #${HOST_ID} [data-role='close'] {
                    border: 0;
                    background: #f6f8fa;
                    color: #57606a;
                    width: 28px;
                    height: 28px;
                    border-radius: 8px;
                    display: inline-flex;
                    align-items: center;
                    justify-content: center;
                    cursor: pointer;
                }

                #${HOST_ID} [data-role='close']:hover {
                    background: #eaeef2;
                    color: #24292f;
                }

                #${HOST_ID} [data-role='content'] {
                    flex: 1 1 auto;
                    min-height: 0;
                    overflow: auto;
                    padding: 16px;
                    display: flex;
                    flex-direction: column;
                    gap: 12px;
                }

                #${HOST_ID} [data-role='footer'] {
                    padding: 10px 16px 14px;
                    border-top: 1px solid #d8dee4;
                    font: 500 11px/1.4 system-ui, sans-serif;
                    color: #57606a;
                    min-height: 16px;
                }

                #${HOST_ID} .ol-sidebar-card {
                    border: 1px solid #d8dee4;
                    border-radius: 12px;
                    background: #ffffff;
                    padding: 12px;
                    box-sizing: border-box;
                }

                #${HOST_ID} .ol-sidebar-muted {
                    margin: 0;
                    color: #57606a;
                    font: 500 12px/1.5 system-ui, sans-serif;
                }

                #${HOST_ID} .ol-sidebar-button,
                #${HOST_ID} .ol-sidebar-link-button {
                    border: 1px solid #d0d7de;
                    border-radius: 10px;
                    background: #f6f8fa;
                    color: #24292f;
                    padding: 8px 10px;
                    font: 600 12px/1.2 system-ui, sans-serif;
                    cursor: pointer;
                    text-decoration: none;
                    display: inline-flex;
                    align-items: center;
                    justify-content: center;
                    gap: 6px;
                    box-sizing: border-box;
                }

                #${HOST_ID} .ol-sidebar-button:hover,
                #${HOST_ID} .ol-sidebar-link-button:hover {
                    background: #eef2f6;
                }

                #${HOST_ID} .ol-sidebar-input,
                #${HOST_ID} .ol-sidebar-textarea {
                    width: 100%;
                    border: 1px solid #d0d7de;
                    border-radius: 10px;
                    background: #ffffff;
                    color: #24292f;
                    padding: 10px 12px;
                    font: 500 12px/1.5 system-ui, sans-serif;
                    box-sizing: border-box;
                }

                #${HOST_ID} .ol-sidebar-textarea {
                    min-height: 240px;
                    resize: vertical;
                    font-family: ui-monospace, SFMono-Regular, Consolas, monospace;
                }

                #${HOST_ID} .ol-sidebar-list {
                    list-style: none;
                    padding: 0;
                    margin: 0;
                    display: flex;
                    flex-direction: column;
                    gap: 10px;
                }
            `;
            document.head.appendChild(style);
        }

        function ensureRefs() {
            if (refs?.root?.isConnected) return refs;

            const root = document.createElement('section');
            root.id = HOST_ID;
            root.dataset.open = state.isOpen && state.activeId ? '1' : '0';

            const rail = document.createElement('nav');
            rail.dataset.role = 'rail';
            rail.setAttribute('aria-label', 'Custom Overleaf sidebar');

            const panel = document.createElement('aside');
            panel.dataset.role = 'panel';
            panel.hidden = !(state.isOpen && state.activeId);

            const header = document.createElement('div');
            header.dataset.role = 'header';

            const heading = document.createElement('div');
            heading.dataset.role = 'heading';

            const title = document.createElement('h2');
            title.dataset.role = 'title';

            const subtitle = document.createElement('p');
            subtitle.dataset.role = 'subtitle';

            heading.append(title, subtitle);

            const closeButton = document.createElement('button');
            closeButton.type = 'button';
            closeButton.dataset.role = 'close';
            closeButton.setAttribute('aria-label', 'Close sidebar panel');
            closeButton.innerHTML = '&times;';
            closeButton.addEventListener('click', () => closePanel());

            header.append(heading, closeButton);

            const content = document.createElement('div');
            content.dataset.role = 'content';

            const footer = document.createElement('div');
            footer.dataset.role = 'footer';

            panel.append(header, content, footer);
            root.append(rail, panel);
            document.body.appendChild(root);

            refs = { root, rail, panel, title, subtitle, content, footer };
            return refs;
        }

        function sortedPanels() {
            return [...state.panels.values()].sort((left, right) => {
                const leftOrder = left.order ?? 0;
                const rightOrder = right.order ?? 0;
                if (leftOrder !== rightOrder) return leftOrder - rightOrder;
                return String(left.title || left.id).localeCompare(String(right.title || right.id));
            });
        }

        function setFooterText(text = '') {
            ensureRefs().footer.textContent = text;
        }

        function syncView() {
            const { root, rail, panel } = ensureRefs();
            const isVisible = Boolean(state.isOpen && state.activeId);
            root.dataset.open = isVisible ? '1' : '0';
            panel.hidden = !isVisible;
            rail.querySelectorAll('[data-role="tab"]').forEach(button => {
                const isActive = isVisible && button.dataset.panelId === state.activeId;
                button.classList.toggle('is-active', isActive);
                button.setAttribute('aria-pressed', isActive ? 'true' : 'false');
            });
        }

        function getPanelApi(panelId) {
            return {
                getProjectId,
                getProjectName,
                buildProjectUrl,
                copyText,
                readJson,
                writeJson,
                formatDateTime,
                setFooterText,
                openPanel,
                closePanel,
                rerender: () => rerenderPanel(panelId),
                isActive: () => state.isOpen && state.activeId === panelId,
                host: window.__overleafSidebarHost,
            };
        }

        function renderActivePanel() {
            const { title, subtitle, content } = ensureRefs();
            const panel = state.activeId ? state.panels.get(state.activeId) : null;
            if (!panel) {
                title.textContent = '';
                subtitle.textContent = '';
                content.textContent = '';
                setFooterText('');
                syncView();
                return;
            }

            title.textContent = panel.title;
            subtitle.textContent = panel.subtitle || '';
            content.textContent = '';
            setFooterText('');
            panel.render(content, getPanelApi(panel.id));
            syncView();
        }

        function renderTabs() {
            const { rail } = ensureRefs();
            rail.textContent = '';
            sortedPanels().forEach(panel => {
                const button = document.createElement('button');
                button.type = 'button';
                button.dataset.role = 'tab';
                button.dataset.panelId = panel.id;
                button.setAttribute('aria-label', panel.title);
                button.title = panel.title;
                button.innerHTML = panel.icon;
                button.addEventListener('click', () => {
                    if (state.isOpen && state.activeId === panel.id) {
                        closePanel();
                    } else {
                        openPanel(panel.id);
                    }
                });
                rail.appendChild(button);
            });
            syncView();
        }

        function openPanel(panelId) {
            if (!state.panels.has(panelId)) return;
            state.activeId = panelId;
            state.isOpen = true;
            persistState();
            renderActivePanel();
        }

        function closePanel() {
            state.isOpen = false;
            persistState();
            syncView();
        }

        function rerenderPanel(panelId) {
            if (state.activeId === panelId && state.isOpen) {
                renderActivePanel();
            } else {
                renderTabs();
            }
        }

        function registerPanel(panel) {
            if (!panel?.id || typeof panel.render !== 'function') {
                throw new Error('Sidebar panels must provide an id and render function');
            }
            state.panels.set(panel.id, panel);
            if (!state.activeId) state.activeId = panel.id;
            renderTabs();
            if (state.isOpen && state.activeId === panel.id) {
                renderActivePanel();
            }
        }

        function handleContextChange() {
            if (state.currentHref === window.location.href) return;
            state.currentHref = window.location.href;
            if (state.isOpen && state.activeId) {
                renderActivePanel();
            } else {
                renderTabs();
            }
        }

        ensureStyle();
        ensureRefs();
        syncView();
        window.addEventListener('keydown', event => {
            if (event.key === 'Escape' && state.isOpen) {
                closePanel();
            }
        }, true);
        window.addEventListener('popstate', handleContextChange);
        window.addEventListener('hashchange', handleContextChange);
        window.setInterval(handleContextChange, 500);

        window.__overleafSidebarHost = {
            registerPanel,
            rerenderPanel,
            openPanel,
            closePanel,
            getProjectId,
            getProjectName,
            buildProjectUrl,
            copyText,
            readJson,
            writeJson,
            formatDateTime,
        };

        return window.__overleafSidebarHost;
    }

    const host = ensureSidebarHost();
    const PANEL_ID = 'overleaf-sidebar-compile-insights';

    function ensureCompileTracker() {
        if (window.__overleafSidebarCompileTracker) return window.__overleafSidebarCompileTracker;

        const state = {
            activeProjectId: null,
            active: false,
            pendingRequests: 0,
            startTime: 0,
            listeners: new Set(),
        };

        function storageKey(projectId) {
            return `overleaf-sidebar-compile-history:${projectId}`;
        }

        function notify() {
            state.listeners.forEach(listener => listener());
        }

        function readHistory(projectId) {
            if (!projectId) return [];
            return host.readJson(storageKey(projectId), []);
        }

        function writeHistory(projectId, items) {
            if (!projectId) return;
            host.writeJson(storageKey(projectId), items.slice(0, 15));
        }

        function trackCompileRequest(url) {
            try {
                const absoluteUrl = new URL(String(url), window.location.origin);
                return /\/compile\b|\/clsi\b/i.test(absoluteUrl.pathname);
            } catch {
                return false;
            }
        }

        function begin(projectId) {
            if (!projectId) return;
            if (!state.active) {
                state.active = true;
                state.startTime = Date.now();
                state.activeProjectId = projectId;
            }
            state.pendingRequests += 1;
            notify();
        }

        function complete(projectId) {
            if (!projectId || !state.active) return;
            state.pendingRequests = Math.max(0, state.pendingRequests - 1);
            if (state.pendingRequests === 0) {
                const duration = Date.now() - state.startTime;
                const history = readHistory(state.activeProjectId || projectId);
                history.unshift({ duration, completedAt: Date.now() });
                writeHistory(state.activeProjectId || projectId, history);
                state.active = false;
                state.startTime = 0;
                state.activeProjectId = null;
            }
            notify();
        }

        const originalFetch = window.fetch;
        window.fetch = async function (...args) {
            const requestUrl = args[0] instanceof Request ? args[0].url : args[0];
            const tracked = trackCompileRequest(requestUrl);
            const projectId = host.getProjectId();
            if (tracked) begin(projectId);
            try {
                return await originalFetch.apply(this, args);
            } finally {
                if (tracked) complete(projectId);
            }
        };

        const originalOpen = XMLHttpRequest.prototype.open;
        const originalSend = XMLHttpRequest.prototype.send;

        XMLHttpRequest.prototype.open = function (method, url, ...rest) {
            this.__overleafSidebarTrackedCompile = trackCompileRequest(url);
            this.__overleafSidebarTrackedProjectId = host.getProjectId();
            return originalOpen.call(this, method, url, ...rest);
        };

        XMLHttpRequest.prototype.send = function (...args) {
            if (this.__overleafSidebarTrackedCompile) {
                begin(this.__overleafSidebarTrackedProjectId);
                const finalize = () => {
                    this.removeEventListener('loadend', finalize);
                    complete(this.__overleafSidebarTrackedProjectId);
                };
                this.addEventListener('loadend', finalize, { once: true });
            }
            return originalSend.apply(this, args);
        };

        window.__overleafSidebarCompileTracker = {
            subscribe(listener) {
                state.listeners.add(listener);
                return () => state.listeners.delete(listener);
            },
            getSnapshot(projectId) {
                const history = readHistory(projectId);
                return {
                    active: state.active && (!projectId || state.activeProjectId === projectId),
                    currentDuration: state.active ? Date.now() - state.startTime : null,
                    history,
                };
            },
        };

        return window.__overleafSidebarCompileTracker;
    }

    const tracker = ensureCompileTracker();
    tracker.subscribe(() => host.rerenderPanel(PANEL_ID));
    window.setInterval(() => host.rerenderPanel(PANEL_ID), 1000);

    function formatSeconds(duration) {
        return `${(duration / 1000).toFixed(2)}s`;
    }

    host.registerPanel({
        id: PANEL_ID,
        order: 50,
        title: 'Compile insights',
        subtitle: 'See current activity plus recent compile timings',
        icon: '<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="13" r="8"/><path d="M12 13V9"/><path d="M12 13l3 2"/><path d="M9 3h6"/></svg>',
        render(container, api) {
            const snapshot = tracker.getSnapshot(api.getProjectId());
            const history = snapshot.history;
            const last = history[0] || null;
            const average = history.length ? history.reduce((total, entry) => total + entry.duration, 0) / history.length : null;
            const slowest = history.length ? Math.max(...history.map(entry => entry.duration)) : null;

            const stats = document.createElement('div');
            stats.style.cssText = 'display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:10px;';
            [
                ['Current', snapshot.active ? formatSeconds(snapshot.currentDuration || 0) : 'Idle'],
                ['Average', average !== null ? formatSeconds(average) : '—'],
                ['Slowest', slowest !== null ? formatSeconds(slowest) : '—'],
            ].forEach(([label, value]) => {
                const card = document.createElement('div');
                card.className = 'ol-sidebar-card';
                const heading = document.createElement('strong');
                heading.style.cssText = 'display:block;font:700 11px/1.2 system-ui,sans-serif;color:#57606a;margin-bottom:6px;text-transform:uppercase;letter-spacing:0.04em;';
                heading.textContent = label;
                const detail = document.createElement('div');
                detail.style.cssText = 'font:700 14px/1.3 system-ui,sans-serif;color:#24292f;';
                detail.textContent = value;
                card.append(heading, detail);
                stats.appendChild(card);
            });
            container.appendChild(stats);

            const intro = document.createElement('p');
            intro.className = 'ol-sidebar-muted';
            intro.textContent = 'Compile timings are tracked locally from Overleaf compile-related network requests.';
            container.appendChild(intro);

            if (!history.length) {
                const empty = document.createElement('p');
                empty.className = 'ol-sidebar-muted';
                empty.textContent = 'No compile history yet for this project.';
                container.appendChild(empty);
                api.setFooterText(snapshot.active ? 'Compile in progress…' : 'Waiting for the next compile');
                return;
            }

            const list = document.createElement('ul');
            list.className = 'ol-sidebar-list';
            history.forEach(entry => {
                const item = document.createElement('li');
                item.className = 'ol-sidebar-card';
                const duration = document.createElement('strong');
                duration.style.cssText = 'display:block;font:700 13px/1.3 system-ui,sans-serif;color:#24292f;';
                duration.textContent = formatSeconds(entry.duration);
                const time = document.createElement('div');
                time.style.cssText = 'margin-top:4px;color:#57606a;font:500 11px/1.5 system-ui,sans-serif;';
                time.textContent = api.formatDateTime(entry.completedAt);
                item.append(duration, time);
                list.appendChild(item);
            });
            container.appendChild(list);
            api.setFooterText(last ? `Last compile: ${formatSeconds(last.duration)}` : 'Waiting for compile data');
        },
    });
})();
