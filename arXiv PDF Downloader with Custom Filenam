// ==UserScript==
// @name         arXiv PDF Downloader with Custom Filename
// @namespace    https://arxiv.org/
// @version      3.0.1
// @description  Download arXiv PDFs with a customizable filename, filename preview, and copy-to-clipboard support
// @match        https://arxiv.org/abs/*
// @updateURL    https://raw.githubusercontent.com/EugenioLandi/userscripts/main/arXiv%20PDF%20Downloader%20with%20Custom%20Filenam
// @downloadURL  https://raw.githubusercontent.com/EugenioLandi/userscripts/main/arXiv%20PDF%20Downloader%20with%20Custom%20Filenam
// @grant        GM_xmlhttpRequest
// @connect      arxiv.org
// @run-at       document-idle
// ==/UserScript==

(function () {
    'use strict';

    if (document.getElementById('arxiv-custom-download-box')) return;

    const $ = (selector, root = document) => root.querySelector(selector);

    function clean(text) {
        return String(text || '').replace(/\s+/g, ' ').trim();
    }

    function sanitizeFilenamePart(text) {
        return clean(text)
            .replace(/[<>:"/\\|?*\u0000-\u001F]/g, '')
            .replace(/\.+$/g, '');
    }

    function truncate(text, max = 220) {
        return text.length <= max ? text : text.slice(0, max).trim();
    }

    function getArxivId() {
        const match = location.pathname.match(/^\/abs\/(.+)$/);
        return match ? match[1] : '';
    }

    function getTitle() {
        const meta = $('meta[name="citation_title"]');
        if (meta?.content) return clean(meta.content);

        const heading = $('h1.title');
        return heading ? clean(heading.textContent.replace(/^Title:\s*/i, '')) : '';
    }

    function getAuthors() {
        const metaAuthors = [...document.querySelectorAll('meta[name="citation_author"]')]
            .map(meta => clean(meta.content))
            .filter(Boolean);
        if (metaAuthors.length) return metaAuthors.join(', ');

        const authorLinks = [...document.querySelectorAll('div.authors a')]
            .map(link => clean(link.textContent))
            .filter(Boolean);
        if (authorLinks.length) return authorLinks.join(', ');

        const authorBlock = $('div.authors');
        return authorBlock ? clean(authorBlock.textContent.replace(/^Authors?:\s*/i, '')) : '';
    }

    function buildFilename(meta) {
        const title = sanitizeFilenamePart(meta.title || 'Untitled');
        const authors = sanitizeFilenamePart(meta.authors || 'Unknown author(s)');
        const id = sanitizeFilenamePart(meta.id || 'arXiv');
        return `${truncate(`${title} - ${authors} - ${id}`)}.pdf`;
    }

    function ensurePdfUrl(id) {
        const existingLink = document.querySelector('a[href*="/pdf/"]');
        if (existingLink?.href) {
            return new URL(existingLink.getAttribute('href'), location.origin).toString();
        }
        return `https://arxiv.org/pdf/${encodeURIComponent(id)}.pdf`;
    }

    function setStatus(element, message, isError = false) {
        element.textContent = message;
        element.style.color = isError ? '#b00020' : '#444';
    }

    function downloadBlob(blob, filename) {
        const blobUrl = URL.createObjectURL(blob);
        const link = document.createElement('a');
        link.href = blobUrl;
        link.download = filename;
        document.body.appendChild(link);
        link.click();
        link.remove();
        window.setTimeout(() => URL.revokeObjectURL(blobUrl), 5000);
    }

    function fetchPdfAsBlob(url) {
        return new Promise((resolve, reject) => {
            if (typeof GM_xmlhttpRequest === 'function') {
                GM_xmlhttpRequest({
                    method: 'GET',
                    url,
                    responseType: 'blob',
                    onload: response => {
                        if (response.status >= 200 && response.status < 300 && response.response) {
                            resolve(response.response);
                        } else {
                            reject(new Error(`HTTP ${response.status}`));
                        }
                    },
                    onerror: () => reject(new Error('Network error')),
                    ontimeout: () => reject(new Error('Request timeout')),
                });
                return;
            }

            fetch(url, { credentials: 'include' })
                .then(response => {
                    if (!response.ok) throw new Error(`HTTP ${response.status}`);
                    return response.blob();
                })
                .then(resolve)
                .catch(reject);
        });
    }

    async function copyToClipboard(text) {
        if (navigator.clipboard?.writeText) {
            await navigator.clipboard.writeText(text);
            return;
        }

        // Legacy fallback for older userscript managers and browsers without Clipboard API support.
        const input = document.createElement('textarea');
        input.value = text;
        document.body.appendChild(input);
        input.select();
        document.execCommand('copy');
        input.remove();
    }

    function normalizeFilenameInput(input) {
        let value = sanitizeFilenamePart(input.value || 'arXiv');
        if (!value.toLowerCase().endsWith('.pdf')) value = `${value}.pdf`;
        input.value = truncate(value, 224);
        return input.value;
    }

    function injectUI(meta) {
        const box = document.createElement('section');
        box.id = 'arxiv-custom-download-box';
        box.style.cssText = [
            'margin:12px 0',
            'padding:12px',
            'border:1px solid #d0d7de',
            'border-radius:8px',
            'background:#f6f8fa',
            'display:flex',
            'flex-direction:column',
            'gap:10px',
        ].join(';');

        const title = document.createElement('strong');
        title.textContent = 'Custom PDF download';

        const filenameInput = document.createElement('input');
        filenameInput.type = 'text';
        filenameInput.value = buildFilename(meta);
        filenameInput.style.cssText = 'width:100%;padding:8px 10px;border:1px solid #d0d7de;border-radius:6px;font:13px/1.3 system-ui,sans-serif;';
        filenameInput.addEventListener('blur', () => normalizeFilenameInput(filenameInput));

        const actions = document.createElement('div');
        actions.style.cssText = 'display:flex;flex-wrap:wrap;gap:8px;';

        const downloadButton = document.createElement('button');
        downloadButton.type = 'button';
        downloadButton.textContent = 'Download PDF';
        downloadButton.style.cssText = 'appearance:none;border:1px solid #1f6feb;background:#2f81f7;color:#fff;padding:8px 12px;border-radius:6px;font-weight:600;cursor:pointer;';

        const copyButton = document.createElement('button');
        copyButton.type = 'button';
        copyButton.textContent = 'Copy filename';
        copyButton.style.cssText = 'appearance:none;border:1px solid #d0d7de;background:#fff;color:#24292f;padding:8px 12px;border-radius:6px;font-weight:600;cursor:pointer;';

        const openLink = document.createElement('a');
        openLink.href = ensurePdfUrl(meta.id);
        openLink.target = '_blank';
        openLink.rel = 'noopener';
        openLink.textContent = 'Open PDF';
        openLink.style.cssText = 'display:inline-flex;align-items:center;padding:8px 12px;border:1px solid #d0d7de;border-radius:6px;background:#fff;color:#24292f;font:600 13px/1 system-ui,sans-serif;text-decoration:none;';

        const status = document.createElement('div');
        status.style.cssText = 'font-size:12px;min-height:16px;color:#444;';

        downloadButton.addEventListener('click', async () => {
            const filename = normalizeFilenameInput(filenameInput);
            downloadButton.disabled = true;
            downloadButton.style.opacity = '0.7';
            setStatus(status, 'Downloading PDF…');

            try {
                const blob = await fetchPdfAsBlob(openLink.href);
                downloadBlob(blob, filename);
                setStatus(status, `Saved ${filename}`);
            } catch (error) {
                console.error('[arXiv userscript] download failed:', error);
                setStatus(status, `Failed (${error?.message || 'unknown error'}). Open the PDF directly as a fallback.`, true);
            } finally {
                downloadButton.disabled = false;
                downloadButton.style.opacity = '1';
            }
        });

        copyButton.addEventListener('click', async () => {
            try {
                const filename = normalizeFilenameInput(filenameInput);
                await copyToClipboard(filename);
                setStatus(status, `Copied ${filename}`);
            } catch (error) {
                setStatus(status, `Copy failed (${error?.message || 'unknown error'})`, true);
            }
        });

        actions.append(downloadButton, copyButton, openLink);
        box.append(title, filenameInput, actions, status);

        const anchor = $('.full-text') || $('#abs-outer') || $('#content') || document.body;
        anchor.prepend(box);
    }

    function main() {
        const id = getArxivId();
        if (!id) return;
        injectUI({ id, title: getTitle(), authors: getAuthors() });
    }

    main();
})();
