    function setStatus(message, isError = false) {
        const status = document.getElementById(STATUS_ID);
        if (!status) return;
        status.textContent = message;
        status.classList.toggle('error', Boolean(isError));
    }

    function updatePanelTitle() {
        const titleElement = document.getElementById(TITLE_ID);
        if (!titleElement) return;
        const title = uniqueStrings([
            contentFromMeta('og:title'),
            contentFromMeta('twitter:title', 'name'),
            textFromSelectors(['h1', '[itemprop="name"]']),
        ])[0] || 'Current item';
        titleElement.textContent = title;
    }

    function getReadyStatusMessage() {
        return state.includeImages
            ? 'Ready to capture this item into a ZIP archive.'
            : 'Ready to capture this item into a ZIP archive without downloading images.';
    }

    function syncIncludeImagesToggle() {
        const toggle = document.getElementById(TOGGLE_ID);
        if (toggle) toggle.checked = state.includeImages;
    }

    function handleIncludeImagesToggle(event) {
        state.includeImages = Boolean(event?.target?.checked);
        persistIncludeImagesPreference(state.includeImages);
        if (isItemPage() && !state.busy) {
            setStatus(getReadyStatusMessage());
        }
    }

    async function handleDownloadClick() {
        if (state.busy) return;

        const button = document.getElementById(BUTTON_ID);
        state.busy = true;
        if (button) button.disabled = true;
        setStatus(state.includeImages ? 'Preparing archive…' : 'Preparing archive without images…');

        try {
            await buildZipArchive({ includeImages: state.includeImages });
        } catch (error) {
            console.error('[Vinted Item ZIP Backup]', error);
            setStatus(`Archive failed: ${error?.message || 'unknown error'}`, true);
        } finally {
            state.busy = false;
            if (button) button.disabled = false;
        }
    }

    function ensurePanel() {
        ensureStyle();

        let panel = document.getElementById(PANEL_ID);
        if (!panel) {
            panel = document.createElement('section');
            panel.id = PANEL_ID;
            panel.innerHTML = `
                <strong>Vinted item ZIP backup</strong>
                <small id="${TITLE_ID}">Current item</small>
                <label for="${TOGGLE_ID}">
                    <input type="checkbox" id="${TOGGLE_ID}">
                    Include images in the ZIP
                </label>
                <button type="button" id="${BUTTON_ID}">Save item as ZIP</button>
                <div id="${STATUS_ID}">Photos, metadata, page HTML, and structured data will be included when available.</div>
            `;
            document.body.appendChild(panel);
            panel.querySelector(`#${BUTTON_ID}`)?.addEventListener('click', handleDownloadClick);
            panel.querySelector(`#${TOGGLE_ID}`)?.addEventListener('change', handleIncludeImagesToggle);
        }

        panel.hidden = !isItemPage();
        syncIncludeImagesToggle();
        if (!panel.hidden) updatePanelTitle();
    }

    function syncUi() {
        const currentUrl = window.location.href;
        if (state.lastUrl !== currentUrl) {
            state.lastUrl = currentUrl;
            ensurePanel();
            if (isItemPage()) {
                setStatus(getReadyStatusMessage());
            }
        } else if (isItemPage() && !document.getElementById(PANEL_ID)) {
            ensurePanel();
        }
    }

    function init() {
        ensurePanel();
        state.lastUrl = window.location.href;
        const observer = new MutationObserver(() => {
            window.clearTimeout(state.statusTimer);
            state.statusTimer = window.setTimeout(syncUi, 120);
        });
        observer.observe(document.documentElement, { childList: true, subtree: true });
        window.setInterval(syncUi, 1000);
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init, { once: true });
    } else {
        init();
    }
})();
