// ==UserScript==
// @name         Vinted Item ZIP Backup
// @namespace    https://www.vinted.com/
// @version      1.2.0
// @description  Save the current Vinted item page as a ZIP with photos, metadata, structured data, and a page snapshot
// @include      https://vinted.*/*
// @include      https://www.vinted.*/*
// @updateURL    https://raw.githubusercontent.com/EugenioLandi/userscripts/main/Vinted%20Item%20ZIP%20Backup
// @downloadURL  https://raw.githubusercontent.com/EugenioLandi/userscripts/main/Vinted%20Item%20ZIP%20Backup
// @grant        GM_xmlhttpRequest
// @grant        GM.xmlHttpRequest
// @connect      *
// @require      https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js
// @run-at       document-idle
// @noframes
// ==/UserScript==

(function () {
    'use strict';

    function isSupportedVintedHost(hostname) {
        const normalizedHostname = String(hostname || '').toLowerCase();
        const bareHostname = normalizedHostname.startsWith('www.')
            ? normalizedHostname.slice(4)
            : normalizedHostname;
        const suffix = bareHostname.startsWith('vinted.')
            ? bareHostname.slice('vinted.'.length)
            : '';
        return [
            'at',
            'be',
            'co.uk',
            'com',
            'cz',
            'de',
            'dk',
            'es',
            'fi',
            'fr',
            'hr',
            'hu',
            'it',
            'lt',
            'lu',
            'nl',
            'pl',
            'pt',
            'ro',
            'se',
            'si',
            'sk',
        ].includes(suffix);
    }

    if (!isSupportedVintedHost(window.location.hostname)) return;
    if (window.__vintedItemZipBackupInitialized) return;
    window.__vintedItemZipBackupInitialized = true;

    const PANEL_ID = 'vinted-item-zip-backup-panel';
    const STYLE_ID = 'vinted-item-zip-backup-style';
    const BUTTON_ID = 'vinted-item-zip-backup-button';
    const STATUS_ID = 'vinted-item-zip-backup-status';
    const TITLE_ID = 'vinted-item-zip-backup-title';
    const TOGGLE_ID = 'vinted-item-zip-backup-include-images';
    const SNAPSHOT_VERSION = '1.1.0';
    const ASSET_REQUEST_TIMEOUT_MS = 20000;
    const MIN_PHOTO_DIMENSION = 160;
    const NON_ITEM_IMAGE_URL_PATTERN = /avatar|profile|member|seller|logo|icon/;
    const ZIP_PROGRESS_STEP = 5;
    const INCLUDE_IMAGES_STORAGE_KEY = 'vinted-item-zip-backup-include-images';
    const state = {
        busy: false,
        includeImages: loadIncludeImagesPreference(),
        lastUrl: '',
        statusTimer: 0,
    };

    function isItemPage() {
        return /\/items\/\d+/.test(window.location.pathname);
    }

    function getItemId() {
        const match = window.location.pathname.match(/\/items\/(\d+)/);
        return match ? match[1] : '';
    }

    function loadIncludeImagesPreference() {
        try {
            const storedValue = window.localStorage.getItem(INCLUDE_IMAGES_STORAGE_KEY);
            if (storedValue !== null) return storedValue !== 'false';
        } catch {}
        return true;
    }

    function persistIncludeImagesPreference(value) {
        try {
            window.localStorage.setItem(INCLUDE_IMAGES_STORAGE_KEY, String(Boolean(value)));
        } catch {}
    }

    function cleanText(value) {
        return String(value || '').replace(/\s+/g, ' ').trim();
    }

    function sanitizeFilenamePart(value) {
        return cleanText(value)
            .replace(/[<>:"/\\|?*\u0000-\u001F]/g, ' ')
            .replace(/\s+/g, ' ')
            .trim()
            .replace(/\.+$/g, '');
    }

    function truncate(value, maxLength = 180) {
        return value.length > maxLength ? value.slice(0, maxLength).trim() : value;
    }

    function uniqueStrings(values) {
        const seen = new Set();
        const result = [];
        for (const value of values) {
            const cleaned = cleanText(value);
            if (!cleaned) continue;
            const key = cleaned.toLowerCase();
            if (seen.has(key)) continue;
            seen.add(key);
            result.push(cleaned);
        }
        return result;
    }

    function safeJsonParse(text) {
        try {
            return JSON.parse(text);
        } catch {
            return null;
        }
    }

    function prettyJson(value) {
        return JSON.stringify(value, null, 2);
    }

    function extractNumericAmount(text) {
        const candidate = cleanText(text).match(/-?[\d.,]+/g)?.sort((left, right) => right.length - left.length)[0];
        if (!candidate) return null;

        let normalized = candidate;
        const commaCount = (normalized.match(/,/g) || []).length;
        const dotCount = (normalized.match(/\./g) || []).length;

        if (commaCount && dotCount) {
            const lastComma = normalized.lastIndexOf(',');
            const lastDot = normalized.lastIndexOf('.');
            if (lastComma > lastDot) {
                normalized = normalized.replace(/\./g, '').replace(',', '.');
            } else {
                normalized = normalized.replace(/,/g, '');
            }
        } else if (commaCount > 1) {
            normalized = normalized.replace(/,/g, '');
        } else if (dotCount > 1) {
            normalized = normalized.replace(/\./g, '');
        } else if (commaCount === 1 && dotCount === 0) {
            normalized = normalized.replace(',', '.');
        }

        const amount = Number(normalized);
        return Number.isFinite(amount) ? amount : null;
    }

    function extractAssignedJsonLiteral(text) {
        const assignmentMatch = text.match(/(?:(?:window\.)?__INITIAL_STATE__|(?:window\.)?__NUXT__|__NEXT_DATA__|__PRELOADED_STATE__)\s*=\s*/);
        if (!assignmentMatch) return '';

        const assignmentEnd = assignmentMatch.index + assignmentMatch[0].length;
        let startIndex = -1;
        for (let index = assignmentEnd; index < text.length; index += 1) {
            const character = text[index];
            if (character === '{' || character === '[') {
                startIndex = index;
                break;
            }
            if (!/\s/.test(character)) break;
        }
        if (startIndex === -1) return '';

        const opening = text[startIndex];
        const closing = opening === '{' ? '}' : ']';
        let depth = 0;
        let quote = '';
        let escaped = false;

        for (let index = startIndex; index < text.length; index += 1) {
            const character = text[index];

            if (quote) {
                if (escaped) {
                    escaped = false;
                } else if (character === '\\') {
                    escaped = true;
                } else if (character === quote) {
                    quote = '';
                }
                continue;
            }

            if (character === '"' || character === '\'' || character === '`') {
                quote = character;
                continue;
            }

            if (character === opening) depth += 1;
            if (character === closing) depth -= 1;

            if (depth === 0) {
                return text.slice(startIndex, index + 1);
            }
        }

        return '';
    }

    function getTimestamp() {
        const date = new Date();
        const year = date.getFullYear();
        const month = String(date.getMonth() + 1).padStart(2, '0');
        const day = String(date.getDate()).padStart(2, '0');
        const hours = String(date.getHours()).padStart(2, '0');
        const minutes = String(date.getMinutes()).padStart(2, '0');
        const seconds = String(date.getSeconds()).padStart(2, '0');
        return `${year}-${month}-${day}_${hours}-${minutes}-${seconds}`;
    }

    function buildArchiveName(item) {
        const parts = [
            sanitizeFilenamePart(item.title || item.metaTitle || `vinted-item-${item.itemId || 'snapshot'}`),
            sanitizeFilenamePart(item.itemId),
            getTimestamp(),
        ].filter(Boolean);
        return truncate(parts.join(' - ') || 'vinted-item-snapshot', 200);
    }

    function textFromSelectors(selectors, root = document) {
        for (const selector of selectors) {
            const element = root.querySelector(selector);
            const value = cleanText(element?.textContent || element?.value || '');
            if (value) return value;
        }
        return '';
    }

    function hrefFromSelectors(selectors, root = document) {
        for (const selector of selectors) {
            const element = root.querySelector(selector);
            const href = element?.getAttribute?.('href');
            if (href) return new URL(href, window.location.origin).toString();
        }
        return '';
    }

    function contentFromMeta(key, attr = 'property') {
        return cleanText(document.querySelector(`meta[${attr}="${key}"]`)?.getAttribute('content') || '');
    }

    function normalizeUrl(url) {
        if (!url || typeof url !== 'string') return '';
        try {
            return new URL(url, window.location.href).toString();
        } catch {
            return '';
        }
    }

    function looksLikeImageUrl(value) {
        if (!value || typeof value !== 'string') return false;
        return /^https?:\/\//i.test(value) || value.startsWith('//');
    }

    function normalizeImageCandidates(value, results = []) {
        if (!value) return results;

        if (typeof value === 'string') {
            const url = normalizeUrl(value);
            if (url && looksLikeImageUrl(url)) results.push(url);
            return results;
        }

        if (Array.isArray(value)) {
            for (const entry of value) normalizeImageCandidates(entry, results);
            return results;
        }

        if (typeof value === 'object') {
            const preferredKeys = [
                'url',
                'secure_url',
                'full_size_url',
                'large_url',
                'medium_url',
                'small_url',
                'image_url',
                'image',
                'src',
                'imageUrl',
                'contentUrl',
                'preview_url',
                'thumbnail_url',
            ];

            for (const key of preferredKeys) {
                if (key in value) normalizeImageCandidates(value[key], results);
            }

            if (!results.length) {
                for (const nestedValue of Object.values(value)) {
                    if (typeof nestedValue === 'string' && looksLikeImageUrl(nestedValue)) {
                        normalizeImageCandidates(nestedValue, results);
                    }
                }
            }
        }

        return results;
    }

    function dedupeUrls(urls) {
        const seen = new Set();
        const result = [];
        for (const url of urls) {
            const normalized = normalizeUrl(url);
            if (!normalized || seen.has(normalized)) continue;
            seen.add(normalized);
            result.push(normalized);
        }
        return result;
    }

    function filterItemPhotoUrls(urls, options = {}) {
        const itemId = cleanText(options.itemId);
        const sellerAvatarUrl = normalizeUrl(options.sellerAvatarUrl);
        const seen = new Set();
        const results = [];

        for (const url of urls) {
            const normalized = normalizeUrl(url);
            if (!normalized || seen.has(normalized)) continue;
            seen.add(normalized);
            if (sellerAvatarUrl && normalized === sellerAvatarUrl) continue;

            let pathname = '';
            let search = '';
            try {
                const parsed = new URL(normalized);
                pathname = parsed.pathname.toLowerCase();
                search = parsed.search.toLowerCase();
            } catch {
                pathname = normalized.toLowerCase();
            }

            const looksLikeAvatar = /user(?:name)?-photo/.test(pathname)
                || NON_ITEM_IMAGE_URL_PATTERN.test(pathname)
                || NON_ITEM_IMAGE_URL_PATTERN.test(search);
            if (looksLikeAvatar) continue;

            const matchedItemId = pathname.match(/\/items\/(\d+)/)?.[1] || '';
            if (itemId && matchedItemId && matchedItemId !== itemId) continue;

            results.push(normalized);
        }

        return results;
    }

    function collectMetaTags() {
        const entries = {};
        for (const meta of document.querySelectorAll('meta[name], meta[property]')) {
            const key = meta.getAttribute('name') || meta.getAttribute('property');
            const value = meta.getAttribute('content');
            if (!key || !value) continue;
            entries[key] = value;
        }
        return entries;
    }

    function collectJsonScripts() {
        const parsed = [];
        const failures = [];

        for (const [index, script] of [...document.scripts].entries()) {
            const text = script.textContent?.trim();
            if (!text) continue;

            const type = cleanText(script.type || 'text/javascript');
            const scriptId = cleanText(script.id);
            const parseCandidates = [];

            if (type.includes('json')) {
                parseCandidates.push(text);
            } else {
                const extractedAssignment = extractAssignedJsonLiteral(text);
                if (extractedAssignment) parseCandidates.push(extractedAssignment);
            }

            for (const candidate of parseCandidates) {
                const data = safeJsonParse(candidate);
                if (data) {
                    parsed.push({ index, type, id: scriptId || null, data });
                } else {
                    failures.push({
                        index,
                        type,
                        id: scriptId || null,
                        preview: candidate.slice(0, 300),
                    });
                }
            }
        }

        return { parsed, failures };
    }

    function walkObject(value, callback, seen = new WeakSet(), path = []) {
        if (!value || typeof value !== 'object') return;
        if (seen.has(value)) return;
        seen.add(value);
        callback(value, path);

        if (Array.isArray(value)) {
            value.forEach((entry, index) => walkObject(entry, callback, seen, path.concat(index)));
            return;
        }

        for (const [key, child] of Object.entries(value)) {
            walkObject(child, callback, seen, path.concat(key));
        }
    }

    function summarizePrice(value) {
        if (value == null) return null;

        if (typeof value === 'number') {
            return { amount: value, text: String(value) };
        }

        if (typeof value === 'string') {
            const text = cleanText(value);
            return { amount: extractNumericAmount(text), text };
        }

        if (typeof value === 'object') {
            const amount = Number(value.amount ?? value.value ?? value.price ?? value.price_amount ?? NaN);
            const currency = cleanText(value.currency ?? value.currency_code ?? value.currencyCode);
            const text = uniqueStrings([
                value.formatted,
                value.text,
                value.display,
                [Number.isFinite(amount) ? amount : '', currency].filter(Boolean).join(' '),
            ])[0] || '';
            return {
                amount: Number.isFinite(amount) ? amount : null,
                currency: currency || null,
                text: text || null,
            };
        }

        return null;
    }

    function scoreItemCandidate(candidate) {
        if (!candidate || typeof candidate !== 'object' || Array.isArray(candidate)) return 0;

        let score = 0;
        const currentItemId = getItemId();
        const asText = JSON.stringify(candidate).slice(0, 5000);

        if (cleanText(candidate.title || candidate.name)) score += 3;
        if (cleanText(candidate.description)) score += 3;
        if (candidate.photos || candidate.photo || candidate.images || candidate.image) score += 3;
        if (candidate.price || candidate.price_numeric || candidate.price_amount || candidate.total_item_price) score += 2;
        if (candidate.user || candidate.seller) score += 2;
        if (candidate.id && String(candidate.id) === currentItemId) score += 4;
        if (currentItemId && asText.includes(currentItemId)) score += 1;
        return score;
    }

    function extractBestStructuredCandidate(parsedScripts) {
        const candidates = [];

        for (const script of parsedScripts) {
            walkObject(script.data, object => {
                const score = scoreItemCandidate(object);
                if (score > 0) candidates.push({ score, object });
            });
        }

        candidates.sort((a, b) => b.score - a.score);
        return candidates[0]?.object || null;
    }

    function collectDefinitionListData() {
        const details = {};

        for (const dl of document.querySelectorAll('dl')) {
            const children = [...dl.children];
            for (let index = 0; index < children.length - 1; index += 1) {
                const term = children[index];
                const description = children[index + 1];
                if (!term || !description) continue;
                if (term.tagName !== 'DT' || description.tagName !== 'DD') continue;
                const key = cleanText(term.textContent);
                const value = cleanText(description.textContent);
                if (key && value && !(key in details)) details[key] = value;
            }
        }

        for (const row of document.querySelectorAll('table tr')) {
            const cells = [...row.querySelectorAll('th, td')];
            if (cells.length < 2) continue;
            const key = cleanText(cells[0].textContent);
            const value = cleanText(cells.slice(1).map(cell => cell.textContent).join(' '));
            if (key && value && !(key in details)) details[key] = value;
        }

        return details;
    }

    function collectBreadcrumbs() {
        const links = [
            ...document.querySelectorAll('nav[aria-label*="breadcrumb" i] a, nav ol a, [data-testid*="breadcrumb"] a'),
        ];
        return uniqueStrings(links.map(link => link.textContent).filter(Boolean));
    }

    function isLikelyItemPhotoElement(image, itemId = '') {
        if (!(image instanceof HTMLImageElement)) return false;

        const width = image.naturalWidth || image.width || 0;
        const height = image.naturalHeight || image.height || 0;
        if (width < MIN_PHOTO_DIMENSION || height < MIN_PHOTO_DIMENSION) return false;

        const anchorHref = normalizeUrl(image.closest('a[href]')?.getAttribute('href') || '');
        if (anchorHref) {
            if (/\/member\/|\/catalog\/|\/search\//i.test(anchorHref)) return false;
            const linkedItemId = anchorHref.match(/\/items\/(\d+)/)?.[1] || '';
            if (linkedItemId && itemId && linkedItemId !== itemId) return false;
        }

        const contextText = [
            image.closest('[data-testid]')?.getAttribute('data-testid') || '',
            image.closest('[class]')?.className || '',
            image.closest('[aria-label]')?.getAttribute('aria-label') || '',
        ].join(' ').toLowerCase();

        if (/seller|profile|avatar|member|recommend|similar|suggest|banner|logo|icon/.test(contextText)) return false;
        if (/gallery|photo|image|carousel|swiper|media/.test(contextText)) return true;

        return false;
    }

    function collectDomPhotos(itemId = '') {
        const candidates = [];
        const seen = new Set();

        for (const image of document.querySelectorAll('img[src]')) {
            if (!isLikelyItemPhotoElement(image, itemId)) continue;

            const url = normalizeUrl(image.currentSrc || image.src || '');
            if (!url || seen.has(url)) continue;
            seen.add(url);

            const width = image.naturalWidth || image.width || 0;
            const height = image.naturalHeight || image.height || 0;
            candidates.push({
                url,
                area: width * height,
            });
        }

        candidates.sort((left, right) => right.area - left.area);
        return candidates.map(candidate => candidate.url);
    }

    function collectSellerAvatar() {
        const selectors = [
            'a[href*="/member/"] img[src]',
            '[data-testid*="profile"] img[src]',
            '[data-testid*="seller"] img[src]',
        ];

        for (const selector of selectors) {
            const image = document.querySelector(selector);
            const url = normalizeUrl(image?.currentSrc || image?.src || '');
            if (url) return url;
        }
        return '';
    }

    function normalizeStructuredData(jsonLdObjects) {
        const products = [];

        for (const entry of jsonLdObjects) {
            walkObject(entry.data, object => {
                const type = object['@type'];
                const types = Array.isArray(type) ? type : [type];
                if (types.some(value => String(value).toLowerCase() === 'product')) {
                    products.push(object);
                }
            });
        }

        const product = products[0] || null;
        const offer = Array.isArray(product?.offers) ? product.offers[0] : (product?.offers || null);
        const seller = offer?.seller || product?.seller || null;
        return {
            product,
            offer,
            seller,
        };
    }

    function collectItemData() {
        const metaTags = collectMetaTags();
        const jsonScripts = collectJsonScripts();
        const jsonLdObjects = jsonScripts.parsed.filter(entry => entry.type.includes('ld+json'));
        const normalizedJsonLd = normalizeStructuredData(jsonLdObjects);
        const bestCandidate = extractBestStructuredCandidate(jsonScripts.parsed);
        const definitionListData = collectDefinitionListData();
        const breadcrumbs = collectBreadcrumbs();
        const itemId = getItemId();
        const domPhotos = collectDomPhotos(itemId);
        const sellerAvatar = collectSellerAvatar();

        const metaTitle = contentFromMeta('og:title') || contentFromMeta('twitter:title', 'name');
        const metaDescription = contentFromMeta('og:description') || contentFromMeta('description', 'name');
        const metaImage = contentFromMeta('og:image') || contentFromMeta('twitter:image', 'name');
        const structuredProduct = normalizedJsonLd.product || {};
        const structuredOffer = normalizedJsonLd.offer || {};
        const structuredSeller = normalizedJsonLd.seller || {};
        const primaryStructuredPhotos = dedupeUrls([
            ...normalizeImageCandidates(bestCandidate?.photos),
            ...normalizeImageCandidates(bestCandidate?.photo),
            ...normalizeImageCandidates(structuredProduct.image),
        ]);
        const secondaryStructuredPhotos = dedupeUrls([
            ...primaryStructuredPhotos,
            ...normalizeImageCandidates(bestCandidate?.images),
            ...normalizeImageCandidates(bestCandidate?.image),
            metaImage,
        ]);
        const usesStructuredPhotoSet = primaryStructuredPhotos.length > 0;
        const candidatePhotoSources = usesStructuredPhotoSet
            ? secondaryStructuredPhotos
            : secondaryStructuredPhotos.concat(domPhotos);
        const filteredPhotos = filterItemPhotoUrls(candidatePhotoSources, {
            itemId,
            sellerAvatarUrl: sellerAvatar,
        });

        const item = {
            archivedAt: new Date().toISOString(),
            snapshotVersion: SNAPSHOT_VERSION,
            itemId,
            pageUrl: window.location.href,
            canonicalUrl: hrefFromSelectors(['link[rel="canonical"]']) || window.location.href,
            pageTitle: cleanText(document.title),
            metaTitle,
            title: uniqueStrings([
                cleanText(bestCandidate?.title),
                cleanText(bestCandidate?.name),
                cleanText(structuredProduct.name),
                textFromSelectors(['h1', '[itemprop="name"]']),
                metaTitle,
            ])[0] || '',
            description: uniqueStrings([
                cleanText(bestCandidate?.description),
                cleanText(structuredProduct.description),
                textFromSelectors([
                    '[itemprop="description"]',
                    '[data-testid*="description"]',
                    '[class*="description"]',
                ]),
                metaDescription,
            ])[0] || '',
            price: summarizePrice(
                bestCandidate?.price
                ?? bestCandidate?.total_item_price
                ?? structuredOffer?.price
                ?? contentFromMeta('product:price:amount')
                ?? textFromSelectors([
                    '[itemprop="price"]',
                    '[data-testid*="price"]',
                    '[class*="price"]',
                ])
            ),
            currency: cleanText(
                bestCandidate?.currency
                || bestCandidate?.price?.currency
                || structuredOffer?.priceCurrency
                || contentFromMeta('product:price:currency')
            ),
            sellerUsername: uniqueStrings([
                cleanText(bestCandidate?.user?.login),
                cleanText(bestCandidate?.seller?.login),
                cleanText(bestCandidate?.user?.username),
                cleanText(bestCandidate?.seller?.username),
                cleanText(structuredSeller?.name),
                textFromSelectors([
                    'a[href*="/member/"] span',
                    '[data-testid*="seller"]',
                    '[data-testid*="profile"]',
                ]),
            ])[0] || '',
            sellerId: uniqueStrings([
                cleanText(bestCandidate?.user?.id),
                cleanText(bestCandidate?.seller?.id),
                cleanText(bestCandidate?.user?.user_id),
            ])[0] || '',
            sellerProfileUrl: hrefFromSelectors([
                'a[href*="/member/"]',
                '[data-testid*="seller"] a[href]',
                '[data-testid*="profile"] a[href]',
            ]),
            sellerAvatarUrl: sellerAvatar,
            brand: uniqueStrings([
                cleanText(bestCandidate?.brand_title),
                cleanText(bestCandidate?.brand),
                cleanText(structuredProduct?.brand?.name),
                definitionListData.Brand,
            ])[0] || '',
            category: uniqueStrings([
                cleanText(bestCandidate?.catalog_branch_title),
                cleanText(bestCandidate?.catalog?.title),
                cleanText(structuredProduct.category),
                breadcrumbs.join(' > '),
            ])[0] || '',
            size: uniqueStrings([
                cleanText(bestCandidate?.size_title),
                cleanText(bestCandidate?.size),
                definitionListData.Size,
            ])[0] || '',
            condition: uniqueStrings([
                cleanText(bestCandidate?.status),
                cleanText(bestCandidate?.status_title),
                definitionListData.Condition,
            ])[0] || '',
            color: uniqueStrings([
                cleanText(bestCandidate?.colour),
                cleanText(bestCandidate?.color),
                definitionListData.Colour,
                definitionListData.Color,
            ])[0] || '',
            material: uniqueStrings([
                cleanText(bestCandidate?.material),
                definitionListData.Material,
            ])[0] || '',
            location: uniqueStrings([
                cleanText(bestCandidate?.user?.country),
                cleanText(bestCandidate?.seller?.country),
                textFromSelectors([
                    '[data-testid*="location"]',
                    '[class*="location"]',
                ]),
            ])[0] || '',
            favoriteCount: cleanText(bestCandidate?.favourite_count || bestCandidate?.favorite_count || ''),
            viewCount: cleanText(bestCandidate?.view_count || bestCandidate?.views || ''),
            uploadDate: uniqueStrings([
                cleanText(bestCandidate?.created_at),
                cleanText(bestCandidate?.createdAt),
                cleanText(structuredProduct.releaseDate),
                cleanText(document.querySelector('time')?.getAttribute('datetime') || ''),
            ])[0] || '',
            photos: dedupeUrls(filteredPhotos),
            breadcrumbs,
            attributes: definitionListData,
        };

        if (!item.currency && item.price?.currency) item.currency = item.price.currency;
        if (item.price?.text && !item.currency) {
            const currencySymbol = item.price.text.match(/\b(?:USD|EUR|GBP)\b|[€$£]/i)?.[0] || '';
            if (currencySymbol) item.currency = currencySymbol;
        }

        return {
            item,
            raw: {
                metaTags,
                jsonLdObjects,
                jsonParseFailures: jsonScripts.failures,
                definitionListData,
                breadcrumbs,
                bestCandidate,
                sellerAvatar,
                domPhotos,
                primaryStructuredPhotos,
                secondaryStructuredPhotos,
                pageHtml: document.documentElement.outerHTML,
                locationHref: window.location.href,
                userAgent: navigator.userAgent,
            },
        };
    }

    function getFileExtensionFromType(contentType, url) {
        const type = cleanText(contentType).toLowerCase();
        if (type.includes('jpeg') || type.includes('jpg')) return 'jpg';
        if (type.includes('png')) return 'png';
        if (type.includes('webp')) return 'webp';
        if (type.includes('gif')) return 'gif';
        if (type.includes('svg')) return 'svg';
        if (type.includes('bmp')) return 'bmp';
        if (type.includes('avif')) return 'avif';
        if (type.includes('json')) return 'json';
        if (type.includes('html')) return 'html';

        try {
            const pathname = new URL(url, window.location.href).pathname;
            const match = pathname.match(/\.([a-z0-9]{2,10})$/i);
            return match ? match[1].toLowerCase() : 'bin';
        } catch {
            return 'bin';
        }
    }

    function getRequestFunction() {
        if (typeof GM_xmlhttpRequest === 'function') return GM_xmlhttpRequest;
        if (typeof GM !== 'undefined' && typeof GM.xmlHttpRequest === 'function') {
            return details => GM.xmlHttpRequest(details);
        }
        return null;
    }

    function fetchBlob(url) {
        const absoluteUrl = normalizeUrl(url);
        if (!absoluteUrl) return Promise.reject(new Error('Invalid URL'));

        const request = getRequestFunction();
        if (request) {
            return new Promise((resolve, reject) => {
                request({
                    method: 'GET',
                    url: absoluteUrl,
                    responseType: 'blob',
                    timeout: ASSET_REQUEST_TIMEOUT_MS,
                    onload: response => {
                        if (response.status >= 200 && response.status < 300 && response.response) {
                            resolve({
                                blob: response.response,
                                contentType: response.response.type || response.responseHeaders || '',
                            });
                        } else {
                            reject(new Error(`HTTP ${response.status}`));
                        }
                    },
                    onerror: () => reject(new Error('Network error')),
                    ontimeout: () => reject(new Error('Request timeout')),
                });
            });
        }

        const controller = typeof AbortController === 'function' ? new AbortController() : null;
        let timeoutId = 0;
        const clearRequestTimeout = () => {
            if (timeoutId) {
                window.clearTimeout(timeoutId);
                timeoutId = 0;
            }
        };
        const requestPromise = fetch(absoluteUrl, {
            credentials: 'include',
            signal: controller?.signal,
        })
            .then(response => {
                if (!response.ok) throw new Error(`HTTP ${response.status}`);
                return response.blob().then(blob => ({
                    blob,
                    contentType: response.headers.get('content-type') || blob.type || '',
                }));
            })
            .catch(error => {
                if (error?.name === 'AbortError') throw new Error('Request timeout');
                throw error;
            });

        return new Promise((resolve, reject) => {
            timeoutId = window.setTimeout(() => {
                if (controller) controller.abort();
                reject(new Error('Request timeout'));
            }, ASSET_REQUEST_TIMEOUT_MS);
            requestPromise
                .then(value => {
                    clearRequestTimeout();
                    resolve(value);
                }, error => {
                    clearRequestTimeout();
                    reject(error);
                });
        });
    }

    function triggerDownload(blob, filename) {
        const objectUrl = URL.createObjectURL(blob);
        const link = document.createElement('a');
        link.href = objectUrl;
        link.download = filename;
        document.body.appendChild(link);
        link.click();
        link.remove();
        window.setTimeout(() => URL.revokeObjectURL(objectUrl), 5000);
    }

    function buildSummaryText(item, downloadLog) {
        const lines = [
            `Title: ${item.title || 'N/A'}`,
            `Item ID: ${item.itemId || 'N/A'}`,
            `Page URL: ${item.pageUrl || 'N/A'}`,
            `Canonical URL: ${item.canonicalUrl || 'N/A'}`,
            `Price: ${item.price?.text || [item.price?.amount, item.currency].filter(Boolean).join(' ') || 'N/A'}`,
            `Seller username: ${item.sellerUsername || 'N/A'}`,
            `Seller ID: ${item.sellerId || 'N/A'}`,
            `Seller profile: ${item.sellerProfileUrl || 'N/A'}`,
            `Brand: ${item.brand || 'N/A'}`,
            `Category: ${item.category || 'N/A'}`,
            `Size: ${item.size || 'N/A'}`,
            `Condition: ${item.condition || 'N/A'}`,
            `Color: ${item.color || 'N/A'}`,
            `Material: ${item.material || 'N/A'}`,
            `Location: ${item.location || 'N/A'}`,
            `Favorites: ${item.favoriteCount || 'N/A'}`,
            `Views: ${item.viewCount || 'N/A'}`,
            `Upload date: ${item.uploadDate || 'N/A'}`,
            `Images included: ${downloadLog.includeImages ? 'Yes' : 'No'}`,
            `Photos detected: ${item.photos.length}`,
            `Photos saved: ${downloadLog.savedPhotos}`,
            `Photos failed: ${downloadLog.failedPhotos.length}`,
            `Archived at: ${item.archivedAt}`,
            '',
            'Description:',
            item.description || 'N/A',
            '',
            'Breadcrumbs:',
            item.breadcrumbs.join(' > ') || 'N/A',
            '',
            'Attributes:',
        ];

        const attributeEntries = Object.entries(item.attributes || {});
        if (attributeEntries.length) {
            for (const [key, value] of attributeEntries) {
                lines.push(`- ${key}: ${value}`);
            }
        } else {
            lines.push('- N/A');
        }

        return `${lines.join('\n')}\n`;
    }

    async function buildZipArchive(options = {}) {
        if (typeof JSZip !== 'function') throw new Error('JSZip did not load');

        const { item, raw } = collectItemData();
        if (!item.itemId) throw new Error('No Vinted item detected on this page');
        const includeImages = options.includeImages !== false;

        const archiveName = buildArchiveName(item);
        const zip = new JSZip();
        const photosFolder = zip.folder('photos');
        const rawFolder = zip.folder('raw');
        const sellerFolder = zip.folder('seller');
        const downloadLog = {
            includeImages,
            savedPhotos: 0,
            failedPhotos: [],
            savedSellerAssets: [],
        };

        if (includeImages) {
            for (const [index, photoUrl] of item.photos.entries()) {
                setStatus(`Downloading photo ${index + 1}/${item.photos.length}…`);
                try {
                    const { blob, contentType } = await fetchBlob(photoUrl);
                    const extension = getFileExtensionFromType(contentType, photoUrl);
                    photosFolder.file(`${String(index + 1).padStart(2, '0')}.${extension}`, blob);
                    downloadLog.savedPhotos += 1;
                } catch (error) {
                    downloadLog.failedPhotos.push({
                        url: photoUrl,
                        error: error?.message || 'Unknown error',
                    });
                }
            }

            if (item.sellerAvatarUrl) {
                setStatus('Downloading seller avatar…');
                try {
                    const { blob, contentType } = await fetchBlob(item.sellerAvatarUrl);
                    const extension = getFileExtensionFromType(contentType, item.sellerAvatarUrl);
                    sellerFolder.file(`avatar.${extension}`, blob);
                    downloadLog.savedSellerAssets.push('avatar');
                } catch (error) {
                    downloadLog.savedSellerAssets.push(`avatar_failed:${error?.message || 'unknown error'}`);
                }
            }
        } else {
            downloadLog.savedSellerAssets.push('avatar_skipped:user_setting');
        }

        const normalizedItem = {
            ...item,
            includeImages,
            photoCount: item.photos.length,
        };

        zip.file('metadata.json', prettyJson(normalizedItem));
        zip.file('summary.txt', buildSummaryText(normalizedItem, downloadLog));
        rawFolder.file('meta-tags.json', prettyJson(raw.metaTags));
        rawFolder.file('json-ld.json', prettyJson(raw.jsonLdObjects));
        rawFolder.file('json-parse-failures.json', prettyJson(raw.jsonParseFailures));
        rawFolder.file('dom-data.json', prettyJson({
            definitionListData: raw.definitionListData,
            breadcrumbs: raw.breadcrumbs,
            bestCandidate: raw.bestCandidate,
            sellerAvatar: raw.sellerAvatar,
            domPhotos: raw.domPhotos,
            primaryStructuredPhotos: raw.primaryStructuredPhotos,
            secondaryStructuredPhotos: raw.secondaryStructuredPhotos,
        }));
        rawFolder.file('download-log.json', prettyJson(downloadLog));
        rawFolder.file('page.html', raw.pageHtml.replace(/<script\b([^>]*)>([\s\S]*?)<\/script>/gi, '<script$1>/* script content omitted to keep archive size manageable */<\/script>'));
        rawFolder.file('context.json', prettyJson({
            locationHref: raw.locationHref,
            userAgent: raw.userAgent,
            archivedAt: normalizedItem.archivedAt,
            snapshotVersion: SNAPSHOT_VERSION,
        }));

        let lastReportedPercentage = -ZIP_PROGRESS_STEP;
        setStatus('Generating ZIP…');
        const blob = await zip.generateAsync({ type: 'blob' }, metadata => {
            if (!metadata) return;
            const percent = Math.floor(metadata.percent || 0);
            if (percent === 100 || percent >= lastReportedPercentage + ZIP_PROGRESS_STEP) {
                lastReportedPercentage = percent;
                setStatus(`Generating ZIP… ${percent}%`);
            }
        });
        triggerDownload(blob, `${archiveName}.zip`);
        setStatus(`Saved ${archiveName}.zip`);
    }

