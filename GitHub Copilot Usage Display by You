// ==UserScript==
// @name         GitHub Copilot Usage Display
// @namespace    http://tampermonkey.net/
// @version      2.4
// @description  Display Copilot premium usage with better parsing, refresh feedback, and GitHub-friendly styling
// @author       You
// @match        https://github.com/copilot*
// @match        https://github.com/features/copilot*
// @match        https://github.com/settings/copilot*
// @updateURL    https://raw.githubusercontent.com/EugenioLandi/userscripts/main/GitHub%20Copilot%20Usage%20Display%20by%20You
// @downloadURL  https://raw.githubusercontent.com/EugenioLandi/userscripts/main/GitHub%20Copilot%20Usage%20Display%20by%20You
// @grant        none
// @run-at       document-idle
// ==/UserScript==

(function () {
    'use strict';

    if (window.__copilotUsageDisplayInitialized) return;
    window.__copilotUsageDisplayInitialized = true;

    const SETTINGS_URL = 'https://github.com/settings/copilot/features';
    const REFRESH_INTERVAL = 5 * 60 * 1000;
    const DISPLAY_ID = 'copilot-usage-display';
    const DISPLAY_HOST_ID = 'copilot-usage-display-host';

    let refreshTimer = null;
    let routeKey = `${location.pathname}${location.search}${location.hash}`;

    function normalizeWhitespace(text) {
        return String(text || '').replace(/\s+/g, ' ').trim();
    }

    function clampPercentage(value) {
        const numeric = Number(value);
        if (!Number.isFinite(numeric)) return null;
        return Math.max(0, Math.min(100, Math.round(numeric)));
    }

    function parseCount(value) {
        const numeric = Number(String(value || '').replace(/[^\d.]/g, ''));
        return Number.isFinite(numeric) ? numeric : null;
    }

    function findPercentageInScripts(html) {
        const patterns = [
            /"usagePercentage"\s*:\s*(\d+(?:\.\d+)?)/i,
            /"percentUsed"\s*:\s*(\d+(?:\.\d+)?)/i,
            /"premiumRequestsUsedPercentage"\s*:\s*(\d+(?:\.\d+)?)/i,
            /"quotaPercent"\s*:\s*(\d+(?:\.\d+)?)/i,
            /"usedPercentage"\s*:\s*(\d+(?:\.\d+)?)/i,
            /"usagePercent(?:age)?"\s*:\s*(\d+(?:\.\d+)?)/i,
        ];

        for (const pattern of patterns) {
            const match = html.match(pattern);
            if (match) return clampPercentage(match[1]);
        }

        return null;
    }

    function scoreContext(context) {
        let score = 0;
        if (/premium/.test(context)) score += 5;
        if (/request/.test(context)) score += 3;
        if (/usage|limit|quota/.test(context)) score += 2;
        if (/monthly|billing|included/.test(context)) score += 1;
        if (/remaining/.test(context)) score += 1;
        return score;
    }

    function findPercentageInText(text) {
        const normalized = normalizeWhitespace(text).toLowerCase();
        const regex = /(\d+(?:\.\d+)?)\s*%/g;
        let best = null;

        for (const match of normalized.matchAll(regex)) {
            const index = match.index || 0;
            const context = normalized.slice(Math.max(0, index - 120), Math.min(normalized.length, index + 120));
            const score = scoreContext(context);
            if (!best || score > best.score) {
                best = { score, value: match[1] };
            }
        }

        return best ? clampPercentage(best.value) : null;
    }

    function findPercentageFromFractions(text) {
        const normalized = normalizeWhitespace(text);
        const patterns = [
            /(\d[\d,]*)\s*(?:of|\/)\s*(\d[\d,]*)\s+premium requests?/i,
            /premium requests?.{0,80}?(\d[\d,]*)\s*(?:of|\/)\s*(\d[\d,]*)/i,
            /(\d[\d,]*)\s+used\s+of\s+(\d[\d,]*)\s+premium requests?/i,
        ];

        for (const pattern of patterns) {
            const match = normalized.match(pattern);
            if (!match) continue;
            const used = parseCount(match[1]);
            const total = parseCount(match[2]);
            if (!used || !total) continue;
            return clampPercentage((used / total) * 100);
        }

        return null;
    }

    function findPercentageInProgressBars(doc) {
        const candidates = [...doc.querySelectorAll('[role="progressbar"][aria-valuenow]')];
        for (const el of candidates) {
            const context = normalizeWhitespace(el.closest('section, div, article')?.textContent || el.textContent).toLowerCase();
            if (!/premium|request|usage|limit|quota/.test(context)) continue;
            const value = clampPercentage(el.getAttribute('aria-valuenow'));
            if (value !== null) return value;
        }
        return null;
    }

    function requiresSignIn(doc) {
        return Boolean(
            doc.querySelector('form[action="/session"]') ||
            /sign in to github/i.test(doc.body?.textContent || '')
        );
    }

    async function fetchUsageState() {
        const response = await fetch(SETTINGS_URL, { credentials: 'include' });
        if (!response.ok) {
            throw new Error(`HTTP ${response.status}`);
        }

        const html = await response.text();
        const doc = new DOMParser().parseFromString(html, 'text/html');
        const percentage = (
            findPercentageInProgressBars(doc) ??
            findPercentageInScripts(html) ??
            findPercentageFromFractions(doc.body.textContent) ??
            findPercentageInText(doc.body.textContent)
        );

        return {
            percentage,
            requiresSignIn: percentage === null && requiresSignIn(doc),
        };
    }

    function getDisplayTheme(percentage) {
        if (percentage >= 90) {
            return {
                background: 'var(--color-danger-subtle, #fff1f0)',
                border: 'var(--color-danger-muted, #ff818266)',
                text: 'var(--color-danger-fg, #d1242f)',
            };
        }
        if (percentage >= 75) {
            return {
                background: 'var(--color-attention-subtle, #fff8e8)',
                border: 'var(--color-attention-muted, #d4a72c66)',
                text: 'var(--color-attention-fg, #9a6700)',
            };
        }
        return {
            background: 'var(--color-canvas-subtle, #f6f8fa)',
            border: 'var(--color-border-default, #d0d7de)',
            text: 'var(--color-fg-default, #24292f)',
        };
    }

    function isVisible(element) {
        return Boolean(element && element.isConnected && element.getClientRects().length > 0);
    }

    function ensureDisplay() {
        let container = document.getElementById(DISPLAY_ID);
        if (container) return container;

        container = document.createElement('button');
        container.id = DISPLAY_ID;
        container.type = 'button';
        container.style.cssText = [
            'display:inline-flex',
            'align-items:center',
            'padding:8px 12px',
            'margin-left:8px',
            'height:32px',
            'border-radius:6px',
            'border:1px solid var(--color-border-default, #d0d7de)',
            'background:var(--color-canvas-subtle, #f6f8fa)',
            'font:500 14px/1 -apple-system,BlinkMacSystemFont,"Segoe UI",Helvetica,Arial,sans-serif',
            'cursor:pointer',
            'white-space:nowrap',
            'user-select:none',
            'transition:background-color 0.2s',
        ].join(';');

        container.innerHTML = '<span data-role="value">Loading…</span>';
        container.title = 'Click to refresh';
        container.addEventListener('click', () => updateUsage(true));
        container.addEventListener('mouseenter', () => {
            container.dataset.preHoverBackground = container.style.background;
            container.style.background = 'var(--color-neutral-muted, #eaeef2)';
        });
        container.addEventListener('mouseleave', () => {
            container.style.background = container.dataset.preHoverBackground || 'var(--color-canvas-subtle, #f6f8fa)';
        });
        return container;
    }

    function ensureDisplayHost(target, mode = 'append') {
        let host = document.getElementById(DISPLAY_HOST_ID);
        if (!host) {
            host = document.createElement('div');
            host.id = DISPLAY_HOST_ID;
            host.style.cssText = 'display:inline-flex;align-items:center;';
        }

        if (target && (mode === 'after' ? host.previousElementSibling !== target : host.parentElement !== target)) {
            if (mode === 'after') {
                target.insertAdjacentElement('afterend', host);
            } else {
                target.appendChild(host);
            }
        }

        return host;
    }

    function findInsertionPoint() {
        const selectors = [
            { selector: '[data-testid="copilot-subpage-nav"]', mode: 'append' },
            { selector: '[data-testid*="copilot-subpage-nav"]', mode: 'append' },
            { selector: '[data-testid*="page-header-actions"]', mode: 'append' },
            { selector: 'header nav', mode: 'append' },
            { selector: '.UnderlineNav', mode: 'append' },
            { selector: 'main h1', mode: 'after' },
            { selector: 'main h2', mode: 'after' },
            { selector: '[role="main"] h1', mode: 'after' },
            { selector: '[role="main"] h2', mode: 'after' },
            { selector: 'header', mode: 'append' },
            { selector: 'main', mode: 'append' },
            { selector: '[role="main"]', mode: 'append' },
        ];

        for (const { selector, mode } of selectors) {
            const candidate = document.querySelector(selector);
            if (!isVisible(candidate)) continue;
            return { element: candidate, mode };
        }

        return { element: document.body, mode: 'append' };
    }

    function mountDisplay() {
        if (!document.body) return;
        const insertionPoint = findInsertionPoint();
        const host = ensureDisplayHost(insertionPoint.element, insertionPoint.mode);
        const display = ensureDisplay();
        if (display.parentElement !== host) {
            host.appendChild(display);
        }
    }

    function setDisplayState(text, percentage = null, title = 'Click to refresh') {
        const display = ensureDisplay();
        const value = display.querySelector('[data-role="value"]');
        value.textContent = text;
        display.title = title;

        const theme = getDisplayTheme(percentage ?? 0);
        display.style.background = percentage === null ? 'var(--color-canvas-subtle, #f6f8fa)' : theme.background;
        display.style.borderColor = percentage === null ? 'var(--color-border-default, #d0d7de)' : theme.border;
        display.style.color = percentage === null ? 'var(--color-fg-default, #24292f)' : theme.text;
        display.style.opacity = text === 'Refreshing…' ? '0.75' : '1';
    }

    async function updateUsage(force = false) {
        mountDisplay();
        const display = ensureDisplay();
        if (display.dataset.loading === '1' && !force) return;

        display.dataset.loading = '1';
        setDisplayState('Refreshing…');

        try {
            const { percentage, requiresSignIn: signInRequired } = await fetchUsageState();
            if (percentage === null) {
                const title = signInRequired
                    ? 'GitHub sign-in is required to read Copilot usage. Click to retry.'
                    : 'Usage percentage not found on the Copilot settings page. Click to retry.';
                setDisplayState('Unavailable', null, title);
                return;
            }

            const timestamp = new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
            setDisplayState(`${percentage}% • ${timestamp}`, percentage, `Last updated at ${timestamp}. Click to refresh.`);
        } catch (error) {
            console.error('[Copilot Usage Display] Failed to refresh usage:', error);
            setDisplayState('Error', null, `${error.message}. Click to retry.`);
        } finally {
            display.dataset.loading = '0';
        }
    }

    function watchRouteChanges() {
        const observer = new MutationObserver(() => {
            const currentRouteKey = `${location.pathname}${location.search}${location.hash}`;
            if (routeKey !== currentRouteKey) {
                routeKey = currentRouteKey;
                mountDisplay();
                updateUsage(true);
            } else {
                mountDisplay();
            }
        });
        observer.observe(document.body, { childList: true, subtree: true });
    }

    function init() {
        mountDisplay();
        updateUsage(true);
        clearInterval(refreshTimer);
        refreshTimer = setInterval(() => updateUsage(), REFRESH_INTERVAL);
        watchRouteChanges();
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init, { once: true });
    } else {
        init();
    }
})();
